# Sanity CMS
PUBLIC_SANITY_PROJECT_ID=your-project-id
PUBLIC_SANITY_DATASET=production

# EmailJS (렌탈 문의 이메일 발송)
PUBLIC_EMAILJS_SERVICE_ID=your-service-id
PUBLIC_EMAILJS_TEMPLATE_ID=your-template-id
PUBLIC_EMAILJS_PUBLIC_KEY=your-public-key

# EmailJS (협업 문의 이메일 발송)
PUBLIC_EMAILJS_COLLAB_TEMPLATE_ID=your-collab-template-id

# Admin
ADMIN_PASSWORD=your-admin-password
SANITY_API_TOKEN=your-sanity-write-token

# Google Indexing API (optional — enables auto crawl request on blog publish)
# 1) Google Cloud Console: create project, enable "Indexing API"
# 2) Create a service account, generate JSON key
# 3) Search Console → settings → users → add service account email as OWNER
# 4) Paste values below (private key keeps literal \n line breaks)
GOOGLE_INDEXING_SERVICE_ACCOUNT_EMAIL=
GOOGLE_INDEXING_PRIVATE_KEY=
