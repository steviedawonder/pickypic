---

const stats = [
  { number: '9+', label: '포토부스 모델', description: '테이블형부터 부스형까지 다양한 라인업', i18nLabel: 'why.stat1.label', i18nDesc: 'why.stat1.desc' },
  { number: '1,000+', label: '누적 이벤트', description: '브랜드, 기업, 파티 등 다양한 현장', i18nLabel: 'why.stat2.label', i18nDesc: 'why.stat2.desc' },
  { number: '1H', label: '빠른 응대', description: '업무시간 기준 1시간 이내 응답', i18nLabel: 'why.stat3.label', i18nDesc: 'why.stat3.desc' },
];

const features = [
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" /></svg>`,
    title: '맞춤형 디자인',
    description: '브랜드 아이덴티티에 맞는 래핑, 레터링, 프레임 커스터마이징',
    i18nTitle: 'why.feature1.title',
    i18nDesc: 'why.feature1.desc',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" /><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z" /></svg>`,
    title: '즉석 인화',
    description: '고화질 즉석 프린트로 현장에서 바로 추억을 간직',
    i18nTitle: 'why.feature2.title',
    i18nDesc: 'why.feature2.desc',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z" /></svg>`,
    title: '디지털 공유',
    description: 'QR코드를 통한 간편한 디지털 사진 공유',
    i18nTitle: 'why.feature3.title',
    i18nDesc: 'why.feature3.desc',
  },
  {
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.656-5.656a4 4 0 010-5.656 4 4 0 015.656 0l.707.707.707-.707a4 4 0 015.656 0 4 4 0 010 5.656L12.42 15.17a1 1 0 01-1 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: '전문 운영팀',
    description: '설치부터 운영, 철수까지 전담 스태프가 책임 관리',
    i18nTitle: 'why.feature4.title',
    i18nDesc: 'why.feature4.desc',
  },
];
---

<section class="bg-white py-24 lg:py-32 overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section Header -->
    <div class="gs-fade-up">
      <span class="text-[11px] font-semibold tracking-[0.5em] text-secondary uppercase">Why PICKYPIC</span>
      <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary" data-i18n="why.title">
        피키픽을 선택하는 이유
      </h2>
      <p class="mt-4 text-sm text-secondary max-w-lg" data-i18n="why.description">
        다양한 포토부스 라인업과 전문 운영 노하우로 특별한 순간을 완성합니다.
      </p>
    </div>

    <!-- Stats -->
    <div class="mt-16 gs-fade-up">
      <div class="grid gap-0 md:grid-cols-3 border border-border-light rounded-xl overflow-hidden">
        {stats.map((stat, i) => (
          <div
            class:list={[
              'p-8 lg:p-10 transition-colors hover:bg-bg-light',
              i < stats.length - 1 ? 'border-b md:border-b-0 md:border-r border-border-light' : '',
            ]}
          >
            <span class="text-3xl font-bold text-primary">{stat.number}</span>
            <h3 class="mt-3 text-base font-bold text-primary" data-i18n={stat.i18nLabel}>{stat.label}</h3>
            <p class="mt-2 text-sm text-secondary" data-i18n={stat.i18nDesc}>{stat.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Features -->
    <div class="mt-16 gs-stagger grid gap-6 md:grid-cols-2">
      {features.map((feature) => (
        <div class="group rounded-2xl border border-border-light bg-white p-8 transition-all duration-300 hover:border-primary/20 hover:shadow-lg">
          <div class="flex items-start gap-5">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-bg-light text-primary">
              <Fragment set:html={feature.icon} />
            </div>
            <div>
              <h3 class="text-lg font-bold text-primary" data-i18n={feature.i18nTitle}>{feature.title}</h3>
              <p class="mt-2 text-sm text-secondary leading-relaxed" data-i18n={feature.i18nDesc}>{feature.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
