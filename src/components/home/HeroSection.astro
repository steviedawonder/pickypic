---
import { sanityClient, bannerQueries } from '../../sanity/client';

// Fetch active banners from Sanity at build time
let sanityBanners: any[] = [];
try {
  sanityBanners = await sanityClient.fetch(bannerQueries.activeBanners);
} catch (e) {
  // Fallback to hardcoded if Sanity fetch fails
}

const fallbackDesktop = [
  '/images/hero/main-1.jpg',
  '/images/hero/main-2.jpg',
  '/images/hero/main-3.jpg',
];

const fallbackMobile = [
  '/images/hero/main-mo1.webp',
  '/images/hero/main-mo2.webp',
  '/images/hero/main-mo3.webp',
];

const hasSanityBanners = sanityBanners && sanityBanners.length > 0;

const desktopSlides = hasSanityBanners
  ? sanityBanners.map((b: any) => ({
      src: b.desktopImage?.asset?.url,
      alt: b.altText || '피키픽 포토부스',
      linkUrl: b.linkUrl || null,
    }))
  : fallbackDesktop.map((src, i) => ({ src, alt: `피키픽 포토부스 대여 — 모던 레트로 감성 포토부스 렌탈 서비스 ${i + 1}`, linkUrl: null }));

const mobileSlides = hasSanityBanners
  ? sanityBanners.map((b: any) => ({
      src: b.mobileImage?.asset?.url || b.desktopImage?.asset?.url,
      alt: b.altText || '피키픽 포토부스 모바일',
      linkUrl: b.linkUrl || null,
    }))
  : fallbackMobile.map((src, i) => ({ src, alt: `피키픽 포토부스 렌탈 — 기업행사 팝업스토어 포토부스 대여 ${i + 1}`, linkUrl: null }));
---

<section class="hero-section" style="background-color: #f7f7f5;">
  <!-- Desktop Version -->
  <div class="hero-desktop">
    <div class="hero-carousel" id="desktop-carousel">
      <div class="carousel-track" id="desktop-track">
        {desktopSlides.map((slide, i) => (
          <div class="carousel-slide" data-index={i}>
            {slide.linkUrl ? (
              <a href={slide.linkUrl}>
                <img src={slide.src} alt={slide.alt} loading={i === 0 ? 'eager' : 'lazy'} />
              </a>
            ) : (
              <img src={slide.src} alt={slide.alt} loading={i === 0 ? 'eager' : 'lazy'} />
            )}
          </div>
        ))}
      </div>

      <!-- Overlay Content -->
      <div class="hero-overlay-desktop">
        <div class="hero-title-desktop">
          <h1 class="hero-heading-desktop">PICKYPIC PHOTOBOOTH<span class="hero-reg-desktop">®</span></h1>
          <p class="hero-sub-desktop">PICK YOUR MOMENT!</p>
        </div>
        <div class="hero-buttons">
          <a href="/products" class="hero-btn" data-i18n="hero.products">제품소개</a>
          <a href="/rental" class="hero-btn" data-i18n="hero.rental">렌탈문의</a>
          <a href="https://smartstore.naver.com/pickypicphoto" target="_blank" rel="noopener noreferrer" class="hero-btn" data-i18n="hero.purchase">구매문의</a>
        </div>
      </div>

      <!-- Navigation Arrows -->
      <button class="carousel-arrow carousel-arrow-left" id="desktop-prev" aria-label="이전 슬라이드">
        <img src="/images/common/left.png" alt="" role="presentation" />
      </button>
      <button class="carousel-arrow carousel-arrow-right" id="desktop-next" aria-label="다음 슬라이드">
        <img src="/images/common/right.png" alt="" role="presentation" />
      </button>
    </div>
  </div>

  <!-- Mobile Version -->
  <div class="hero-mobile">
    <div class="hero-carousel" id="mobile-carousel">
      <div class="carousel-track" id="mobile-track">
        {mobileSlides.map((slide, i) => (
          <div class="carousel-slide" data-index={i}>
            {slide.linkUrl ? (
              <a href={slide.linkUrl}>
                <img src={slide.src} alt={slide.alt} loading={i === 0 ? 'eager' : 'lazy'} />
              </a>
            ) : (
              <img src={slide.src} alt={slide.alt} loading={i === 0 ? 'eager' : 'lazy'} />
            )}
          </div>
        ))}
      </div>

      <!-- Overlay Content -->
      <div class="hero-overlay-mobile">
        <div class="hero-title-mobile">
          <h1 class="hero-heading-mobile">PICKYPIC PHOTOBOOTH<span class="hero-reg-mobile">®</span></h1>
          <p class="hero-sub-mobile">PICK YOUR MOMENT!</p>
        </div>
        <div class="hero-buttons hero-buttons-mobile">
          <a href="/products" class="hero-btn hero-btn-mobile" data-i18n="hero.products">제품소개</a>
          <a href="/rental" class="hero-btn hero-btn-mobile" data-i18n="hero.rental">렌탈문의</a>
          <a href="https://smartstore.naver.com/pickypicphoto" target="_blank" rel="noopener noreferrer" class="hero-btn hero-btn-mobile" data-i18n="hero.purchase">구매문의</a>
        </div>
      </div>

      <!-- Navigation Arrows -->
      <button class="carousel-arrow carousel-arrow-left" id="mobile-prev" aria-label="이전 슬라이드">
        <img src="/images/common/left.png" alt="" role="presentation" />
      </button>
      <button class="carousel-arrow carousel-arrow-right" id="mobile-next" aria-label="다음 슬라이드">
        <img src="/images/common/right.png" alt="" role="presentation" />
      </button>
    </div>
  </div>
</section>

<style>
  .hero-section {
    width: 100%;
    overflow: hidden;
    padding-top: 45px;
  }

  @media (min-width: 769px) {
    .hero-section {
      padding-top: 60px;
    }
  }

  @media (max-width: 768px) {
    .hero-section {
      padding-top: 90px;
    }
  }

  /* Desktop / Mobile visibility */
  .hero-desktop {
    display: block;
  }
  .hero-mobile {
    display: none;
  }

  @media (max-width: 768px) {
    .hero-desktop {
      display: none;
    }
    .hero-mobile {
      display: block;
    }
  }

  /* Carousel */
  .hero-carousel {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .hero-desktop .hero-carousel {
    aspect-ratio: 100 / 55;
  }

  .hero-mobile .hero-carousel {
    aspect-ratio: 3 / 4;
  }

  .carousel-track {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    right: 0;
    width: 100%;
    height: 100%;
  }

  .carousel-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 1s ease-in-out;
  }

  .carousel-slide.active {
    opacity: 1;
  }

  .carousel-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Desktop Overlay */
  .hero-overlay-desktop {
    position: absolute;
    top: 50%;
    left: 26%;
    transform: translate(-50%, -50%);
    z-index: 10;
    text-align: left;
  }

  .hero-title-desktop {
    margin: 0 0 40px;
    text-align: left;
  }

  .hero-heading-desktop {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    font-size: 64px;
    letter-spacing: 0.005em;
    color: #1d1d1f;
    line-height: 1;
    margin: 0;
  }

  .hero-reg-desktop {
    font-size: 20px;
    position: relative;
    top: -1.4em;
    margin-left: 2px;
  }

  .hero-sub-desktop {
    font-family: Arial, Helvetica, sans-serif;
    font-weight: 500;
    font-size: 20px;
    letter-spacing: 0.08em;
    color: #1d1d1f;
    margin: 8px 0 0;
    padding-left: 2px;
  }

  /* Mobile Overlay */
  .hero-overlay-mobile {
    position: absolute;
    top: 5%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    text-align: center;
    width: 90%;
  }

  .hero-title-mobile {
    margin: 0 auto 16px;
    text-align: left;
  }

  .hero-heading-mobile {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    font-size: 38px;
    letter-spacing: 0.005em;
    color: #1d1d1f;
    line-height: 1;
    margin: 0;
  }

  .hero-reg-mobile {
    font-size: 12px;
    position: relative;
    top: -1.4em;
    margin-left: 1px;
  }

  .hero-sub-mobile {
    font-family: Arial, Helvetica, sans-serif;
    font-weight: 500;
    font-size: 14px;
    letter-spacing: 0.08em;
    color: #1d1d1f;
    margin: 6px 0 0;
    padding-left: 1px;
  }

  /* Buttons */
  .hero-buttons {
    display: flex;
    gap: 0;
    justify-content: flex-start;
    flex-wrap: nowrap;
    width: 100%;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50px;
    padding: 12px 0;
    flex: 1;
    font-size: 14.5px;
    font-weight: 700;
    background: #ffffff;
    color: #000000;
    border: 1px solid #A2A2A2;
    text-decoration: none;
    transition: background-color 0.3s, color 0.3s;
    cursor: pointer;
    white-space: nowrap;
    margin-right: 10px;
  }

  .hero-btn:last-child {
    margin-right: 0;
  }

  .hero-btn:hover {
    background: #000000;
    color: #ffffff;
  }

  /* Mobile Buttons */
  .hero-buttons-mobile {
    gap: 10px;
    flex-wrap: nowrap;
  }

  .hero-btn-mobile {
    padding: 10px 24px;
    font-size: 14px;
    border-radius: 50px;
  }

  /* Navigation Arrows */
  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    opacity: 0.7;
    transition: opacity 0.3s;
  }

  .carousel-arrow:hover {
    opacity: 1;
  }

  .carousel-arrow img {
    width: 40px;
    height: 40px;
  }

  @media (max-width: 768px) {
    .carousel-arrow img {
      width: 24px;
      height: 24px;
    }
  }

  .carousel-arrow-left {
    left: 20px;
  }

  .carousel-arrow-right {
    right: 20px;
  }
</style>

<script>
  function initCarousel(trackId: string, prevId: string, nextId: string, slideCount: number) {
    const track = document.getElementById(trackId);
    const prevBtn = document.getElementById(prevId);
    const nextBtn = document.getElementById(nextId);

    if (!track || !prevBtn || !nextBtn) return;

    const slides = track.querySelectorAll('.carousel-slide');
    let current = 0;
    let autoplayTimer: ReturnType<typeof setInterval>;

    // Initialize: show first slide
    slides[0]?.classList.add('active');

    function goTo(index: number) {
      slides[current]?.classList.remove('active');
      current = ((index % slideCount) + slideCount) % slideCount;
      slides[current]?.classList.add('active');
    }

    function next() {
      goTo(current + 1);
    }

    function prev() {
      goTo(current - 1);
    }

    function startAutoplay() {
      autoplayTimer = setInterval(next, 4000);
    }

    function resetAutoplay() {
      clearInterval(autoplayTimer);
      startAutoplay();
    }

    nextBtn.addEventListener('click', () => {
      next();
      resetAutoplay();
    });

    prevBtn.addEventListener('click', () => {
      prev();
      resetAutoplay();
    });

    startAutoplay();
  }

  function initAllCarousels() {
    const desktopCount = document.getElementById('desktop-track')?.querySelectorAll('.carousel-slide').length || 3;
    const mobileCount = document.getElementById('mobile-track')?.querySelectorAll('.carousel-slide').length || 3;
    initCarousel('desktop-track', 'desktop-prev', 'desktop-next', desktopCount);
    initCarousel('mobile-track', 'mobile-prev', 'mobile-next', mobileCount);
  }

  document.addEventListener('DOMContentLoaded', initAllCarousels);
  document.addEventListener('astro:after-swap', initAllCarousels);
</script>
