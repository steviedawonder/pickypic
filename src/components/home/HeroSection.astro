---
const desktopSlides = [
  '/images/hero/main-1.jpg',
  '/images/hero/main-2.jpg',
  '/images/hero/main-3.jpg',
];

const mobileSlides = [
  '/images/hero/main-mo1.jpg',
  '/images/hero/main-mo2.jpg',
  '/images/hero/main-mo3.jpg',
];
---

<section class="hero-section" style="background-color: #f7f7f5;">
  <!-- Desktop Version -->
  <div class="hero-desktop">
    <div class="hero-carousel" id="desktop-carousel">
      <div class="carousel-track" id="desktop-track">
        {desktopSlides.map((src, i) => (
          <div class="carousel-slide" data-index={i}>
            <img src={src} alt={`피키픽 포토부스 ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'} />
          </div>
        ))}
      </div>

      <!-- Overlay Content -->
      <div class="hero-overlay-desktop">
        <div class="hero-title-desktop">
          <h1 class="hero-heading-desktop">PICKYPIC PHOTOBOOTH<span class="hero-reg-desktop">®</span></h1>
          <p class="hero-sub-desktop">PICK YOUR MOMENT!</p>
        </div>
        <div class="hero-buttons">
          <a href="/products" class="hero-btn" data-i18n="hero.products">제품소개</a>
          <a href="/rental" class="hero-btn" data-i18n="hero.rental">렌탈문의</a>
          <a href="https://smartstore.naver.com/pickypicphoto" target="_blank" rel="noopener noreferrer" class="hero-btn" data-i18n="hero.purchase">구매문의</a>
        </div>
      </div>

      <!-- Navigation Arrows -->
      <button class="carousel-arrow carousel-arrow-left" id="desktop-prev" aria-label="이전 슬라이드">
        <img src="/images/common/left.png" alt="이전" />
      </button>
      <button class="carousel-arrow carousel-arrow-right" id="desktop-next" aria-label="다음 슬라이드">
        <img src="/images/common/right.png" alt="다음" />
      </button>
    </div>
  </div>

  <!-- Mobile Version -->
  <div class="hero-mobile">
    <div class="hero-carousel" id="mobile-carousel">
      <div class="carousel-track" id="mobile-track">
        {mobileSlides.map((src, i) => (
          <div class="carousel-slide" data-index={i}>
            <img src={src} alt={`피키픽 포토부스 모바일 ${i + 1}`} loading={i === 0 ? 'eager' : 'lazy'} />
          </div>
        ))}
      </div>

      <!-- Overlay Content -->
      <div class="hero-overlay-mobile">
        <div class="hero-title-mobile">
          <h1 class="hero-heading-mobile">PICKYPIC PHOTOBOOTH<span class="hero-reg-mobile">®</span></h1>
          <p class="hero-sub-mobile">PICK YOUR MOMENT!</p>
        </div>
        <div class="hero-buttons hero-buttons-mobile">
          <a href="/products" class="hero-btn hero-btn-mobile" data-i18n="hero.products">제품소개</a>
          <a href="/rental" class="hero-btn hero-btn-mobile" data-i18n="hero.rental">렌탈문의</a>
          <a href="https://smartstore.naver.com/pickypicphoto" target="_blank" rel="noopener noreferrer" class="hero-btn hero-btn-mobile" data-i18n="hero.purchase">구매문의</a>
        </div>
      </div>

      <!-- Navigation Arrows -->
      <button class="carousel-arrow carousel-arrow-left" id="mobile-prev" aria-label="이전 슬라이드">
        <img src="/images/common/left.png" alt="이전" />
      </button>
      <button class="carousel-arrow carousel-arrow-right" id="mobile-next" aria-label="다음 슬라이드">
        <img src="/images/common/right.png" alt="다음" />
      </button>
    </div>
  </div>
</section>

<style>
  .hero-section {
    width: 100%;
    overflow: hidden;
  }

  /* Desktop / Mobile visibility */
  .hero-desktop {
    display: block;
  }
  .hero-mobile {
    display: none;
  }

  @media (max-width: 768px) {
    .hero-desktop {
      display: none;
    }
    .hero-mobile {
      display: block;
    }
  }

  /* Carousel */
  .hero-carousel {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .hero-desktop .hero-carousel {
    aspect-ratio: 100 / 55;
  }

  .hero-mobile .hero-carousel {
    aspect-ratio: 1 / 1;
  }

  .carousel-track {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    display: flex;
    width: 300%;
    transition: transform 0.6s ease-in-out;
  }

  .carousel-slide {
    width: calc(100% / 3);
    height: 100%;
    flex-shrink: 0;
  }

  .carousel-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Desktop Overlay */
  .hero-overlay-desktop {
    position: absolute;
    top: 50%;
    left: 25%;
    transform: translate(-50%, -50%);
    z-index: 10;
    text-align: center;
  }

  .hero-title-desktop {
    margin: 50px auto;
    text-align: left;
  }

  .hero-heading-desktop {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    font-size: 72px;
    letter-spacing: 0.005em;
    color: #1d1d1f;
    line-height: 1;
    margin: 0;
  }

  .hero-reg-desktop {
    font-size: 22px;
    position: relative;
    top: -1.4em;
    margin-left: 2px;
  }

  .hero-sub-desktop {
    font-family: Arial, Helvetica, sans-serif;
    font-weight: 700;
    font-size: 22px;
    letter-spacing: 0.08em;
    color: #1d1d1f;
    margin: 8px 0 0;
  }

  /* Mobile Overlay */
  .hero-overlay-mobile {
    position: absolute;
    top: 20%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    text-align: center;
  }

  .hero-title-mobile {
    margin: 0 auto 20px;
    text-align: center;
  }

  .hero-heading-mobile {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    font-size: 36px;
    letter-spacing: 0.005em;
    color: #1d1d1f;
    line-height: 1;
    margin: 0;
  }

  .hero-reg-mobile {
    font-size: 12px;
    position: relative;
    top: -1.4em;
    margin-left: 1px;
  }

  .hero-sub-mobile {
    font-family: Arial, Helvetica, sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.08em;
    color: #1d1d1f;
    margin: 4px 0 0;
    text-align: left;
  }

  /* Buttons */
  .hero-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50px;
    padding: 18px 60px;
    font-size: 18px;
    font-weight: 700;
    background: #ffffff;
    color: #000000;
    border: 1px solid #A2A2A2;
    text-decoration: none;
    transition: background-color 0.3s, color 0.3s;
    cursor: pointer;
    white-space: nowrap;
  }

  .hero-btn:hover {
    background: #000000;
    color: #ffffff;
  }

  /* Mobile Buttons */
  .hero-buttons-mobile {
    gap: 8px;
  }

  .hero-btn-mobile {
    width: 93px;
    height: 38px;
    padding: 0;
    font-size: 14px;
  }

  /* Navigation Arrows */
  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 20;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    opacity: 0.7;
    transition: opacity 0.3s;
  }

  .carousel-arrow:hover {
    opacity: 1;
  }

  .carousel-arrow img {
    width: 40px;
    height: 40px;
  }

  @media (max-width: 768px) {
    .carousel-arrow img {
      width: 24px;
      height: 24px;
    }
  }

  .carousel-arrow-left {
    left: 20px;
  }

  .carousel-arrow-right {
    right: 20px;
  }
</style>

<script>
  function initCarousel(trackId: string, prevId: string, nextId: string, slideCount: number) {
    const track = document.getElementById(trackId);
    const prevBtn = document.getElementById(prevId);
    const nextBtn = document.getElementById(nextId);

    if (!track || !prevBtn || !nextBtn) return;

    let current = 0;
    let autoplayTimer: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      current = ((index % slideCount) + slideCount) % slideCount;
      track.style.transform = `translateX(-${current * (100 / slideCount)}%)`;
    }

    function next() {
      goTo(current + 1);
    }

    function prev() {
      goTo(current - 1);
    }

    function startAutoplay() {
      autoplayTimer = setInterval(next, 4000);
    }

    function resetAutoplay() {
      clearInterval(autoplayTimer);
      startAutoplay();
    }

    nextBtn.addEventListener('click', () => {
      next();
      resetAutoplay();
    });

    prevBtn.addEventListener('click', () => {
      prev();
      resetAutoplay();
    });

    startAutoplay();
  }

  function initAllCarousels() {
    initCarousel('desktop-track', 'desktop-prev', 'desktop-next', 3);
    initCarousel('mobile-track', 'mobile-prev', 'mobile-next', 3);
  }

  document.addEventListener('DOMContentLoaded', initAllCarousels);
  document.addEventListener('astro:after-swap', initAllCarousels);
</script>
