---
import Button from '@components/common/Button.astro';
---

<section class="relative flex h-screen min-h-[700px] items-end overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0">
    <div class="h-full w-full bg-gradient-to-br from-gray-900 via-gray-800 to-black">
      <!-- Placeholder: Replace with actual hero image -->
      <div class="absolute inset-0 flex items-center justify-center">
        <span class="text-[200px] font-bold text-white/[0.03] tracking-[0.3em] select-none">PICKYPIC</span>
      </div>
    </div>
    <!-- Overlays -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/30 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="hero-content relative z-10 w-full px-6 pb-20 md:px-16 lg:px-24">
    <p class="text-[10px] font-medium tracking-[0.4em] text-white/50 uppercase">
      Premium Photo Booth Rental
    </p>
    <h1 class="mt-4 text-[clamp(2.5rem,7vw,6.5rem)] font-bold leading-[0.9] tracking-tight text-white">
      특별한 순간을<br />담는 포토부스
    </h1>
    <div class="mt-7 h-[2px] w-14 bg-white/60"></div>
    <p class="mt-7 max-w-md text-sm leading-relaxed text-white/65 lg:text-base">
      브랜드 팝업, 기업 행사, 파티까지.<br />
      피키픽 포토부스로 잊지 못할 경험을 만들어보세요.
    </p>

    <!-- CTA Buttons -->
    <div class="mt-10 flex flex-wrap gap-4">
      <Button href="/products" variant="outline-white" size="lg">
        제품소개
      </Button>
      <Button href="/rental" variant="outline-white" size="lg">
        렌탈문의
      </Button>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 right-8 hidden lg:flex flex-col items-center gap-2 text-white/30">
    <span class="text-[10px] tracking-[0.3em] uppercase rotate-90 origin-center translate-x-4 mb-8">Scroll</span>
    <div class="h-12 w-[1px] bg-white/20 animate-pulse"></div>
  </div>
</section>
