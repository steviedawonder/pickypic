---
/**
 * PopupBanner - Sanity에서 활성화된 팝업 배너를 가져와 표시
 * 어드민 팝업 관리에서 등록/활성화/비활성화 가능
 */
import { createClient } from '@sanity/client';
import imageUrlBuilder from '@sanity/image-url';

const client = createClient({
  projectId: '7b9lcco4',
  dataset: 'production',
  useCdn: true,
  apiVersion: '2024-01-01',
});

const builder = imageUrlBuilder(client);

// 활성화된 팝업 배너만 가져오기
let banner: any = null;
let imageUrl = '';
try {
  const banners = await client.fetch(`*[_type == "popupBanner" && isActive == true] {
    _id, isActive, linkUrl, altText,
    image { asset-> { _id, url } }
  }`);
  banner = banners.length > 0 ? banners[0] : null;
  imageUrl = banner?.image?.asset?.url || '';
} catch (e) {
  // Sanity 접속 실패 시 팝업 표시 안 함
}
---

{banner && (
  <div id="popup-overlay" class="fixed inset-0 z-[9999] flex items-center justify-center bg-black/40" style="display:none;">
    <div class="popup-container relative w-[90vw] max-w-[500px] shadow-2xl">
      <!-- Popup Image -->
      <a href={banner.linkUrl || '/rental'}>
        <img
          src={imageUrl}
          alt={banner.altText || '피키픽 포토부스'}
          class="w-full block"
        />
      </a>
      <!-- Footer -->
      <div class="flex items-center justify-between bg-[#333] px-4 py-3 text-sm text-white">
        <button id="popup-dismiss-24h" class="flex items-center gap-1 hover:underline cursor-pointer">
          <span data-i18n="popup_banner.no_show">24시간 동안 다시 열람하지 않습니다.</span>
        </button>
        <button id="popup-close" class="flex items-center gap-1 hover:underline cursor-pointer">
          <span data-i18n="popup_banner.close">닫기</span> <span class="text-lg leading-none">&times;</span>
        </button>
      </div>
    </div>
  </div>

  <script is:inline>
    (function() {
      var STORAGE_KEY = 'pickypic-popup-dismissed';
      var overlay = document.getElementById('popup-overlay');
      if (!overlay) return;

      // Check if popup was dismissed within 24 hours
      var dismissed = localStorage.getItem(STORAGE_KEY);
      if (dismissed) {
        var dismissedTime = parseInt(dismissed, 10);
        if (Date.now() - dismissedTime < 24 * 60 * 60 * 1000) {
          return; // Still within 24h, don't show
        }
      }

      // Show popup
      overlay.style.display = 'flex';

      // Close popup
      function closePopup() {
        overlay.style.display = 'none';
      }

      // Dismiss for 24 hours
      document.getElementById('popup-dismiss-24h').addEventListener('click', function() {
        localStorage.setItem(STORAGE_KEY, Date.now().toString());
        closePopup();
      });

      // Simple close
      document.getElementById('popup-close').addEventListener('click', closePopup);

      // Close on overlay click (outside popup)
      overlay.addEventListener('click', function(e) {
        if (e.target === overlay) {
          closePopup();
        }
      });
    })();
  </script>
)}
