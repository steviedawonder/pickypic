---
import Button from '@components/common/Button.astro';
import { company } from '@data/company';
---

<section class="bg-primary py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
    <div class="gs-fade-up">
      <span class="text-[11px] font-semibold tracking-[0.5em] text-white/40 uppercase">Get Started</span>
      <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-white">
        렌탈이 필요하신가요?
      </h2>
      <p class="mt-4 text-base text-white/60 max-w-lg mx-auto">
        행사 규모와 컨셉에 맞는 최적의 포토부스를 제안해 드립니다.<br />
        업무시간 기준 1시간 이내 응답해 드립니다.
      </p>

      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <Button href="/rental" variant="outline-white" size="lg">
          렌탈문의 바로가기
        </Button>
        <a
          href={company.kakaoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-[#FEE500] px-8 py-4 text-base font-bold text-[#3C1E1E] transition-opacity hover:opacity-90"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 3C6.48 3 2 6.58 2 10.95c0 2.82 1.87 5.29 4.68 6.68-.15.55-.96 3.53-1 3.67 0 .08.03.16.09.21a.23.23 0 0 0 .22.02c.31-.04 3.56-2.33 4.12-2.72.6.09 1.22.14 1.89.14 5.52 0 10-3.58 10-7.95S17.52 3 12 3z" />
          </svg>
          카카오톡 문의
        </a>
      </div>

      <p class="mt-8 text-xs text-white/30">
        전화 문의: <a href={`tel:${company.phone}`} class="text-white/50 hover:text-white/70">{company.phone}</a>
      </p>
    </div>
  </div>
</section>
