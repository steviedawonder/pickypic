---
import { navItems } from '@data/navigation';

const currentPath = Astro.url.pathname;

const navI18nKeys = [
  'nav.about',
  'nav.products',
  'nav.rental',
  'nav.portfolio',
  'nav.support',
  'nav.ai',
  'nav.blog',
];
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 bg-white"
>
  <nav class="mx-auto flex max-w-[1440px] items-center justify-between px-[25px] pt-4 pb-4 lg:px-10 lg:pt-10 lg:pb-5">
    <!-- Logo -->
    <a href="/" class="flex items-center">
      <span class="logo-text text-[24px] lg:text-[38px] leading-none">PICKYPIC PHOTOBOOTH<span class="text-[9px] lg:text-[12px] relative -top-[1.4em] ml-0.5">®</span></span>
    </a>

    <!-- Desktop Menu + Language Selector -->
    <div class="hidden items-center gap-8 lg:flex">
      <ul class="flex items-center gap-8">
        {navItems.map((item, i) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'relative text-base font-medium tracking-wide transition-colors duration-300 hover:text-black pb-1',
                currentPath === item.href || currentPath.startsWith(item.href + '/')
                  ? 'text-black after:absolute after:bottom-0 after:left-0 after:right-0 after:h-[2px] after:bg-black'
                  : 'text-gray-600',
              ]}
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noopener noreferrer' : undefined}
              data-i18n={navI18nKeys[i]}
            >
              {item.label}
            </a>
          </li>
        ))}
        <!-- SHOP: EN + overseas IP only -->
        <li class="shop-nav-item hidden">
          <a
            href="/shop"
            class="relative text-base font-medium tracking-wide transition-colors duration-300 hover:text-black pb-1 text-gray-600"
          >
            SHOP
          </a>
        </li>
      </ul>

      <!-- Language Selector -->
      <div class="flex items-center gap-1 text-xs ml-4 border-l border-gray-200 pl-4">
        <svg class="w-4 h-4 text-gray-500 mr-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10" />
          <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
        </svg>
        <button type="button" class="lang-btn text-black font-bold cursor-pointer hover:text-black transition-colors" data-lang="ko">KO</button>
        <span class="text-gray-300">|</span>
        <button type="button" class="lang-btn text-gray-400 font-normal cursor-pointer hover:text-black transition-colors" data-lang="jp">JP</button>
        <span class="text-gray-300">|</span>
        <button type="button" class="lang-btn text-gray-400 font-normal cursor-pointer hover:text-black transition-colors" data-lang="en">EN</button>
      </div>
    </div>

    <!-- Mobile: Language Selector + Hamburger -->
    <div class="flex items-center gap-3 lg:hidden">
      <div class="flex items-center gap-1 text-[11px]">
        <svg class="w-3.5 h-3.5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10" />
          <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
        </svg>
        <button type="button" class="lang-btn text-black font-bold cursor-pointer" data-lang="ko">KO</button>
        <span class="text-gray-300">|</span>
        <button type="button" class="lang-btn text-gray-400 font-normal cursor-pointer" data-lang="jp">JP</button>
        <span class="text-gray-300">|</span>
        <button type="button" class="lang-btn text-gray-400 font-normal cursor-pointer" data-lang="en">EN</button>
      </div>
      <button
        id="mobile-menu-btn"
        class="flex flex-col gap-1.5"
        aria-label="메뉴 열기"
      >
        <span class="hamburger-line block h-[2px] w-6 bg-gray-800 transition-all duration-300"></span>
        <span class="hamburger-line block h-[2px] w-6 bg-gray-800 transition-all duration-300"></span>
        <span class="hamburger-line block h-[2px] w-4 ml-auto bg-gray-800 transition-all duration-300"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Horizontal Nav -->
  <div class="mobile-nav-bar lg:hidden">
    <div class="flex gap-6 px-4 py-2.5 overflow-x-auto scrollbar-hide whitespace-nowrap">
      {navItems.map((item, i) => (
        <a
          href={item.href}
          class:list={[
            'text-[13px] font-medium tracking-wide transition-colors duration-300 shrink-0',
            currentPath === item.href || currentPath.startsWith(item.href + '/')
              ? 'text-black'
              : 'text-gray-500',
          ]}
          data-i18n={navI18nKeys[i]}
        >
          {item.label}
        </a>
      ))}
      <a
        href="/shop"
        class="shop-nav-item hidden text-[13px] font-medium tracking-wide transition-colors duration-300 shrink-0 text-gray-500"
      >
        SHOP
      </a>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] translate-x-full transition-transform duration-500 ease-in-out"
>
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/20 backdrop-blur-sm" id="mobile-menu-backdrop"></div>

  <!-- Menu Panel -->
  <div class="absolute right-0 top-0 bottom-0 w-full max-w-sm bg-white shadow-2xl">
    <!-- Close Button -->
    <div class="flex items-center justify-between px-6 py-4">
      <a href="/">
        <span class="logo-text text-[20px] leading-none">PICKYPIC PHOTOBOOTH<span class="text-[10px] relative -top-[0.85em] ml-0.5">®</span></span>
      </a>
      <button id="mobile-menu-close" class="p-2" aria-label="메뉴 닫기">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Menu Items -->
    <nav class="px-6 pt-8">
      <ul class="space-y-1">
        {navItems.map((item, i) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'mobile-nav-link block py-4 text-lg font-medium tracking-wide transition-colors duration-200 border-b border-gray-100',
                currentPath === item.href || currentPath.startsWith(item.href + '/')
                  ? 'text-black'
                  : 'text-gray-600',
              ]}
              data-i18n={navI18nKeys[i]}
            >
              {item.label}
            </a>
          </li>
        ))}
        <!-- SHOP: EN + overseas IP only -->
        <li class="shop-nav-item hidden">
          <a
            href="/shop"
            class="mobile-nav-link block py-4 text-lg font-medium tracking-wide transition-colors duration-200 border-b border-gray-100 text-gray-600"
          >
            SHOP
          </a>
        </li>
      </ul>
    </nav>

    <!-- Contact Info -->
    <div class="absolute bottom-0 left-0 right-0 px-6 py-8 border-t border-gray-100">
      <p class="text-xs text-gray-400" data-i18n="nav.contact_phone">문의전화</p>
      <a href="tel:02-338-9181" class="text-sm font-semibold text-black">02-338-9181</a>
    </div>
  </div>
</div>

<style>
  .logo-text {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    letter-spacing: 0.005em;
    color: #1d1d1f;
  }
  .mobile-nav-bar {
    border-top: 1px solid #f0f0f0;
    border-bottom: 1px solid #f0f0f0;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-menu-close');
  const backdrop = document.getElementById('mobile-menu-backdrop');
  const mobileMenu = document.getElementById('mobile-menu');

  function openMenu() {
    mobileMenu?.classList.remove('translate-x-full');
    mobileMenu?.classList.add('translate-x-0');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu?.classList.add('translate-x-full');
    mobileMenu?.classList.remove('translate-x-0');
    document.body.style.overflow = '';
  }

  menuBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
