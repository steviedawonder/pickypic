---
import { navItems } from '@data/navigation';

interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header
  id="navbar"
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-all duration-500',
    transparent ? 'nav-transparent' : 'nav-solid',
  ]}
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 lg:px-8">
    <!-- Logo -->
    <a href="/" class="text-lg font-bold tracking-[0.15em] text-inherit">
      PICKYPIC
    </a>

    <!-- Desktop Menu -->
    <ul class="hidden items-center gap-8 lg:flex">
      {navItems.map((item) => (
        <li>
          {item.isCta ? (
            <a
              href={item.href}
              class="rounded-full bg-primary px-6 py-2.5 text-xs font-semibold tracking-[0.1em] text-white transition-all duration-300 hover:bg-black"
            >
              {item.label}
            </a>
          ) : (
            <a
              href={item.external ? item.href : item.href}
              class:list={[
                'text-sm font-medium tracking-[0.1em] transition-colors duration-300 hover:text-primary',
                currentPath === item.href
                  ? 'text-primary border-b border-primary pb-0.5'
                  : 'text-secondary',
              ]}
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noopener noreferrer' : undefined}
            >
              {item.label}
            </a>
          )}
        </li>
      ))}
    </ul>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="flex flex-col gap-1.5 lg:hidden"
      aria-label="메뉴 열기"
    >
      <span class="hamburger-line block h-[2px] w-6 bg-current transition-all duration-300"></span>
      <span class="hamburger-line block h-[2px] w-6 bg-current transition-all duration-300"></span>
      <span class="hamburger-line block h-[2px] w-4 ml-auto bg-current transition-all duration-300"></span>
    </button>
  </nav>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] translate-x-full transition-transform duration-500 ease-in-out"
>
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/20 backdrop-blur-sm" id="mobile-menu-backdrop"></div>

  <!-- Menu Panel -->
  <div class="absolute right-0 top-0 bottom-0 w-full max-w-sm bg-white shadow-2xl">
    <!-- Close Button -->
    <div class="flex items-center justify-between px-6 py-5">
      <span class="text-lg font-bold tracking-[0.15em]">PICKYPIC</span>
      <button id="mobile-menu-close" class="p-2" aria-label="메뉴 닫기">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Menu Items -->
    <nav class="px-6 pt-8">
      <ul class="space-y-1">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'mobile-nav-link block py-4 text-lg font-medium tracking-[0.05em] transition-colors duration-200 border-b border-border-light',
                currentPath === item.href ? 'text-primary' : 'text-secondary',
                item.isCta && 'text-primary font-bold',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Contact Info -->
    <div class="absolute bottom-0 left-0 right-0 px-6 py-8 border-t border-border-light">
      <p class="text-xs text-secondary">문의전화</p>
      <a href="tel:02-338-9181" class="text-sm font-semibold text-primary">02-338-9181</a>
    </div>
  </div>
</div>

<style>
  .nav-transparent {
    background: transparent;
    color: #ffffff;
  }

  .nav-solid {
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    color: var(--color-primary);
  }

  .nav-scrolled {
    background: rgba(255, 255, 255, 0.97) !important;
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06) !important;
    color: var(--color-primary) !important;
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.04);
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  if (navbar?.classList.contains('nav-transparent')) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 80) {
        navbar.classList.add('nav-scrolled');
      } else {
        navbar.classList.remove('nav-scrolled');
      }
    });
  }

  const menuBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('mobile-menu-close');
  const backdrop = document.getElementById('mobile-menu-backdrop');
  const mobileMenu = document.getElementById('mobile-menu');

  function openMenu() {
    mobileMenu?.classList.remove('translate-x-full');
    mobileMenu?.classList.add('translate-x-0');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu?.classList.add('translate-x-full');
    mobileMenu?.classList.remove('translate-x-0');
    document.body.style.overflow = '';
  }

  menuBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
