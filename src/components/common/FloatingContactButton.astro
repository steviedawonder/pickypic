---

---

<div id="floating-btns" class="fixed bottom-8 right-8 z-40 flex flex-col gap-3">
  <!-- 카카오톡 상담 버튼 -->
  <a
    href="http://pf.kakao.com/_qbEMb/chat"
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-3 rounded-full bg-[#FEE500] px-8 py-4.5 text-base font-bold text-[#191919] shadow-lg shadow-black/15 transition-all duration-300 hover:bg-[#F5DC00] hover:shadow-xl hover:-translate-y-0.5 active:translate-y-0"
    aria-label="카카오톡 상담"
  >
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 3C6.48 3 2 6.58 2 10.94c0 2.8 1.86 5.27 4.66 6.67-.15.53-.54 1.91-.62 2.21-.1.37.14.36.29.26.12-.08 1.93-1.31 2.71-1.84.94.14 1.92.21 2.96.21 5.52 0 10-3.58 10-7.5C22 6.58 17.52 3 12 3z"/>
    </svg>
    <span data-i18n="floating.kakao">카카오톡 상담</span>
  </a>

  <!-- 렌탈문의 버튼 -->
  <a
    href="/rental"
    class="flex items-center gap-3 rounded-full bg-primary px-8 py-4.5 text-base font-bold text-white shadow-lg shadow-black/15 transition-all duration-300 hover:bg-black hover:shadow-xl hover:-translate-y-0.5 active:translate-y-0"
    aria-label="렌탈문의 페이지로 이동"
  >
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
    </svg>
    <span data-i18n="floating.rental">렌탈문의</span>
  </a>
</div>

<style>
  #floating-btns {
    opacity: 0;
    transform: translateY(20px);
    animation: floatingBtnIn 0.6s ease-out 1s forwards;
  }

  @keyframes floatingBtnIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 640px) {
    #floating-btns {
      right: 1rem;
      bottom: 1.25rem;
    }

    #floating-btns a {
      padding: 0.875rem 1.5rem;
      font-size: 0.875rem;
    }
  }
</style>
