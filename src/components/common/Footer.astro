---
import { company } from '@data/company';
---

<footer class="bg-bg-charcoal text-white">
  <div class="mx-auto max-w-7xl px-6 py-8 lg:px-8 lg:py-16">
    <!-- Logo & Company Info -->
    <div class="lg:grid lg:grid-cols-3 lg:gap-10">
      <div>
        <img
          src="/images/common/footer-logo.png"
          alt="PICKYPIC PHOTOBOOTH®"
          class="h-6 lg:h-8 mb-4 lg:mb-6"
        />
        <address class="not-italic text-xs lg:text-sm text-white/60 leading-relaxed space-y-0.5 lg:space-y-1">
          <p><span data-i18n="footer.company_label">상호</span> : {company.name}</p>
          <p><span data-i18n="footer.business_number">사업자등록번호</span> : {company.businessNumber}</p>
          <p><span data-i18n="footer.address_label">주소</span> : {company.address}</p>
          <p><span data-i18n="footer.phone_label">전화번호</span> : <a href={company.phoneTel} class="hover:text-white/80 transition-colors">{company.phone}</a></p>
        </address>
        <p class="mt-3 lg:mt-6 text-[10px] lg:text-xs text-white/30">
          &copy; 2025 Picky Global Ltd. All rights reserved.
        </p>
      </div>

      <!-- Follow us & Contact us: side by side on mobile -->
      <div class="grid grid-cols-2 gap-4 mt-6 lg:mt-0 lg:col-span-2 lg:grid-cols-2">
        <!-- Follow us -->
        <div>
          <h3 class="text-xs lg:text-sm font-semibold tracking-wide mb-2 lg:mb-4">Follow us</h3>
          <div class="space-y-1 lg:space-y-2 text-xs lg:text-sm text-white/60 leading-relaxed">
            <p><span data-i18n="footer.kakao">카카오톡 채널</span> <a href={company.kakaoUrl} target="_blank" rel="noopener noreferrer" class="hover:text-white/80 transition-colors">{company.kakaoChannel}</a></p>
            <div>
              <p>Instagram  <a href={`https://www.instagram.com/${company.instagram.official}/`} target="_blank" rel="noopener noreferrer" class="hover:text-white/80 transition-colors">{company.instagram.official}</a></p>
              <p class="pl-[4.2rem] lg:pl-[5.5rem]"><a href={`https://www.instagram.com/${company.instagram.global}/`} target="_blank" rel="noopener noreferrer" class="hover:text-white/80 transition-colors">{company.instagram.global}</a></p>
              <p class="pl-[4.2rem] lg:pl-[5.5rem]"><a href={`https://www.instagram.com/${company.instagram.sg}/`} target="_blank" rel="noopener noreferrer" class="hover:text-white/80 transition-colors">{company.instagram.sg}</a></p>
            </div>
          </div>
        </div>

        <!-- Contact us -->
        <div>
          <h3 class="text-xs lg:text-sm font-semibold tracking-wide mb-2 lg:mb-4">Contact us</h3>
          <address class="not-italic space-y-1 lg:space-y-2 text-xs lg:text-sm text-white/60 leading-relaxed">
            <p>TEL <a href={company.phoneTel} class="hover:text-white/80 transition-colors">{company.phone}</a></p>
            <p>E-MAIL <a href={`mailto:${company.email}`} class="hover:text-white/80 transition-colors">{company.email}</a></p>
            <p><span data-i18n="footer.partnership">협업제안</span> <a href={`mailto:${company.partnerEmail}`} class="hover:text-white/80 transition-colors">{company.partnerEmail}</a></p>
          </address>
        </div>
      </div>
    </div>
  </div>
</footer>
