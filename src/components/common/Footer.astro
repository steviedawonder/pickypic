---
import { company } from '@data/company';
---

<footer class="bg-bg-charcoal text-white">
  <div class="mx-auto max-w-7xl px-6 py-14 lg:px-8 lg:py-16">
    <div class="grid gap-10 lg:grid-cols-3">
      <!-- Left Column: Logo & Company Info -->
      <div>
        <img
          src="/images/common/footer-logo.png"
          alt="PICKYPIC PHOTOBOOTH®"
          class="h-8 mb-6"
        />
        <div class="space-y-1 text-sm text-white/60 leading-relaxed">
          <p>상호 : {company.name}</p>
          <p>사업자등록번호 : {company.businessNumber}</p>
          <p>주소 : {company.address}</p>
          <p>전화번호 : {company.phone}</p>
        </div>
        <p class="mt-6 text-xs text-white/30">
          &copy; 2025 Picky Global Ltd. All rights reserved.
        </p>
      </div>

      <!-- Middle Column: Follow us -->
      <div>
        <h3 class="text-sm font-semibold tracking-wide mb-4">Follow us</h3>
        <div class="space-y-2 text-sm text-white/60 leading-relaxed">
          <p>카카오톡 채널 {company.kakaoChannel}</p>
          <div>
            <p>Instagram  {company.instagram.official}</p>
            <p class="pl-[5.5rem]">{company.instagram.global}</p>
            <p class="pl-[5.5rem]">{company.instagram.sg}</p>
          </div>
        </div>
      </div>

      <!-- Right Column: Contact us -->
      <div>
        <h3 class="text-sm font-semibold tracking-wide mb-4">Contact us</h3>
        <div class="space-y-2 text-sm text-white/60 leading-relaxed">
          <p>TEL {company.phone}</p>
          <p>E-MAIL {company.email}</p>
          <p>협업제안 {company.partnerEmail}</p>
        </div>
      </div>
    </div>
  </div>
</footer>
