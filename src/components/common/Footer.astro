---
import { company } from '@data/company';
---

<footer class="bg-bg-charcoal text-white">
  <div class="mx-auto max-w-7xl px-6 py-14 lg:px-8 lg:py-16">
    <div class="grid gap-10 lg:grid-cols-[1fr_2fr]">
      <!-- Brand -->
      <div>
        <p class="text-xl font-bold tracking-[0.1em]">{company.brand}</p>
        <p class="mt-2 text-sm text-white/50">{company.brandKo}</p>
        <div class="mt-6 flex items-center gap-4">
          <!-- KakaoTalk -->
          <a
            href={company.kakaoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1.5 rounded-full bg-[#FEE500] px-4 py-2 text-xs font-bold text-[#3C1E1E] transition-opacity hover:opacity-90"
            aria-label="카카오톡 채널"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 3C6.48 3 2 6.58 2 10.95c0 2.82 1.87 5.29 4.68 6.68-.15.55-.96 3.53-1 3.67 0 .08.03.16.09.21a.23.23 0 0 0 .22.02c.31-.04 3.56-2.33 4.12-2.72.6.09 1.22.14 1.89.14 5.52 0 10-3.58 10-7.95S17.52 3 12 3z" />
            </svg>
            TALK
          </a>
          <!-- Instagram -->
          <a
            href={`https://instagram.com/${company.instagram.official}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-white/50 transition-colors hover:text-white"
            aria-label="인스타그램"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Info Grid -->
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Contact -->
        <div>
          <h3 class="text-xs font-semibold tracking-[0.2em] text-white/40 uppercase mb-4">Contact</h3>
          <div class="space-y-3">
            <div>
              <p class="text-xs text-white/40">전화</p>
              <a href={`tel:${company.phone}`} class="text-sm text-white/80 hover:text-white">{company.phone}</a>
            </div>
            <div>
              <p class="text-xs text-white/40">이메일</p>
              <a href={`mailto:${company.email}`} class="text-sm text-white/80 hover:text-white break-all">{company.email}</a>
            </div>
            <div>
              <p class="text-xs text-white/40">협업 제안</p>
              <a href={`mailto:${company.partnerEmail}`} class="text-sm text-white/80 hover:text-white break-all">{company.partnerEmail}</a>
            </div>
          </div>
        </div>

        <!-- Address -->
        <div>
          <h3 class="text-xs font-semibold tracking-[0.2em] text-white/40 uppercase mb-4">Location</h3>
          <p class="text-sm text-white/80 leading-relaxed">{company.address}</p>
        </div>

        <!-- Links -->
        <div>
          <h3 class="text-xs font-semibold tracking-[0.2em] text-white/40 uppercase mb-4">Links</h3>
          <ul class="space-y-2">
            <li>
              <a href="/rental" class="text-sm text-white/80 hover:text-white">렌탈문의</a>
            </li>
            <li>
              <a href={company.naverStore} target="_blank" rel="noopener noreferrer" class="text-sm text-white/80 hover:text-white">
                네이버 스마트스토어
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/30">
        {company.name} | 사업자등록번호: {company.businessNumber}
      </p>
      <p class="text-xs text-white/30">
        &copy; {new Date().getFullYear()} {company.brand}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
