---
import { company } from '@data/company';
import { sanityClient } from '../../sanity/client';

// Fetch footer data from Sanity siteSettings at build time
let footerData: any = null;
try {
  footerData = await sanityClient.fetch(`*[_type == "siteSettings"][0] {
    companyName, businessNumber, address, phone, email, partnerEmail,
    kakaoChannel, kakaoUrl, instagramOfficial, instagramGlobal, instagramSg, naverStoreUrl
  }`);
} catch (e) {
  // Fallback to company.ts data
}

// Use Sanity data if available, otherwise fallback to company.ts
const footer = {
  name: footerData?.companyName || company.name,
  businessNumber: footerData?.businessNumber || company.businessNumber,
  address: footerData?.address || company.address,
  phone: footerData?.phone || company.phone,
  phoneTel: `tel:${(footerData?.phone || company.phone).replace(/[^0-9+]/g, '')}`,
  email: footerData?.email || company.email,
  partnerEmail: footerData?.partnerEmail || company.partnerEmail,
  kakaoChannel: footerData?.kakaoChannel || company.kakaoChannel,
  kakaoUrl: footerData?.kakaoUrl || company.kakaoUrl,
  instagram: {
    official: footerData?.instagramOfficial || company.instagram.official,
    global: footerData?.instagramGlobal || company.instagram.global,
    sg: footerData?.instagramSg || company.instagram.sg,
  },
};
---

<footer class="text-white relative z-10" style="background-color: #262626;">
  <div class="mx-auto max-w-7xl px-6 py-8 lg:px-8 lg:py-16">
    <!-- Logo & Company Info -->
    <div class="lg:grid lg:grid-cols-3 lg:gap-10">
      <div>
        <img
          src="/images/common/footer-logo.png"
          alt="PICKYPIC PHOTOBOOTH®"
          class="h-6 lg:h-8 mb-4 lg:mb-6"
        />
        <address class="not-italic text-xs lg:text-sm text-white/60 leading-relaxed space-y-0.5 lg:space-y-1">
          <p><span data-i18n="footer.company_label">상호</span> : <a href="/admin" style="color: inherit; text-decoration: none;">{footer.name}</a></p>
          <p><span data-i18n="footer.business_number">사업자등록번호</span> : {footer.businessNumber}</p>
          <p><span data-i18n="footer.address_label">주소</span> : {footer.address}</p>
          <p><span data-i18n="footer.phone_label">전화번호</span> : <a href={footer.phoneTel} class="hover:text-white/80 transition-colors">{footer.phone}</a></p>
        </address>
        <p class="mt-3 lg:mt-6 text-[10px] lg:text-xs text-white/30">
          &copy; {new Date().getFullYear()} Picky Global Ltd. All rights reserved.
        </p>
      </div>

      <!-- Follow us & Contact us -->
      <div class="grid grid-cols-2 gap-4 mt-6 lg:mt-0 lg:col-span-2 lg:grid-cols-2 lg:justify-items-end">
        <!-- Follow us -->
        <div>
          <h3 class="text-xs lg:text-sm font-semibold tracking-wide mb-2 lg:mb-4">Follow us</h3>
          <div class="space-y-1 lg:space-y-2 text-xs lg:text-sm text-white/60 leading-relaxed">
            <p><span data-i18n="footer.kakao">카카오톡 채널</span> <a href={footer.kakaoUrl} target="_blank" rel="noopener noreferrer" class="hover:text-white/80 transition-colors">{footer.kakaoChannel}</a></p>
            <div>
              <p>Instagram  <a href={`https://www.instagram.com/${footer.instagram.official}/`} target="_blank" rel="noopener noreferrer" class="hover:text-white/80 transition-colors">{footer.instagram.official}</a></p>
              <p class="pl-[4.2rem] lg:pl-[5.5rem]"><a href={`https://www.instagram.com/${footer.instagram.global}/`} target="_blank" rel="noopener noreferrer" class="hover:text-white/80 transition-colors">{footer.instagram.global}</a></p>
              <p class="pl-[4.2rem] lg:pl-[5.5rem]"><a href={`https://www.instagram.com/${footer.instagram.sg}/`} target="_blank" rel="noopener noreferrer" class="hover:text-white/80 transition-colors">{footer.instagram.sg}</a></p>
            </div>
          </div>
        </div>

        <!-- Contact us -->
        <div>
          <h3 class="text-xs lg:text-sm font-semibold tracking-wide mb-2 lg:mb-4">Contact us</h3>
          <address class="not-italic space-y-1 lg:space-y-2 text-xs lg:text-sm text-white/60 leading-relaxed">
            <p>TEL <a href={footer.phoneTel} class="hover:text-white/80 transition-colors">{footer.phone}</a></p>
            <p>E-MAIL <a href={`mailto:${footer.email}`} class="hover:text-white/80 transition-colors">{footer.email}</a></p>
            <p><span data-i18n="footer.partnership">협업제안</span> <a href={`mailto:${footer.partnerEmail}`} class="hover:text-white/80 transition-colors">{footer.partnerEmail}</a></p>
          </address>
        </div>
      </div>
    </div>
  </div>
</footer>
