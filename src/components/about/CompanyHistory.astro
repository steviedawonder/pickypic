---
const milestones = [
  {
    year: '2024',
    items: [
      {
        ko: '넷플릭스, 현대자동차, 기아 등 대형 브랜드 협업',
        en: 'Major brand collaborations with Netflix, Hyundai Motor, Kia, etc.',
        jp: 'ネットフリックス、現代自動車、起亜など大手ブランドとの協業',
      },
      {
        ko: '포토부스 라인업 9종 이상 확대',
        en: 'Photo booth lineup expanded to 9+ models',
        jp: 'フォトブースラインナップを9種類以上に拡大',
      },
      {
        ko: '아웃도어피키, 에어피키 신제품 출시',
        en: 'New product launches: Outdoor Picky & Air Picky',
        jp: 'アウトドアピキ、エアピキの新製品発売',
      },
    ],
  },
  {
    year: '2023',
    items: [
      {
        ko: '누적 이벤트 1,000건 돌파',
        en: 'Surpassed 1,000 cumulative events',
        jp: '累積イベント1,000件突破',
      },
      {
        ko: '뉴발란스, 로몽드 등 브랜드 팝업 협업',
        en: 'Brand pop-up collaborations with New Balance, Laumonde, etc.',
        jp: 'ニューバランス、ローモンドなどブランドポップアップ協業',
      },
      {
        ko: '모던 레트로 피키 라인 론칭',
        en: 'Modern Retro Picky line launched',
        jp: 'モダンレトロピキラインローンチ',
      },
    ],
  },
  {
    year: '2022',
    items: [
      {
        ko: '주식회사 피키글로벌 법인 설립',
        en: 'PICKYGLOBAL Co., Ltd. incorporated',
        jp: '株式会社ピキグローバル法人設立',
      },
      {
        ko: '스탠드형 포토부스 라인업 확대',
        en: 'Stand-type photo booth lineup expanded',
        jp: 'スタンド型フォトブースラインナップ拡大',
      },
      {
        ko: '기업 행사 전문 서비스 시작',
        en: 'Corporate event specialist service launched',
        jp: '企業イベント専門サービス開始',
      },
    ],
  },
  {
    year: '2021',
    items: [
      {
        ko: '피키픽 포토부스 브랜드 런칭',
        en: 'PICKYPIC photo booth brand launched',
        jp: 'ピキピックフォトブースブランドローンチ',
      },
      {
        ko: '테이블형 포토부스 최초 개발',
        en: 'First development of table-type photo booth',
        jp: 'テーブル型フォトブースを初開発',
      },
      {
        ko: '렌탈 서비스 시작',
        en: 'Rental service launched',
        jp: 'レンタルサービス開始',
      },
    ],
  },
];
---

<section class="py-20 lg:py-28 bg-bg-light">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-16 gs-fade-up">
      <p class="mb-4 text-[11px] font-semibold tracking-[0.5em] text-secondary uppercase">History</p>
      <h2 class="text-[clamp(1.5rem,2.5vw,2.25rem)] font-bold tracking-tight text-primary" data-i18n="history.title">
        피키픽의 여정
      </h2>
    </div>

    <div class="relative max-w-3xl mx-auto">
      <!-- Timeline line -->
      <div class="absolute left-6 lg:left-1/2 top-0 bottom-0 w-px bg-border-default lg:-translate-x-px"></div>

      <div class="space-y-12 gs-stagger">
        {milestones.map((milestone, i) => (
          <div class:list={[
            'relative pl-16 lg:pl-0 lg:flex lg:items-start lg:gap-12',
            i % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse',
          ]}>
            <!-- Dot -->
            <div class="absolute left-4 lg:left-1/2 top-1 w-5 h-5 bg-white border-2 border-primary rounded-full lg:-translate-x-1/2 z-10"></div>

            <!-- Year -->
            <div class:list={[
              'lg:w-1/2',
              i % 2 === 0 ? 'lg:text-right lg:pr-12' : 'lg:text-left lg:pl-12',
            ]}>
              <span class="text-3xl lg:text-4xl font-bold text-primary tracking-tight">{milestone.year}</span>
            </div>

            <!-- Content -->
            <div class:list={[
              'mt-3 lg:mt-0 lg:w-1/2',
              i % 2 === 0 ? 'lg:pl-12' : 'lg:pr-12 lg:text-right',
            ]}>
              <ul class="space-y-2">
                {milestone.items.map((item) => (
                  <li class="text-secondary leading-relaxed">
                    <span class="history-ko">{item.ko}</span>
                    <span class="history-en hidden">{item.en}</span>
                    <span class="history-jp hidden">{item.jp}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  function applyHistoryLang(lang: string) {
    document.querySelectorAll<HTMLElement>('.history-ko').forEach((koEl) => {
      const parent = koEl.parentElement;
      if (!parent) return;
      const targetEl = parent.querySelector<HTMLElement>(`.history-${lang}`);
      const hasTranslation = targetEl && targetEl !== koEl && targetEl.textContent?.trim();
      koEl.classList.toggle('hidden', !!hasTranslation);
      ['en', 'jp'].forEach((l) => {
        const el = parent.querySelector<HTMLElement>(`.history-${l}`);
        if (el) el.classList.toggle('hidden', l !== lang || !hasTranslation);
      });
    });
  }

  function initHistoryLang() {
    const lang = localStorage.getItem('pickypic-lang') || 'ko';
    applyHistoryLang(lang);
  }

  initHistoryLang();
  document.addEventListener('langChanged', (e: Event) => {
    applyHistoryLang((e as CustomEvent).detail);
  });
  document.addEventListener('astro:after-swap', initHistoryLang);
</script>
