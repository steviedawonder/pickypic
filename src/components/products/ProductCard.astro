---
import type { Product } from '@data/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<div class="group bg-white border border-border-light hover:border-primary/20 transition-all duration-300" data-category={product.category}>
  <!-- Image -->
  <div class="relative aspect-[4/3] bg-bg-light overflow-hidden">
    <div class="absolute inset-0 flex items-center justify-center text-secondary/30">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" />
      </svg>
    </div>
    <!-- Category badge -->
    <div class="absolute top-3 left-3 px-3 py-1 bg-primary text-white text-[10px] font-semibold tracking-[0.1em] uppercase">
      {product.categoryLabel}
    </div>
  </div>

  <!-- Content -->
  <div class="p-5 lg:p-6">
    <h3 class="text-lg font-bold text-primary tracking-tight mb-1">{product.name}</h3>
    <p class="text-xs text-secondary mb-4">{product.nameKo}</p>

    <!-- Specs -->
    <div class="mb-4 py-3 border-t border-b border-border-light">
      <p class="text-xs text-secondary">
        <span class="font-semibold text-primary">규격</span>&nbsp;&nbsp;{product.dimensions}
      </p>
    </div>

    <!-- Features -->
    <div class="flex flex-wrap gap-2">
      {product.features.map((feature) => (
        <span class="px-2.5 py-1 bg-bg-light text-xs text-secondary">{feature}</span>
      ))}
    </div>
  </div>
</div>
