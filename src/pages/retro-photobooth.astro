            <h4 class="text-sm font-bold tracking-[0.1em] text-primary uppercase mb-4 text-center">Photo booth specification</h4>
            <table class="w-full text-sm border-collapse"><tbody id="modal-specs-desktop"></tbody></table>
          </div>
          <div class="lg:col-span-3 flex items-center justify-center"><img id="modal-img-right" src="" alt="" class="max-w-full max-h-[320px]" /></div>
        </div>
        <div class="lg:hidden p-6">
          <div class="flex gap-4 justify-center mb-6 items-center">
            <div class="w-1/2 max-w-[180px] flex items-center justify-center"><img id="modal-img-left-m" src="" alt="" class="max-w-full max-h-[260px] object-contain" /></div>
            <div class="w-1/2 max-w-[180px] flex items-center justify-center"><img id="modal-img-right-m" src="" alt="" class="max-w-full max-h-[260px] object-contain" /></div>
          </div>
          <h4 class="text-sm font-bold tracking-[0.1em] text-primary uppercase mb-4 text-center">Photo booth specification</h4>
          <table class="w-full text-sm border-collapse"><tbody id="modal-specs-mobile"></tbody></table>
        </div>
        <div class="px-8 pb-8 flex justify-center gap-3">
