---
// SEO landing page for photo booth startup keywords
// Not linked in navigation — targets organic search traffic
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import FAQSchema from '@components/seo/FAQSchema.astro';
import { products } from '@data/products';

// Group products for startup recommendations
const smallMediumProducts = products.filter(p =>
  ['modern-picky', 'classic-picky', 'urban-picky', 'modern-mini-picky', 'urban-mini-picky', 'modern-retro-picky', 'urban-retro-picky'].includes(p.id)
);
const allProducts = products;

// FAQ data for structured markup
const faqItems = [
  {
    question: '포토부스 창업 초기 비용은 얼마나 드나요?',
    answer: '포토부스 창업 초기 비용은 기기 종류, 매장 규모, 인테리어 수준에 따라 달라집니다. 일반적으로 기기 구매비(1,000만~3,000만 원), 인테리어 비용(500만~2,000만 원), 초기 운영비(200만~500만 원) 등을 고려해야 합니다. 피키픽은 예산에 맞는 기기 추천과 창업 컨설팅을 제공합니다.',
  },
  {
    question: '포토부스 사업의 수익성은 어떤가요?',
    answer: '포토부스는 무인 운영이 가능해 인건비를 최소화할 수 있고, 1회 촬영당 3,000~6,000원의 매출이 발생합니다. 입지와 운영 방식에 따라 다르지만, 월 매출 300만~1,000만 원 이상을 기대할 수 있으며, 고정비가 낮아 투자 대비 수익률이 높은 편입니다.',
  },
  {
    question: '1인 운영이 가능한가요?',
    answer: '네, 가능합니다. 피키픽 포토부스는 사용자가 직접 촬영하는 셀프 방식이므로 상주 인력 없이 무인으로 운영할 수 있습니다. 원격 모니터링과 간단한 용지 교체 정도만 필요하며, 부업이나 다중 매장 운영에도 적합합니다.',
  },
  {
    question: 'A/S 및 기술 지원은 어떻게 받나요?',
    answer: '피키픽은 기기 판매 후에도 지속적인 A/S와 기술 지원을 제공합니다. 원격 진단을 통한 빠른 문제 해결, 방문 수리 서비스, 소프트웨어 업데이트 등을 지원하며, 전담 담당자가 배정되어 운영 중 발생하는 문제에 신속히 대응합니다.',
  },
  {
    question: '어떤 장소에 포토부스를 설치할 수 있나요?',
    answer: '피키픽 포토부스는 무인사진관, 카페, 쇼핑몰, 복합문화공간, 대학교, 영화관, 놀이공원 등 다양한 장소에 설치할 수 있습니다. 테이블형, 스탠드형, 부스형 등 9종 이상의 라인업이 있어 공간 크기와 용도에 맞게 선택 가능합니다.',
  },
  {
    question: '포토부스 창업까지 얼마나 걸리나요?',
    answer: '상담부터 기기 설치까지 보통 2~4주가 소요됩니다. 기기 선정, 맞춤 소프트웨어 세팅, 배송 및 설치, 운영 교육까지 원스톱으로 진행됩니다. 매장 인테리어를 포함할 경우 일정이 추가될 수 있습니다.',
  },
];
---

<BaseLayout
  title="포토부스 창업 · 셀프포토스튜디오 창업 비용 & 가이드 | 피키픽 PICKYPIC"
  description="포토부스 창업, 무인사진관 창업, 셀프포토스튜디오 창업을 준비하신다면 피키픽과 함께하세요. 9종 이상의 포토부스 라인업, 기기 판매부터 설치·A/S·운영 교육까지 올인원 창업 지원. 창업 비용 구성과 수익 모델을 확인하세요."
>
  <!-- Breadcrumb -->
  <BreadcrumbSchema items={[
    { name: '홈', href: '/' },
    { name: '포토부스 창업', href: '/photobooth-startup' },
  ]} />

  <!-- Hero Section -->
  <section class="relative bg-white pt-14 pb-10 lg:pt-12 lg:pb-14 overflow-hidden">
    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8 gs-fade-up">
      <h1 class="text-2xl lg:text-[clamp(2rem,5vw,3.5rem)] font-bold tracking-tight text-primary leading-tight">
        포토부스 창업, 피키픽과 함께 시작하세요
      </h1>
      <p class="mt-4 text-sm lg:text-base text-secondary leading-relaxed max-w-3xl">
        PICKYPIC(피키픽)은 포토부스 사업 창업을 기기 판매, 기술 지원, 운영 노하우로 지원합니다.
        스탠드형·테이블형·부스형 등 <strong>9종 이상의 포토부스 라인업</strong>을 보유하고 있어
        셀프포토스튜디오, 카페, 이벤트 사업 등 다양한 창업 형태에 맞는 최적의 솔루션을 제공합니다.
      </p>
    </div>
  </section>

  <!-- Why Photo Booth Startup -->
  <section class="bg-bg-muted py-16 lg:py-20" aria-labelledby="why-startup">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <h2 id="why-startup" class="text-xl lg:text-2xl font-bold text-primary mb-10 text-center gs-fade-up">
        포토부스 창업이 주목받는 이유
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 gs-stagger">
        <!-- Unmanned Operation -->
        <div class="bg-white rounded-lg p-6 lg:p-8 border border-border-light">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-primary mb-2">무인 운영 가능</h3>
          <p class="text-sm text-secondary leading-relaxed">
            셀프 촬영 방식으로 상주 인력 없이 운영할 수 있습니다. 1인 창업, 부업, 다중 매장 운영에 적합하며 인건비 부담을 최소화할 수 있습니다.
          </p>
        </div>
        <!-- Low Labor Cost -->
        <div class="bg-white rounded-lg p-6 lg:p-8 border border-border-light">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-primary mb-2">낮은 고정비, 높은 수익성</h3>
          <p class="text-sm text-secondary leading-relaxed">
            임대료와 소모품 비용 외 큰 고정비가 없어 투자 대비 수익률이 높습니다. 기기 한 대로도 안정적인 매출을 기대할 수 있습니다.
          </p>
        </div>
        <!-- MZ Generation Demand -->
        <div class="bg-white rounded-lg p-6 lg:p-8 border border-border-light">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-primary mb-2">MZ세대 수요 폭발</h3>
          <p class="text-sm text-secondary leading-relaxed">
            인생네컷, 포토그레이 등 셀프 사진 문화가 MZ세대를 중심으로 확산되며 시장이 빠르게 성장하고 있습니다. SNS 공유 문화와도 자연스럽게 연결됩니다.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Startup Type Guide -->
  <section class="bg-white py-16 lg:py-20" aria-labelledby="startup-types">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <h2 id="startup-types" class="text-xl lg:text-2xl font-bold text-primary mb-10 text-center gs-fade-up">
        창업 형태별 가이드
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 gs-stagger">
        <!-- Unmanned Photo Studio -->
        <div class="rounded-lg border border-border-default p-6 lg:p-8">
          <span class="inline-block text-xs font-semibold text-white bg-primary rounded-full px-3 py-1 mb-4">무인사진관</span>
          <h3 class="text-lg font-semibold text-primary mb-3">독립 매장형 셀프포토스튜디오</h3>
          <ul class="text-sm text-secondary leading-relaxed space-y-2">
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5">&#8226;</span>
              <span>역세권, 대학가, 상권 밀집 지역에 적합</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5">&#8226;</span>
              <span>10~30평 규모의 전용 공간 활용</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5">&#8226;</span>
              <span>복수 기기 배치로 회전율 극대화</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5">&#8226;</span>
              <span>추천 기기: 스탠드형, 부스형</span>
            </li>
          </ul>
        </div>
        <!-- Cafe Photo Zone -->
        <div class="rounded-lg border border-border-default p-6 lg:p-8">
          <span class="inline-block text-xs font-semibold text-white bg-primary rounded-full px-3 py-1 mb-4">카페 내 포토존</span>
          <h3 class="text-lg font-semibold text-primary mb-3">기존 매장에 포토부스 추가</h3>
          <ul class="text-sm text-secondary leading-relaxed space-y-2">
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5">&#8226;</span>
              <span>카페, 디저트숍, 복합공간에 추가 수익원</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5">&#8226;</span>
              <span>2~5평의 작은 공간에도 설치 가능</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5">&#8226;</span>
              <span>매장 체류 시간 증가 및 SNS 바이럴 효과</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5">&#8226;</span>
              <span>추천 기기: 테이블형, 미니 스탠드형</span>
            </li>
          </ul>
        </div>
        <!-- Event Rental Business -->
        <div class="rounded-lg border border-border-default p-6 lg:p-8">
          <span class="inline-block text-xs font-semibold text-white bg-primary rounded-full px-3 py-1 mb-4">이벤트 렌탈업</span>
          <h3 class="text-lg font-semibold text-primary mb-3">행사 대여 전문 사업</h3>
          <ul class="text-sm text-secondary leading-relaxed space-y-2">
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5">&#8226;</span>
              <span>웨딩, 기업 행사, 브랜드 팝업 등에 대여</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5">&#8226;</span>
              <span>별도 매장 없이 이동형으로 운영 가능</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5">&#8226;</span>
              <span>건당 높은 수익, 계절 수요 활용</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-primary mt-0.5">&#8226;</span>
              <span>추천 기기: 부스형(아웃도어, 에어피키)</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Recommended Equipment by Scale -->
  <section class="bg-bg-muted py-16 lg:py-20" aria-labelledby="recommended-equipment">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <h2 id="recommended-equipment" class="text-xl lg:text-2xl font-bold text-primary mb-4 text-center gs-fade-up">
        규모별 추천 기기
      </h2>
      <p class="text-sm text-secondary text-center mb-10 max-w-2xl mx-auto gs-fade-up">
        피키픽은 9종 이상의 포토부스를 보유하고 있어 창업 규모와 목적에 맞는 기기를 추천합니다. 각 제품을 클릭하면 상세 스펙을 확인할 수 있습니다.
      </p>

      <!-- 중소형 창업 -->
      <div class="mb-10 gs-fade-up">
        <h3 class="text-lg font-bold text-primary mb-1 flex items-center gap-2">
          <span class="inline-block w-2 h-2 bg-primary rounded-full"></span>
          중소형 창업 — 테이블형 + 스탠드형
        </h3>
        <p class="text-xs text-secondary mb-4 ml-4">카페, 소형 매장, 무인사진관 (2~20평) — 컴팩트한 사이즈부터 프리미엄 독립형까지</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 lg:gap-4">
          {smallMediumProducts.map((p) => (
            <button type="button" class="product-row bg-white rounded-xl border border-border-default p-4 text-center hover:border-primary hover:shadow-md transition-all duration-200 cursor-pointer group" data-product-id={p.id}>
              <div class="aspect-square bg-gray-50 rounded-lg mb-3 flex items-center justify-center overflow-hidden">
                <img src={p.imageRight} alt={`${p.nameKo} ${p.name}`} class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-300" loading="lazy" />
              </div>
              <p class="text-sm font-bold text-primary leading-tight">{p.nameKo}</p>
              <p class="text-[10px] text-secondary mt-0.5">{p.name}</p>
              <span class="inline-block text-[10px] text-primary/70 bg-primary/5 rounded-full px-2 py-0.5 mt-2">{p.categoryLabel}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- 대형 창업 -->
      <div class="gs-fade-up">
        <h3 class="text-lg font-bold text-primary mb-1 flex items-center gap-2">
          <span class="inline-block w-2 h-2 bg-primary rounded-full"></span>
          대형 창업 — 전 제품 라인업
        </h3>
        <p class="text-xs text-secondary mb-4 ml-4">대형 매장, 이벤트 렌탈업, 다중 매장 운영 (20평 이상) — 모든 기기를 활용한 풀 라인업 구성</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 lg:gap-4">
          {allProducts.map((p) => (
            <button type="button" class="product-row bg-white rounded-xl border border-border-default p-4 text-center hover:border-primary hover:shadow-md transition-all duration-200 cursor-pointer group" data-product-id={p.id}>
              <div class="aspect-square bg-gray-50 rounded-lg mb-3 flex items-center justify-center overflow-hidden">
                <img src={p.imageRight} alt={`${p.nameKo} ${p.name}`} class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-300" loading="lazy" />
              </div>
              <p class="text-sm font-bold text-primary leading-tight">{p.nameKo}</p>
              <p class="text-[10px] text-secondary mt-0.5">{p.name}</p>
              <span class="inline-block text-[10px] text-primary/70 bg-primary/5 rounded-full px-2 py-0.5 mt-2">{p.categoryLabel}</span>
            </button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Startup Cost Breakdown -->
  <section class="bg-white py-16 lg:py-20" aria-labelledby="startup-cost">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <h2 id="startup-cost" class="text-xl lg:text-2xl font-bold text-primary mb-10 text-center gs-fade-up">
        포토부스 창업 비용 구성
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 gs-stagger">
        <!-- Equipment Cost -->
        <div class="text-center p-6 lg:p-8 rounded-lg border border-border-default">
          <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-primary mb-2">기기 구매비</h3>
          <p class="text-2xl font-bold text-primary mb-2">1,000만 ~ 3,000만 원</p>
          <p class="text-sm text-secondary leading-relaxed">
            포토부스 기기 본체, 프린터, 소프트웨어 라이선스 포함. 기기 타입과 수량에 따라 달라집니다.
          </p>
        </div>
        <!-- Interior Cost -->
        <div class="text-center p-6 lg:p-8 rounded-lg border border-border-default">
          <div class="w-14 h-14 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
