---
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
---

<BaseLayout
  title="A.I 퍼스널컬러 | 피키픽 | 포토부스 대여 및 기업 행사 렌탈 전문"
  description="피키픽 포토부스의 AI 기반 퍼스널 컬러 진단 포토부스. 최신 AI 기술을 활용한 개인 맞춤형 컬러 진단 서비스."
>
  <BreadcrumbSchema items={[
    { name: '홈', href: '/' },
    { name: 'AI 퍼스널컬러', href: '/ai-personal-color' },
  ]} />

  <section class="pb-10 lg:pt-2 lg:pb-16 bg-white">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <div class="text-center mb-4 lg:mb-6 gs-fade-up">
        <h1 class="text-2xl lg:text-[clamp(2rem,4vw,3rem)] font-bold tracking-tight text-primary leading-tight">
          A.I 퍼스널 컬러 진단 포토부스
        </h1>
      </div>

      <div class="gs-fade-up">
        <a href="/ai-personal-color/detail" class="block group">
          <img
            src="/images/ai-personal-color/personal-color.jpg"
            alt="AI 퍼스널 컬러 진단 포토부스"
            class="w-full rounded-lg transition-transform duration-300 group-hover:scale-[1.01] cursor-pointer"
            width="1200"
            height="800"
            loading="eager"
          />
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
