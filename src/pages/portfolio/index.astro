---
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import { portfolioItems as localItems, portfolioCategories } from '@data/portfolio';
import { sanityClient, portfolioQueries } from '../../sanity/client';

// Fetch from Sanity
let sanityItems: any[] = [];
try {
  sanityItems = await sanityClient.fetch(portfolioQueries.allItems) || [];
} catch {
  sanityItems = [];
}

// Merge: Sanity items first, then local items as fallback
// Once migration is complete, local items can be removed
const allItems = [
  ...sanityItems.map((item: any) => ({
    id: item.slug?.current || item._id,
    title: item.title,
    image: item.thumbnail?.asset?.url || '',
    imageAlt: item.thumbnail?.alt || `${item.title} | 포토부스 렌탈`,
    category: item.category,
    href: `/portfolio/${item.slug?.current || item._id}`,
    source: 'sanity' as const,
  })),
  ...localItems.map((item) => ({
    id: String(item.id),
    title: item.title,
    image: item.image,
    imageAlt: `${item.title} | 포토부스 렌탈`,
    category: item.category,
    href: `/portfolio/${item.id}`,
    source: 'local' as const,
  })),
];
---

<BaseLayout
  title="포토부스 렌탈 포트폴리오 | 피키픽 PICKYPIC"
  description="넷플릭스, 현대자동차, 뉴발란스 등 유수 브랜드와 함께한 피키픽 포토부스 렌탈 사례를 확인하세요. 브랜드 팝업부터 기업 행사까지, 성공적인 이벤트를 만들어 드립니다."
>
  <BreadcrumbSchema items={[
    { name: '홈', href: '/' },
    { name: '포트폴리오', href: '/portfolio' },
  ]} />

  <!-- Hero: PORTFOLIO -->
  <section class="pt-10 pb-5 lg:pt-14 lg:pb-8 bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <h1 class="text-left lg:text-center text-2xl sm:text-3xl md:text-5xl lg:text-6xl font-black tracking-tight text-primary uppercase gs-fade-up">
        PORTFOLIO
      </h1>
    </div>
  </section>

  <!-- Category Filter Pills -->
  <section class="pb-3 lg:pb-6 bg-white" aria-label="포트폴리오 카테고리 필터">
    <div class="mx-auto max-w-[1600px] px-6 lg:px-8">
      <div class="relative" id="portfolio-pills-wrapper">
        <!-- Mobile scroll indicator left -->
        <button type="button" class="pills-scroll-left absolute left-0 top-1/2 -translate-y-1/2 -translate-x-1 z-10 w-7 h-7 bg-white/90 border border-gray-300 rounded-full flex items-center justify-center text-gray-500 shadow-sm lg:hidden opacity-0 pointer-events-none transition-opacity duration-200" aria-label="왼쪽 스크롤">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <nav class="overflow-x-auto scrollbar-hide pills-scroll-container" aria-label="포트폴리오 카테고리">
          <div class="flex gap-2.5 lg:gap-3 justify-start lg:justify-center min-w-max lg:min-w-0 lg:flex-wrap pb-2" id="category-pills">
            {portfolioCategories.map((cat, i) => (
              <button
                type="button"
                class:list={[
                  'portfolio-pill flex flex-col items-center justify-center px-2.5 lg:px-3 h-[42px] lg:h-[46px] rounded-full border transition-all duration-300 cursor-pointer whitespace-nowrap min-w-[100px] lg:min-w-[110px]',
                  i === 0
                    ? 'bg-primary text-white border-primary'
                    : 'bg-white text-primary border-border hover:border-primary',
                ]}
                data-category={cat.id}
                aria-pressed={i === 0 ? 'true' : 'false'}
              >
                <span class="text-[11px] lg:text-xs font-normal leading-tight">{cat.label}</span>
                {'labelEn' in cat && cat.labelEn && (
                  <span class="text-[10px] lg:text-xs font-normal mt-0.5 opacity-70 leading-tight">{cat.labelEn}</span>
                )}
              </button>
            ))}
          </div>
        </nav>
        <!-- Mobile scroll indicator right -->
        <button type="button" class="pills-scroll-right absolute right-0 top-1/2 -translate-y-1/2 translate-x-1 z-10 w-7 h-7 bg-white/90 border border-gray-300 rounded-full flex items-center justify-center text-gray-500 shadow-sm lg:hidden opacity-0 pointer-events-none transition-opacity duration-200" aria-label="오른쪽 스크롤">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- Search Bar -->
  <section class="pb-6 lg:pb-12 bg-white" aria-label="포트폴리오 검색">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-xs lg:max-w-md mx-auto relative">
        <input
          type="search"
          id="portfolio-search"
          placeholder="Search"
          class="w-full pl-4 pr-10 py-2 lg:py-3 border border-border rounded-md lg:rounded-xl text-sm text-primary placeholder-secondary focus:outline-none focus:border-primary transition-colors duration-300"
          aria-label="포트폴리오 검색"
        />
        <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-secondary" aria-label="검색">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 lg:w-5 lg:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
        </button>
      </div>
    </div>
  </section>

  <!-- Portfolio Gallery -->
  <section class="pb-16 lg:pb-24 bg-white" aria-label="포트폴리오 갤러리">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 lg:gap-8" id="portfolio-grid">
        {allItems.map((item) => (
          <article
            class="portfolio-item gs-fade-up"
            data-title={item.title.toLowerCase()}
            data-category={item.category}
            data-id={item.id}
            itemscope
            itemtype="https://schema.org/CreativeWork"
          >
            <a href={item.href} class="block">
              <div class="overflow-hidden rounded-lg">
                <img
                  src={item.image}
                  alt={item.imageAlt}
                  class="w-full aspect-[5/6] object-cover transition-transform duration-500 hover:scale-105"
                  loading="lazy"
                  itemprop="image"
                />
              </div>
              <h2 class="mt-2 text-[11px] lg:text-base font-semibold text-primary leading-snug line-clamp-1" itemprop="name">
                {item.title} | 포토부스 렌탈
              </h2>
            </a>
          </article>
        ))}
      </div>

      <!-- No Results Message -->
      <div id="no-results" class="hidden py-20 text-center">
        <p class="text-secondary text-lg" data-i18n="portfolio.no_results">검색 결과가 없습니다.</p>
      </div>

      <!-- Pagination -->
      <nav class="mt-12 lg:mt-16 flex justify-center items-center gap-2" id="pagination" aria-label="페이지 네비게이션">
      </nav>
    </div>
  </section>

  <!-- Structured Data: Portfolio -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "PICKYPIC 포트폴리오",
    "description": "피키픽 포토부스의 브랜드 협업 포트폴리오",
    "mainEntity": {
      "@type": "ItemList",
      "numberOfItems": allItems.length,
      "itemListElement": allItems.slice(0, 15).map((item, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "CreativeWork",
          "name": item.title,
          "image": item.image,
        }
      }))
    }
  })} />
</BaseLayout>

<style>
  /* Hide scrollbar for category pills */
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  .portfolio-item.hidden-item {
    display: none;
  }

  /* Pagination button styles */
  .page-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    height: 2.5rem;
    padding: 0 0.5rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    border: 1px solid transparent;
    background: transparent;
    color: var(--color-primary, #1d1d1f);
  }
  .page-btn:hover {
    background-color: #f5f5f7;
  }
  .page-btn.active {
    background-color: var(--color-primary, #1d1d1f);
    color: #fff;
    border-color: var(--color-primary, #1d1d1f);
  }
  .page-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }
  .page-btn.arrow-btn {
    font-size: 1rem;
  }
</style>

<script>
  function initPortfolio() {
    const ITEMS_PER_PAGE = 15;
    const allItems = Array.from(document.querySelectorAll<HTMLElement>('.portfolio-item'));
    const pills = document.querySelectorAll<HTMLButtonElement>('.portfolio-pill');
    const searchInput = document.getElementById('portfolio-search') as HTMLInputElement;
    const paginationNav = document.getElementById('pagination') as HTMLElement;
    const noResults = document.getElementById('no-results') as HTMLElement;

    if (!allItems.length || !paginationNav) return;

    let currentCategory = 'all';
    let searchQuery = '';
    let currentPage = 1;

    function getFilteredItems(): HTMLElement[] {
      return allItems.filter((item) => {
        const title = item.dataset.title || '';
        const category = item.dataset.category || '';
        const matchesSearch = !searchQuery || title.includes(searchQuery.toLowerCase());
        const matchesCategory = currentCategory === 'all' || category === currentCategory;
        return matchesSearch && matchesCategory;
      });
    }

    function renderPagination(totalItems: number) {
      const totalPages = Math.ceil(totalItems / ITEMS_PER_PAGE);
      if (totalPages <= 1) {
        paginationNav.innerHTML = '';
        return;
      }

      let html = '';
      html += `<button type="button" class="page-btn arrow-btn" data-page="prev" ${currentPage === 1 ? 'disabled' : ''} aria-label="이전 페이지">&lsaquo;</button>`;
      for (let i = 1; i <= totalPages; i++) {
        html += `<button type="button" class="page-btn ${i === currentPage ? 'active' : ''}" data-page="${i}" aria-label="페이지 ${i}" ${i === currentPage ? 'aria-current="page"' : ''}>${i}</button>`;
      }
      html += `<button type="button" class="page-btn arrow-btn" data-page="next" ${currentPage === totalPages ? 'disabled' : ''} aria-label="다음 페이지">&rsaquo;</button>`;

      paginationNav.innerHTML = html;

      paginationNav.querySelectorAll<HTMLButtonElement>('.page-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const page = btn.dataset.page;
          if (!page) return;
          const totalPgs = Math.ceil(totalItems / ITEMS_PER_PAGE);
          if (page === 'prev' && currentPage > 1) currentPage--;
          else if (page === 'next' && currentPage < totalPgs) currentPage++;
          else if (page !== 'prev' && page !== 'next') currentPage = parseInt(page, 10);
          updateDisplay();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      });
    }

    function updateDisplay() {
      const filtered = getFilteredItems();
      const totalPages = Math.ceil(filtered.length / ITEMS_PER_PAGE);
      if (currentPage > totalPages) currentPage = totalPages || 1;

      const startIdx = (currentPage - 1) * ITEMS_PER_PAGE;
      const endIdx = startIdx + ITEMS_PER_PAGE;

      allItems.forEach((item) => item.classList.add('hidden-item'));
      filtered.forEach((item, i) => {
        if (i >= startIdx && i < endIdx) {
          item.classList.remove('hidden-item');
          item.style.opacity = '1';
          item.style.transform = 'translateY(0)';
        }
      });

      noResults.classList.toggle('hidden', filtered.length > 0);
      renderPagination(filtered.length);
    }

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        currentCategory = pill.dataset.category || 'all';
        currentPage = 1;
        pills.forEach((p) => {
          if (p === pill) {
            p.classList.add('bg-primary', 'text-white', 'border-primary');
            p.classList.remove('bg-white', 'text-primary', 'border-border');
            p.setAttribute('aria-pressed', 'true');
          } else {
            p.classList.remove('bg-primary', 'text-white', 'border-primary');
            p.classList.add('bg-white', 'text-primary', 'border-border');
            p.setAttribute('aria-pressed', 'false');
          }
        });
        pill.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        updateDisplay();
      });
    });

    let searchTimeout: ReturnType<typeof setTimeout>;
    searchInput?.addEventListener('input', () => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        searchQuery = searchInput.value.trim();
        currentPage = 1;
        updateDisplay();
      }, 300);
    });

    updateDisplay();
  }

  function initPillsScrollIndicators() {
    const wrapper = document.getElementById('portfolio-pills-wrapper');
    if (!wrapper) return;
    const container = wrapper.querySelector('.pills-scroll-container') as HTMLElement;
    const leftBtn = wrapper.querySelector('.pills-scroll-left') as HTMLButtonElement;
    const rightBtn = wrapper.querySelector('.pills-scroll-right') as HTMLButtonElement;
    if (!container || !leftBtn || !rightBtn) return;

    function updateIndicators() {
      const { scrollLeft, scrollWidth, clientWidth } = container;
      const atStart = scrollLeft <= 5;
      const atEnd = scrollLeft + clientWidth >= scrollWidth - 5;
      leftBtn.style.opacity = atStart ? '0' : '1';
      leftBtn.style.pointerEvents = atStart ? 'none' : 'auto';
      rightBtn.style.opacity = atEnd ? '0' : '1';
      rightBtn.style.pointerEvents = atEnd ? 'none' : 'auto';
    }

    container.addEventListener('scroll', updateIndicators, { passive: true });
    window.addEventListener('resize', updateIndicators);
    leftBtn.addEventListener('click', () => container.scrollBy({ left: -150, behavior: 'smooth' }));
    rightBtn.addEventListener('click', () => container.scrollBy({ left: 150, behavior: 'smooth' }));
    setTimeout(updateIndicators, 100);
  }

  document.addEventListener('DOMContentLoaded', () => { initPortfolio(); initPillsScrollIndicators(); });
  document.addEventListener('astro:after-swap', () => { initPortfolio(); initPillsScrollIndicators(); });
</script>
