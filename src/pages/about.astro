---
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
---

<BaseLayout
  title="회사소개 페이지 | 피키픽 | 포토부스 대여 및 기업 행사 렌탈 전문"
  description="피키픽 포토부스는 브랜드 팝업스토어, 기업 행사, 웨딩, 파티 등 다양한 이벤트에 맞춤형 포토부스 렌탈 서비스를 제공합니다. PICKYPIC PHOTOBOOTH 회사소개."
>
  <!-- About Page Schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "피키픽 회사소개",
    "description": "피키픽 포토부스는 2020년 설립된 프리미엄 포토부스 렌탈 전문 기업입니다.",
    "url": "https://picky-pic.com/about",
    "mainEntity": {
      "@type": "LocalBusiness",
      "@id": "https://picky-pic.com/#organization"
    }
  })} />

  <BreadcrumbSchema items={[
    { name: '홈', href: '/' },
    { name: '회사소개', href: '/about' },
  ]} />

  <!-- Hero Carousel -->
  <section class="about-hero" aria-label="회사소개 히어로 이미지">
    <!-- Desktop -->
    <div class="about-hero-desktop">
      <img
        src="/images/company/company-hero.jpg"
        alt="피키픽 포토부스 회사소개"
        loading="eager"
        width="1920"
        height="1056"
      />
    </div>
    <!-- Mobile -->
    <div class="about-hero-mobile">
      <img
        src="/images/company/company-hero-mo.jpg"
        alt="피키픽 포토부스 회사소개"
        loading="eager"
        width="750"
        height="750"
      />
    </div>
  </section>

  <!-- Company Buttons -->
  <article class="about-content">
    <section class="about-intro gs-fade-up">
      <nav class="about-buttons" aria-label="회사 관련 링크">
        <a href="#" class="about-btn" download data-i18n="about.btn_company">회사소개</a>
        <a href="/products" class="about-btn" data-i18n="about.btn_products">제품소개</a>
        <a href="mailto:pickypic.marketing@gmail.com" class="about-btn" data-i18n="about.btn_partnership">협업제안</a>
      </nav>
    </section>
  </article>
</BaseLayout>

<style>
  /* Hero */
  .about-hero {
    width: 100%;
    overflow: hidden;
    padding-top: 90px;
  }

  @media (max-width: 768px) {
    .about-hero {
      padding-top: 95px;
    }
  }

  .about-hero-desktop {
    display: block;
  }

  .about-hero-mobile {
    display: none;
  }

  .about-hero img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .about-hero-desktop {
      display: none;
    }
    .about-hero-mobile {
      display: block;
    }
  }

  /* Content */
  .about-content {
    display: flex;
    justify-content: center;
    position: relative;
    margin-top: -180px;
    padding: 0 24px 80px;
    z-index: 1;
  }

  .about-intro {
    max-width: 720px;
    text-align: center;
  }

  /* Buttons */
  .about-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .about-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50px;
    padding: 18px 60px;
    font-size: 18px;
    font-weight: 700;
    background: #ffffff;
    color: #000000;
    border: 1px solid #a2a2a2;
    text-decoration: none;
    transition: background-color 0.3s, color 0.3s;
    cursor: pointer;
    white-space: nowrap;
  }

  .about-btn:hover {
    background: #000000;
    color: #ffffff;
  }

  @media (max-width: 768px) {
    .about-content {
      margin-top: 0;
      padding: 30px 20px 60px;
    }

    .about-buttons {
      gap: 8px;
      flex-wrap: nowrap;
    }

    .about-btn {
      padding: 10px 24px;
      font-size: 13px;
    }
  }
</style>
