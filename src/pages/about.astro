---
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
---

<BaseLayout
  title="피키픽 회사소개 | 포토부스 렌탈 전문 기업 PICKYPIC"
  description="2020년 설립된 피키픽은 넷플릭스·현대자동차·스타벅스 등 1,000건 이상의 브랜드 팝업 및 기업 행사에 포토부스를 제공하는 프리미엄 포토부스 렌탈 전문 기업입니다."
>
  <!-- About Page Schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "피키픽 회사소개",
    "description": "피키픽 포토부스는 2020년 설립된 프리미엄 포토부스 렌탈 전문 기업입니다.",
    "url": "https://picky-pic.com/about",
    "mainEntity": {
      "@type": "LocalBusiness",
      "@id": "https://picky-pic.com/#organization"
    }
  })} />

  <BreadcrumbSchema items={[
    { name: '홈', href: '/' },
    { name: '회사소개', href: '/about' },
  ]} />

  <!-- Hero Carousel -->
  <section class="about-hero" aria-label="회사소개 히어로 이미지">
    <!-- Desktop -->
    <div class="about-hero-desktop">
      <img
        src="/images/company/company-hero.jpg"
        alt="피키픽 포토부스 회사소개 — 서울 성수동 프리미엄 포토부스 렌탈 기업 PICKYPIC"
        loading="eager"
        width="1920"
        height="1056"
      />
    </div>
    <!-- Mobile -->
    <div class="about-hero-mobile">
      <img
        src="/images/company/company-hero-mo.jpg"
        alt="피키픽 포토부스 회사소개 — 서울 성수동 프리미엄 포토부스 렌탈 기업 PICKYPIC"
        loading="eager"
        width="750"
        height="750"
      />
    </div>
  </section>

  <!-- GEO: Company facts for AI citation -->
  <section class="py-10 lg:py-14 bg-white">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <p class="text-sm lg:text-base text-secondary leading-relaxed text-center">
        피키픽포토부스(PICKYPIC Photobooth)는 2020년 설립된 서울 성수동 소재 프리미엄 포토부스 렌탈 전문 기업입니다.
        스탠드형, 테이블형, 부스형 등 9종 이상의 포토부스 라인업을 보유하고 있으며,
        넷플릭스, 현대자동차, 기아, 뉴발란스, 스타벅스 등 1,000건 이상의 브랜드 팝업 및 기업 행사에 포토부스를 제공하고 있습니다.
        한국과 싱가포르에서 서비스를 운영하며, 브랜드 맞춤 커스터마이징과 AI 퍼스널 컬러 분석 등 혁신적인 포토 경험을 선사합니다.
      </p>
    </div>
  </section>

  <!-- Company Buttons -->
  <article class="about-content">
    <section class="about-intro gs-fade-up">
      <nav class="about-buttons" aria-label="회사 관련 링크">
        <a href="/files/company/PICKYPIC_회사소개서_KR.pdf" class="about-btn" download id="company-pdf-btn" data-i18n="about.btn_company">회사소개</a>
        <a href="/products" class="about-btn" data-i18n="about.btn_products">제품소개</a>
        <a href="/collaboration" class="about-btn" data-i18n="about.btn_partnership">협업제안</a>
      </nav>
    </section>
  </article>
</BaseLayout>

<script>
  import { getCurrentLang } from '../i18n/i18n';

  const pdfMap: Record<string, string> = {
    ko: '/files/company/PICKYPIC_회사소개서_KR.pdf',
    en: '/files/company/PICKYPIC_Company_Introduction_EN.pdf',
    jp: '/files/company/PICKYPIC_Company_Introduction_JP.pdf',
  };

  function updatePdfLink() {
    const btn = document.getElementById('company-pdf-btn') as HTMLAnchorElement | null;
    if (btn) btn.href = pdfMap[getCurrentLang()] || pdfMap.ko;
  }

  updatePdfLink();
  document.addEventListener('langChanged', updatePdfLink);
</script>

<style>
  /* Hero */
  .about-hero {
    width: 100%;
    overflow: hidden;
    padding-top: 0;
    margin-bottom: -15vw;
  }

  @media (max-width: 768px) {
    .about-hero {
      padding-top: 50px;
      margin-bottom: -20px;
    }
  }

  .about-hero-desktop {
    display: block;
  }

  .about-hero-mobile {
    display: none;
  }

  .about-hero img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .about-hero-desktop {
      display: none;
    }
    .about-hero-mobile {
      display: block;
    }
  }

  /* Content */
  .about-content {
    display: flex;
    justify-content: center;
    position: relative;
    margin-top: 0;
    padding: 0 24px 20px;
    z-index: 1;
  }

  .about-intro {
    max-width: 720px;
    text-align: center;
  }

  /* Buttons */
  .about-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .about-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50px;
    padding: 18px 60px;
    font-size: 18px;
    font-weight: 700;
    background: #ffffff;
    color: #000000;
    border: 1px solid #a2a2a2;
    text-decoration: none;
    transition: background-color 0.3s, color 0.3s;
    cursor: pointer;
    white-space: nowrap;
  }

  .about-btn:hover {
    background: #000000;
    color: #ffffff;
  }

  @media (max-width: 768px) {
    .about-content {
      margin-top: 0;
      padding: 30px 20px 30px;
    }

    .about-buttons {
      gap: 8px;
      flex-wrap: nowrap;
    }

    .about-btn {
      padding: 10px 24px;
      font-size: 13px;
    }
  }
</style>
