---
// SEO landing page for photobooth rental keywords
// Not linked from navigation — captures organic search traffic
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import ServiceSchema from '@components/seo/ServiceSchema.astro';
import FAQSchema from '@components/seo/FAQSchema.astro';
import { products } from '@data/products';

// FAQ items for structured data and visual section
const faqItems = [
  {
    question: '포토부스 대여 가격은 얼마인가요?',
    answer: '포토부스 대여 가격은 모델, 행사 규모, 운영 시간에 따라 달라집니다. 스탠드형·테이블형·부스형 등 9종의 포토부스 중 행사에 맞는 최적의 모델을 추천드리며, 정확한 견적은 문의를 통해 안내받으실 수 있습니다.',
  },
  {
    question: '포토부스 렌탈 절차는 어떻게 되나요?',
    answer: '문의 접수 → 맞춤 견적 안내 → 계약 및 결제 → 현장 설치 → 운영 지원 → 철거의 순서로 진행됩니다. 문의 후 영업시간 기준 1시간 이내에 답변을 드리고 있습니다.',
  },
  {
    question: '포토부스 대여 시 최소 운영 시간이 있나요?',
    answer: '최소 운영 시간은 2시간부터이며, 행사 성격에 따라 유연하게 조정이 가능합니다. 반일(4시간), 종일(8시간) 등 다양한 패키지를 제공하고 있습니다.',
  },
  {
    question: '서울 외 지역에서도 포토부스 대여가 가능한가요?',
    answer: '네, 전국 어디든 출장 설치가 가능합니다. 서울·수도권 외에도 부산, 대구, 제주 등 전국 지역은 물론 해외(싱가포르 등) 행사에도 포토부스를 제공하고 있습니다.',
  },
  {
    question: '인생네컷처럼 프레임을 커스텀할 수 있나요?',
    answer: '네, 피키픽의 모든 포토부스는 프레임 디자인을 자유롭게 커스터마이징할 수 있습니다. 브랜드 로고, 행사 테마, 컬러 등을 반영한 맞춤 프레임을 제작해 드립니다.',
  },
  {
    question: '포토부스 대여 시 운영 인력도 지원되나요?',
    answer: '네, 포토부스 대여 시 전문 운영 스태프가 현장에 상주하여 장비 운영 및 고객 안내를 도와드립니다. 설치부터 철거까지 원스톱으로 진행됩니다.',
  },
];
---

<BaseLayout
  title="포토부스 대여 · 포토부스 렌탈 가격 안내 | 피키픽 PICKYPIC"
  description="포토부스 대여, 포토부스 렌탈, 인생네컷 대여 전문 피키픽(PICKYPIC). 스탠드형·테이블형·부스형 등 9종의 프리미엄 포토부스를 브랜드 팝업, 기업 행사, 웨딩에 제공합니다. 지금 견적을 요청하세요."
>
  <!-- Structured data -->
  <BreadcrumbSchema items={[
    { name: '홈', href: '/' },
    { name: '포토부스 대여', href: '/photobooth-rental' },
  ]} />
  <ServiceSchema
    serviceName="포토부스 대여 · 렌탈 서비스"
    serviceType="Photo Booth Rental"
    description="피키픽은 2020년 설립된 서울 성수동 소재 프리미엄 포토부스 렌탈 전문 기업으로, 스탠드형·테이블형·부스형 등 9종 이상의 포토부스를 브랜드 팝업, 기업 행사, 웨딩 등에 제공합니다."
  />

  <!-- Hero Section -->
  <section class="relative bg-white pt-14 pb-8 lg:pt-12 lg:pb-12 overflow-hidden">
    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8 gs-fade-up">
      <h1 class="text-2xl lg:text-4xl font-bold tracking-tight text-primary leading-tight">
        포토부스 대여 · 렌탈 서비스
      </h1>
      <p class="mt-4 text-sm lg:text-base text-secondary leading-relaxed max-w-3xl">
        피키픽포토부스(PICKYPIC)는 2020년 설립된 서울 성수동 소재 프리미엄 포토부스 렌탈 전문 기업으로, 넷플릭스·현대자동차·스타벅스 등 1,000건 이상의 브랜드 팝업 및 기업 행사에 9종 이상의 포토부스를 제공하고 있습니다.
      </p>
      <!-- CTA buttons -->
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/rental" class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-medium text-white hover:bg-primary/90 transition-colors">
          렌탈 문의하기
        </a>
        <a href="/products" class="inline-flex items-center justify-center rounded-full border border-gray-400 px-6 py-3 text-sm font-medium text-primary hover:bg-primary hover:text-white transition-colors">
          제품 보기
        </a>
      </div>
    </div>
  </section>

  <!-- Service Introduction -->
  <section class="bg-white py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 gs-fade-up">
      <h2 class="text-xl lg:text-2xl font-bold text-primary mb-6">포토부스 대여 서비스 소개</h2>
      <div class="text-sm lg:text-base text-secondary leading-relaxed space-y-4 max-w-3xl">
        <p>
          피키픽은 브랜드 팝업, 기업 행사, 전시회, 웨딩, 파티 등 다양한 이벤트에 맞춤형 포토부스를 대여해 드리는 전문 렌탈 서비스입니다. 단순한 장비 대여를 넘어, 프레임 디자인 커스터마이징부터 현장 설치, 운영 스태프 지원, 철거까지 원스톱으로 제공합니다.
        </p>
        <p>
          인생네컷, 포토이즘과 같은 셀프 포토 촬영 경험을 행사 현장에서 구현할 수 있으며, 브랜드 아이덴티티를 반영한 맞춤 프레임으로 차별화된 고객 경험을 만들어 드립니다.
        </p>
      </div>
    </div>
  </section>

  <!-- Photobooth Types -->
  <section class="bg-bg-muted py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 gs-fade-up">
      <h2 class="text-xl lg:text-2xl font-bold text-primary mb-8">포토부스 종류</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 gs-stagger">
        <!-- Stand type -->
        <div class="bg-white rounded-lg overflow-hidden">
          <div class="booth-carousel relative aspect-[4/3] overflow-hidden" data-interval="3000">
            <img src="/images/products/modern-picky-photo.png" alt="피키픽 모던피키 스탠드형 포토부스" class="booth-slide absolute inset-0 w-full h-full object-contain bg-gray-50 opacity-100 transition-opacity duration-700" />
            <img src="/images/products/classic-picky-photo.png" alt="피키픽 클래식피키 스탠드형 포토부스" class="booth-slide absolute inset-0 w-full h-full object-contain bg-gray-50 opacity-0 transition-opacity duration-700" loading="lazy" />
            <img src="/images/products/urban-picky-photo.png" alt="피키픽 어반피키 스탠드형 포토부스" class="booth-slide absolute inset-0 w-full h-full object-contain bg-gray-50 opacity-0 transition-opacity duration-700" loading="lazy" />
          </div>
          <div class="p-6 lg:p-8">
            <h3 class="text-lg font-bold text-primary mb-3">스탠드형 포토부스</h3>
            <p class="text-sm text-secondary leading-relaxed mb-4">
              가장 인기 있는 포토부스 유형으로, 행사장 어디에나 설치 가능한 독립형 구조입니다. 컴팩트한 디자인과 고화질 촬영이 특징입니다.
            </p>
            <ul class="text-sm text-secondary space-y-1.5">
              <li><button type="button" class="product-row text-left hover:text-primary underline underline-offset-2 decoration-primary/30 hover:decoration-primary cursor-pointer transition-colors" data-product-id="modern-picky">· 모던피키 (Modern Picky)</button></li>
              <li><button type="button" class="product-row text-left hover:text-primary underline underline-offset-2 decoration-primary/30 hover:decoration-primary cursor-pointer transition-colors" data-product-id="classic-picky">· 클래식피키 (Classic Picky)</button></li>
              <li><button type="button" class="product-row text-left hover:text-primary underline underline-offset-2 decoration-primary/30 hover:decoration-primary cursor-pointer transition-colors" data-product-id="urban-picky">· 어반피키 (Urban Picky)</button></li>
            </ul>
          </div>
        </div>
        <!-- Table type -->
        <div class="bg-white rounded-lg overflow-hidden">
          <div class="booth-carousel relative aspect-[4/3] overflow-hidden" data-interval="3500">
            <img src="/images/products/modern-mini-picky-photo.png" alt="피키픽 모던미니피키 테이블형 포토부스" class="booth-slide absolute inset-0 w-full h-full object-contain bg-gray-50 opacity-100 transition-opacity duration-700" />
            <img src="/images/products/urban-mini-picky-photo.png" alt="피키픽 어반미니피키 테이블형 포토부스" class="booth-slide absolute inset-0 w-full h-full object-contain bg-gray-50 opacity-0 transition-opacity duration-700" loading="lazy" />
            <img src="/images/products/modern-retro-picky-photo.png" alt="피키픽 모던레트로피키 테이블형 포토부스" class="booth-slide absolute inset-0 w-full h-full object-contain bg-gray-50 opacity-0 transition-opacity duration-700" loading="lazy" />
            <img src="/images/products/urban-retro-picky-photo.png" alt="피키픽 어반레트로피키 테이블형 포토부스" class="booth-slide absolute inset-0 w-full h-full object-contain bg-gray-50 opacity-0 transition-opacity duration-700" loading="lazy" />
          </div>
          <div class="p-6 lg:p-8">
            <h3 class="text-lg font-bold text-primary mb-3">테이블형 포토부스</h3>
            <p class="text-sm text-secondary leading-relaxed mb-4">
              테이블 위에 설치하는 컴팩트 모델로, 공간이 제한된 팝업스토어나 카페, 소규모 행사에 최적화되어 있습니다.
            </p>
            <ul class="text-sm text-secondary space-y-1.5">
              <li><button type="button" class="product-row text-left hover:text-primary underline underline-offset-2 decoration-primary/30 hover:decoration-primary cursor-pointer transition-colors" data-product-id="modern-mini-picky">· 모던 미니피키 (Modern Mini Picky)</button></li>
              <li><button type="button" class="product-row text-left hover:text-primary underline underline-offset-2 decoration-primary/30 hover:decoration-primary cursor-pointer transition-colors" data-product-id="urban-mini-picky">· 어반 미니피키 (Urban Mini Picky)</button></li>
              <li><button type="button" class="product-row text-left hover:text-primary underline underline-offset-2 decoration-primary/30 hover:decoration-primary cursor-pointer transition-colors" data-product-id="modern-retro-picky">· 모던 레트로피키 (Modern Retro Picky)</button></li>
              <li><button type="button" class="product-row text-left hover:text-primary underline underline-offset-2 decoration-primary/30 hover:decoration-primary cursor-pointer transition-colors" data-product-id="urban-retro-picky">· 어반 레트로피키 (Urban Retro Picky)</button></li>
            </ul>
          </div>
        </div>
        <!-- Booth type -->
        <div class="bg-white rounded-lg overflow-hidden">
          <div class="booth-carousel relative aspect-[4/3] overflow-hidden" data-interval="4000">
            <img src="/images/products/outdoor-picky-photo.png" alt="피키픽 아웃도어피키 부스형 포토부스" class="booth-slide absolute inset-0 w-full h-full object-contain bg-gray-50 opacity-100 transition-opacity duration-700" />
            <img src="/images/products/air-picky-photo.png" alt="피키픽 에어피키 부스형 포토부스" class="booth-slide absolute inset-0 w-full h-full object-contain bg-gray-50 opacity-0 transition-opacity duration-700" loading="lazy" />
          </div>
          <div class="p-6 lg:p-8">
            <h3 class="text-lg font-bold text-primary mb-3">부스형 포토부스</h3>
            <p class="text-sm text-secondary leading-relaxed mb-4">
              독립된 촬영 공간을 제공하는 부스형 모델로, 야외 행사나 대형 페스티벌에 적합합니다. 날씨에 구애받지 않는 안정적인 촬영 환경을 제공합니다.
            </p>
            <ul class="text-sm text-secondary space-y-1.5">
              <li><button type="button" class="product-row text-left hover:text-primary underline underline-offset-2 decoration-primary/30 hover:decoration-primary cursor-pointer transition-colors" data-product-id="outdoor-picky">· 아웃도어피키 (Outdoor Picky)</button></li>
              <li><button type="button" class="product-row text-left hover:text-primary underline underline-offset-2 decoration-primary/30 hover:decoration-primary cursor-pointer transition-colors" data-product-id="air-picky">· 에어피키 (Air Picky)</button></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Rental Process -->
  <section class="bg-white py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 gs-fade-up">
      <h2 class="text-xl lg:text-2xl font-bold text-primary mb-8">포토부스 대여 절차</h2>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 lg:gap-6 gs-stagger">
        {[
          { step: '01', title: '문의', desc: '전화, 카카오톡, 웹사이트를 통해 행사 일정과 요구사항을 알려주세요.' },
          { step: '02', title: '견적', desc: '행사 규모와 요구사항에 맞는 최적의 포토부스와 견적을 안내드립니다.' },
          { step: '03', title: '설치', desc: '행사 당일, 전문 팀이 현장에 포토부스를 설치하고 세팅합니다.' },
          { step: '04', title: '운영', desc: '운영 스태프가 상주하여 촬영 안내 및 장비를 관리합니다.' },
          { step: '05', title: '철거', desc: '행사 종료 후 깔끔하게 철거하고, 촬영 데이터를 전달드립니다.' },
        ].map((item) => (
          <div class="text-center p-4">
            <span class="block text-2xl lg:text-3xl font-bold text-primary/20 mb-2" style="font-family: 'Montserrat', sans-serif;">{item.step}</span>
            <h3 class="text-sm lg:text-base font-bold text-primary mb-2">{item.title}</h3>
            <p class="text-xs lg:text-sm text-secondary leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="bg-bg-muted py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 gs-fade-up">
      <h2 class="text-xl lg:text-2xl font-bold text-primary mb-8">포토부스 대여 포함 사항</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-6 gs-stagger">
        {[
          { title: '포토부스 장비', desc: '선택하신 모델의 포토부스 본체, DSLR 카메라, 조명, 프린터 일체 제공' },
          { title: '맞춤 프레임 디자인', desc: '브랜드 로고, 행사 테마를 반영한 맞춤 포토 프레임 제작' },
          { title: '현장 설치 · 철거', desc: '전문 팀의 현장 방문 설치 및 행사 종료 후 철거 서비스' },
          { title: '운영 스태프', desc: '행사 시간 동안 상주하며 촬영 안내 및 장비 운영 지원' },
          { title: '무제한 인화', desc: '행사 시간 내 촬영 횟수 제한 없이 즉석 인화 제공' },
          { title: '디지털 데이터', desc: '촬영된 원본 사진 및 프레임 적용 사진 디지털 파일 제공' },
        ].map((item) => (
          <div class="bg-white rounded-lg p-5 lg:p-6">
            <h3 class="text-sm lg:text-base font-bold text-primary mb-2">{item.title}</h3>
            <p class="text-xs lg:text-sm text-secondary leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <FAQSchema items={faqItems} title="포토부스 대여 자주 묻는 질문" />

  <!-- Bottom CTA -->
  <section class="bg-white py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center gs-fade-up">
      <h2 class="text-xl lg:text-2xl font-bold text-primary mb-4">포토부스 대여, 지금 문의하세요</h2>
      <p class="text-sm lg:text-base text-secondary mb-6 max-w-2xl mx-auto">
        행사 일정과 요구사항을 알려주시면 영업시간 1시간 이내에 맞춤 견적을 안내드립니다.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/rental" class="inline-flex items-center justify-center rounded-full bg-primary px-8 py-3 text-sm font-medium text-white hover:bg-primary/90 transition-colors">
          렌탈 문의하기
        </a>
        <a href="/products" class="inline-flex items-center justify-center rounded-full border border-gray-400 px-8 py-3 text-sm font-medium text-primary hover:bg-primary hover:text-white transition-colors">
          제품 보기
        </a>
      </div>
    </div>
  </section>
  <!-- Product Detail Modal -->
  <div id="product-modal" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-label="제품 상세 정보">
    <div id="modal-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4 sm:p-6">
      <div class="relative bg-white rounded-2xl w-full max-w-5xl max-h-[90vh] overflow-y-auto shadow-2xl">
        <button type="button" id="modal-close" class="absolute top-4 right-4 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-white border border-border-default hover:bg-primary hover:text-white hover:border-primary transition-all duration-300 cursor-pointer" aria-label="닫기">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
        <div class="pt-8 pb-4 px-8 border-b border-border-light">
          <span id="modal-type" class="text-xl lg:text-2xl font-black tracking-[0.15em] text-primary uppercase block mb-1"></span>
          <h3 id="modal-name" class="text-sm lg:text-base font-medium text-secondary tracking-tight"></h3>
        </div>
        <!-- Desktop 3-col -->
        <div class="hidden lg:grid lg:grid-cols-12 gap-0 p-8 items-center">
          <div class="lg:col-span-3 flex items-center justify-center"><img id="modal-img-left" src="" alt="" class="max-w-full max-h-[420px]" /></div>
          <div class="lg:col-span-6 px-6 flex flex-col justify-center">
            <h4 class="text-sm font-bold tracking-[0.1em] text-primary uppercase mb-4 text-center">Photo booth specification</h4>
            <table class="w-full text-sm border-collapse"><tbody id="modal-specs-desktop"></tbody></table>
          </div>
          <div class="lg:col-span-3 flex items-center justify-center"><img id="modal-img-right" src="" alt="" class="max-w-full max-h-[420px]" /></div>
        </div>
        <!-- Mobile -->
        <div class="lg:hidden p-6">
          <div class="flex gap-4 justify-center mb-6 items-center">
            <div class="w-1/2 max-w-[180px] flex items-center justify-center"><img id="modal-img-left-m" src="" alt="" class="max-w-full max-h-[260px] object-contain" /></div>
            <div class="w-1/2 max-w-[180px] flex items-center justify-center"><img id="modal-img-right-m" src="" alt="" class="max-w-full max-h-[260px] object-contain" /></div>
          </div>
          <h4 class="text-sm font-bold tracking-[0.1em] text-primary uppercase mb-4 text-center">Photo booth specification</h4>
          <table class="w-full text-sm border-collapse"><tbody id="modal-specs-mobile"></tbody></table>
        </div>
        <div class="px-8 pb-8 flex justify-center gap-3">
          <a href="/products" class="inline-flex items-center justify-center px-6 py-3 bg-primary text-white font-semibold text-sm rounded-full hover:bg-primary/90 transition-colors duration-300">전체 제품 보기</a>
          <a href="/rental" class="inline-flex items-center justify-center px-6 py-3 border border-primary text-primary font-semibold text-sm rounded-full hover:bg-primary hover:text-white transition-colors duration-300">렌탈 문의</a>
        </div>
      </div>
    </div>
  </div>

  <script id="products-data" type="application/json" set:html={JSON.stringify(
    products.map(p => ({ id: p.id, name: p.name, nameKo: p.nameKo, type: p.type, imageLeft: p.imageLeft, imageRight: p.imageRight, specs: p.specs }))
  )} />
</BaseLayout>

<script>
  function initBoothCarousels() {
    document.querySelectorAll<HTMLElement>('.booth-carousel').forEach((carousel) => {
      const slides = carousel.querySelectorAll<HTMLImageElement>('.booth-slide');
      if (slides.length <= 1) return;
      const interval = parseInt(carousel.dataset.interval || '3000', 10);
      let current = 0;
      setInterval(() => {
        slides[current].style.opacity = '0';
        current = (current + 1) % slides.length;
        slides[current].style.opacity = '1';
      }, interval);
    });
  }

  function initProductModal() {
    const modal = document.getElementById('product-modal');
    const backdrop = document.getElementById('modal-backdrop');
    const closeBtn = document.getElementById('modal-close');
    if (!modal || !backdrop || !closeBtn) return;

    const productsData = JSON.parse(document.getElementById('products-data')?.textContent || '[]');
    const productById: Record<string, any> = {};
    productsData.forEach((p: any) => { productById[p.id] = p; });
    const smallTypes = ['modern-mini-picky', 'urban-mini-picky', 'modern-retro-picky', 'urban-retro-picky'];

    function openModal(productId: string) {
      const product = productById[productId];
      if (!product) return;
      const maxH = smallTypes.includes(productId) ? 'max-h-[320px]' : 'max-h-[420px]';

      (document.getElementById('modal-type') as HTMLElement).textContent = product.type;
      (document.getElementById('modal-name') as HTMLElement).textContent = `${product.name} | ${product.nameKo}`;

      const imgLeft = document.getElementById('modal-img-left') as HTMLImageElement;
      const imgRight = document.getElementById('modal-img-right') as HTMLImageElement;
      imgLeft.src = product.imageLeft; imgLeft.alt = `${product.name} ${product.nameKo} 라인 이미지`; imgLeft.className = `max-w-full ${maxH}`;
      imgRight.src = product.imageRight; imgRight.alt = `${product.name} ${product.nameKo} 제품 이미지`; imgRight.className = `max-w-full ${maxH}`;

      const imgLeftM = document.getElementById('modal-img-left-m') as HTMLImageElement;
      const imgRightM = document.getElementById('modal-img-right-m') as HTMLImageElement;
      imgLeftM.src = product.imageLeft; imgLeftM.alt = imgLeft.alt;
      imgRightM.src = product.imageRight; imgRightM.alt = imgRight.alt;

      const specHtml = product.specs.map((s: any) =>
        `<tr class="border-b border-border-light"><th class="text-left py-2 pr-4 font-semibold text-primary text-xs whitespace-nowrap align-top w-[140px]">${s.label}</th><td class="py-2 text-secondary text-xs leading-relaxed">${s.value}</td></tr>`
      ).join('');
      (document.getElementById('modal-specs-desktop') as HTMLElement).innerHTML = specHtml;
      (document.getElementById('modal-specs-mobile') as HTMLElement).innerHTML = specHtml;

      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    document.querySelectorAll<HTMLElement>('.product-row').forEach(el => {
      el.addEventListener('click', () => {
        const id = el.dataset.productId;
        if (id) openModal(id);
      });
    });

    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
    });
  }

  document.addEventListener('DOMContentLoaded', () => { initBoothCarousels(); initProductModal(); });
  document.addEventListener('astro:after-swap', () => { initBoothCarousels(); initProductModal(); });
</script>
