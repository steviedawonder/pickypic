---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="포토부스 구매 · 온라인 쇼핑 | 피키픽 PICKYPIC"
  description="피키픽 포토부스 제품을 온라인으로 구매하세요. 포토부스 판매 및 관련 액세서리를 한눈에 비교하고 편리하게 주문할 수 있습니다."
>
  <section class="pt-20 lg:pt-24 bg-white shop-section">
    <div class="iframe-wrapper">
      <iframe
        id="shop-iframe"
        src="https://pickyglobal.com/shop/list.php?ca_id=10"
        class="shop-iframe"
        title="PICKYPIC Shop"
        loading="lazy"
        allow="payment"
      ></iframe>
    </div>
  </section>
</BaseLayout>

<style>
  .shop-section {
    height: calc(100vh - 80px);
    min-height: 600px;
    display: flex;
    flex-direction: column;
  }
  .iframe-wrapper {
    flex: 1;
    overflow: hidden;
    position: relative;
  }
  .shop-iframe {
    width: 100%;
    border: 0;
    position: absolute;
    top: -140px;
    left: 0;
    height: calc(100% + 140px);
  }
</style>
