---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/common/Button.astro';
---

<BaseLayout title="페이지를 찾을 수 없습니다 | PICKYPIC" description="요청하신 페이지를 찾을 수 없습니다.">
  <section class="min-h-[70vh] flex items-center justify-center">
    <div class="text-center px-6">
      <p class="text-[120px] lg:text-[180px] font-bold text-border-light leading-none">404</p>
      <h1 class="text-2xl lg:text-3xl font-bold text-primary mt-4 mb-3">
        페이지를 찾을 수 없습니다
      </h1>
      <p class="text-secondary mb-10 max-w-md mx-auto">
        요청하신 페이지가 존재하지 않거나 이동되었습니다.<br />
        아래 링크에서 원하시는 내용을 찾아보세요.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <Button href="/" variant="primary" size="md">홈으로 돌아가기</Button>
        <Button href="/products" variant="outline" size="md">제품소개</Button>
        <Button href="/rental" variant="outline" size="md">렌탈문의</Button>
      </div>
    </div>
  </section>
</BaseLayout>
