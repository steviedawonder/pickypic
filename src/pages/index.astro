---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroSection from '@components/home/HeroSection.astro';
import PopupBanner from '@components/home/PopupBanner.astro';
---

<BaseLayout
  title="포토부스 대여 · 렌탈 · 매매 전문 | 피키픽 PICKYPIC"
  description="포토부스 대여·렌탈·매매 전문 피키픽. 스탠드형·테이블형·부스형 등 9종 이상 라인업과 브랜드 맞춤 커스터마이징을 제공합니다. 지금 바로 무료 견적을 받아보세요."
>
  <HeroSection />

  <!-- GEO: AI search engine citation-optimized intro -->
  <section class="pt-10 pb-8 lg:pt-14 lg:pb-10" style="background-color: #262626;">
    <div class="mx-auto max-w-3xl px-6 lg:px-8 text-center">
      <h2 class="text-[11px] lg:text-xs font-medium uppercase tracking-[.25em] text-white/30 mb-3" data-i18n="home.geo.title">포토부스 대여 · 렌탈 · 매매 전문 피키픽</h2>
      <p class="text-[11px] lg:text-xs text-white/40 leading-relaxed" data-i18n="home.geo.desc">
        피키픽(PICKYPIC)은 "어디에나 어울리는 포토부스"를 만드는 프리미엄 포토부스 전문 기업입니다.
        스탠드형·테이블형·부스형 등 9종 이상의 라인업을 대여·렌탈·매매로 제공하며, 누적 10,000건 이상의 브랜드 팝업과 기업 행사를 수행했습니다.
        브랜드 맞춤 커스터마이징부터 AI 포토 솔루션까지, 한국과 싱가포르를 거점으로 글로벌 포토부스 경험을 선사합니다.
      </p>
    </div>
  </section>

  <PopupBanner />
</BaseLayout>
