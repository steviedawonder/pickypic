---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroSection from '@components/home/HeroSection.astro';
import ProductCategories from '@components/home/ProductCategories.astro';
import WhyPickyPic from '@components/home/WhyPickyPic.astro';
import ClientLogos from '@components/home/ClientLogos.astro';
import CtaSection from '@components/home/CtaSection.astro';
---

<BaseLayout
  title="피키픽 포토부스 | PICKYPIC - 포토부스 렌탈/대여 전문"
  description="피키픽 포토부스 - 브랜드 팝업, 기업 행사, 파티 등 다양한 이벤트에 맞춤형 포토부스 렌탈 서비스를 제공합니다. 테이블형, 스탠드형, 부스형 9종 이상의 포토부스 라인업."
  transparentNav={true}
>
  <HeroSection />
  <ProductCategories />
  <WhyPickyPic />
  <ClientLogos />
  <CtaSection />
</BaseLayout>
