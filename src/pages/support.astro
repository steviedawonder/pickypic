---
import BaseLayout from '@layouts/BaseLayout.astro';
import TextHero from '@components/common/TextHero.astro';
import Button from '@components/common/Button.astro';
import { company } from '@data/company';
import { products } from '@data/products';

const guides = products.map((p) => ({
  name: p.name,
  nameKo: p.nameKo,
  category: p.categoryLabel,
}));
---

<BaseLayout
  title="고객지원 | 피키픽 포토부스 PICKYPIC"
  description="피키픽 포토부스 제품별 사용 가이드 및 고객지원 안내. 궁금한 점은 언제든 문의해주세요."
>
  <TextHero
    subtitle="Support"
    title="고객지원"
    description="포토부스 사용 가이드 및 문의 안내"
  />

  <!-- Product Guides -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-12 lg:mb-16 gs-fade-up">
        <h2 class="text-[clamp(1.5rem,2.5vw,2.25rem)] font-bold tracking-tight text-primary">
          제품 사용 가이드
        </h2>
        <p class="mt-4 text-secondary">
          각 제품별 설치 및 사용 방법을 확인하세요.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 gs-stagger">
        {guides.map((guide) => (
          <div class="border border-border-light p-6 hover:border-primary/20 transition-colors duration-300">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="text-base font-bold text-primary">{guide.name}</h3>
                <p class="text-xs text-secondary mt-1">{guide.nameKo}</p>
              </div>
              <span class="px-2.5 py-1 bg-bg-light text-[10px] font-semibold text-secondary tracking-[0.05em]">
                {guide.category}
              </span>
            </div>
            <div class="flex items-center gap-2 text-secondary">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
              </svg>
              <span class="text-xs">사용 가이드 PDF</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Support -->
  <section class="py-20 lg:py-28 bg-bg-light">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center gs-fade-up">
        <h2 class="text-[clamp(1.5rem,2.5vw,2.25rem)] font-bold tracking-tight text-primary mb-6">
          추가 문의가 필요하신가요?
        </h2>
        <p class="text-secondary mb-10 leading-relaxed">
          포토부스 사용 중 궁금한 점이나 기술적인 문의사항이 있으시면<br class="hidden sm:block" />
          아래 연락처로 편하게 문의해주세요.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-12">
          <div class="bg-white p-6 text-center">
            <p class="text-xs font-semibold tracking-[0.1em] text-secondary uppercase mb-3">전화 문의</p>
            <a href={`tel:${company.phone}`} class="text-lg font-bold text-primary hover:underline">{company.phone}</a>
          </div>
          <div class="bg-white p-6 text-center">
            <p class="text-xs font-semibold tracking-[0.1em] text-secondary uppercase mb-3">이메일</p>
            <a href={`mailto:${company.email}`} class="text-sm font-bold text-primary hover:underline break-all">{company.email}</a>
          </div>
          <div class="bg-white p-6 text-center">
            <p class="text-xs font-semibold tracking-[0.1em] text-secondary uppercase mb-3">카카오톡</p>
            <a href={company.kakaoUrl} target="_blank" rel="noopener noreferrer" class="text-sm font-bold text-primary hover:underline">{company.kakaoChannel}</a>
          </div>
        </div>

        <Button href="/rental" variant="primary" size="lg">렌탈문의 바로가기</Button>
      </div>
    </div>
  </section>
</BaseLayout>
