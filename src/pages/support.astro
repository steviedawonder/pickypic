---
import BaseLayout from '@layouts/BaseLayout.astro';

const title = '고객지원 페이지 | 피키픽 | 포토부스 대여 및 기업 행사 렌탈 전문';
const description = '피키픽 포토부스 제품별 가이드파일 다운로드. 부스형, 스탠드형, 테이블형 포토부스 가이드를 확인하세요.';

const products = [
  { image: '/images/support/support-1.png', name: 'MODERN PICKY', category: '스탠드형' },
  { image: '/images/support/support-2.png', name: 'CLASSIC PICKY', category: '스탠드형' },
  { image: '/images/support/support-3.png', name: 'URBAN PICKY', category: '스탠드형' },
  { image: '/images/support/support-4.png', name: 'MODERN MINI PICKY', category: '테이블형' },
  { image: '/images/support/support-5.png', name: 'URBAN MINI PICKY', category: '테이블형' },
  { image: '/images/support/support-6.png', name: 'MODERN RETRO PICKY', category: '테이블형' },
  { image: '/images/support/support-7.png', name: 'URBAN RETRO PICKY', category: '테이블형' },
  { image: '/images/support/support-8.png', name: 'OUTDOOR PICKY', category: '부스형' },
  { image: '/images/support/support-9.png', name: 'AIR PICKY', category: '부스형' },
];

const categories = ['전체', '부스형', '스탠드형', '테이블형'];
---

<BaseLayout title={title} description={description}>
  <section class="py-20 lg:py-28 bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">

      <!-- Header row: title + search bar -->
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 mb-10 gs-fade-up">
        <h1 class="text-[clamp(2rem,4vw,3.5rem)] font-bold tracking-tight text-primary leading-tight">
          고객지원
        </h1>
        <div class="relative w-full sm:w-72">
          <input
            type="search"
            id="support-search"
            placeholder="Search"
            aria-label="제품 검색"
            class="w-full border border-border rounded-full py-2.5 pl-5 pr-11 text-sm text-primary placeholder:text-secondary-light focus:outline-none focus:border-primary transition-colors"
          />
          <button type="button" aria-label="검색" class="absolute right-4 top-1/2 -translate-y-1/2 text-secondary-light hover:text-primary transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Subtitle -->
      <p class="text-base sm:text-lg text-secondary mb-8 gs-fade-up">
        피키픽 포토부스 가이드파일 다운로드
      </p>

      <!-- Category filter tabs -->
      <nav aria-label="제품 카테고리 필터" class="mb-12 gs-fade-up">
        <ul class="flex flex-wrap gap-2" role="tablist">
          {categories.map((cat, i) => (
            <li role="presentation">
              <button
                type="button"
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                data-category={cat}
                class:list={[
                  'category-tab px-5 py-2 text-sm font-medium rounded-md transition-colors',
                  i === 0
                    ? 'bg-primary text-white'
                    : 'bg-bg-light text-secondary hover:bg-border-light',
                ]}
              >
                {cat}
              </button>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Product guide cards grid -->
      <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-6 gs-stagger">
        {products.map((product) => (
          <article
            class="product-card border border-border-light rounded-2xl overflow-hidden hover:border-primary/30 transition-colors duration-300 flex flex-col"
            data-category={product.category}
            data-name={product.name}
          >
            <div class="flex-1 flex items-center justify-center p-8 sm:p-10">
              <img
                src={product.image}
                alt={`${product.name} 가이드`}
                class="max-h-60 sm:max-h-72 w-auto object-contain"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="px-6 pb-6 pt-2 text-center">
              <h2 class="text-sm sm:text-base font-bold tracking-wide text-primary uppercase">
                {product.name}
              </h2>
            </div>
          </article>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden py-20 text-center text-secondary">
        <p class="text-lg">검색 결과가 없습니다.</p>
      </div>

    </div>
  </section>

  <script>
    function initSupportFilters() {
      const tabs = document.querySelectorAll<HTMLButtonElement>('.category-tab');
      const cards = document.querySelectorAll<HTMLElement>('.product-card');
      const searchInput = document.querySelector<HTMLInputElement>('#support-search');
      const emptyState = document.getElementById('empty-state');
      const grid = document.getElementById('product-grid');

      let activeCategory = '전체';

      function filterCards() {
        const searchTerm = (searchInput?.value ?? '').toLowerCase().trim();
        let visibleCount = 0;

        cards.forEach((card) => {
          const cardCategory = card.getAttribute('data-category') ?? '';
          const cardName = (card.getAttribute('data-name') ?? '').toLowerCase();

          const matchesCategory = activeCategory === '전체' || cardCategory === activeCategory;
          const matchesSearch = !searchTerm || cardName.includes(searchTerm);

          if (matchesCategory && matchesSearch) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        if (emptyState && grid) {
          emptyState.classList.toggle('hidden', visibleCount > 0);
          grid.classList.toggle('hidden', visibleCount === 0);
        }
      }

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          tabs.forEach((t) => {
            t.classList.remove('bg-primary', 'text-white');
            t.classList.add('bg-bg-light', 'text-secondary');
            t.setAttribute('aria-selected', 'false');
          });
          tab.classList.remove('bg-bg-light', 'text-secondary');
          tab.classList.add('bg-primary', 'text-white');
          tab.setAttribute('aria-selected', 'true');

          activeCategory = tab.getAttribute('data-category') ?? '전체';
          filterCards();
        });
      });

      searchInput?.addEventListener('input', filterCards);
    }

    document.addEventListener('DOMContentLoaded', initSupportFilters);
    document.addEventListener('astro:after-swap', initSupportFilters);
  </script>
</BaseLayout>
