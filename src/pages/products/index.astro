---
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import FAQSchema from '@components/seo/FAQSchema.astro';
import { products, productCategories } from '@data/products';
import { createClient } from '@sanity/client';
import { faqQueries } from '../../sanity/client';

const sanityClient = createClient({
  projectId: '7b9lcco4',
  dataset: 'production',
  useCdn: true,
  apiVersion: '2024-01-01',
});

let downloadFiles: any[] = [];
try {
  downloadFiles = await sanityClient.fetch(`*[_type == "downloadFile" && isActive == true && category == "product"] {
    displayName, linkedProducts, "fileUrl": file.asset->url
  }`);
} catch (e) {
  // Sanity 접속 실패 시 빈 배열
}

// FAQ from Sanity with hardcoded fallback
const fallbackFAQ = [
  {
    question: '피키픽 포토부스 구매와 렌탈의 차이는 무엇인가요?',
    answer: '구매는 포토부스를 완전히 소유하여 매장에서 상시 운영하는 방식이며, 렌탈은 일정 기간 대여하여 사용하는 방식입니다. 정기적인 사용 및 운영을 하시거나 장기간 이상 사용 계획이 있다면 구매가 경제적이며, 단기 행사나 시범 운영 목적이라면 렌탈이 적합합니다. 구매 시 1년 무상 A/S와 소프트웨어 업데이트가 포함됩니다.',
    questionEn: 'What is the difference between purchasing and renting a PICKYPIC photo booth?',
    answerEn: 'Purchasing means fully owning the photo booth for permanent operation in your store, while renting means borrowing it for a set period. If you plan to use it regularly or long-term, purchasing is more economical. For short-term events or trial operations, renting is more suitable. Purchase includes 1 year of free A/S and software updates.',
    questionJp: 'ピキピック フォトブースの購入とレンタルの違いは何ですか？',
    answerJp: '購入はフォトブースを完全に所有して店舗で常時運営する方式で、レンタルは一定期間借りて使用する方式です。定期的な使用や長期的な利用計画がある場合は購入が経済的で、短期イベントや試験運営目的であればレンタルが適しています。購入時は1年間の無償A/Sとソフトウェアアップデートが含まれます。',
  },
  {
    question: '피키픽 포토부스 제품 라인업에는 어떤 것이 있나요?',
    answer: '피키픽은 모던 레트로 디자인의 스탠딩형과 컴팩트형 두 가지 라인업을 운영하고 있습니다. 스탠딩형은 매장 설치용으로 최적화되어 있으며, 컴팩트형은 이동과 설치가 간편하여 행사장에 적합합니다. 두 모델 모두 AI 퍼스널 컬러 분석, QR + 인화 하이브리드 출력, 3개 국어 지원 등 피키픽 핵심 기능을 동일하게 탑재하고 있습니다.',
    questionEn: 'What product lineup does PICKYPIC photo booth offer?',
    answerEn: 'PICKYPIC offers two lineups in modern retro design: standing type and compact type. The standing type is optimized for permanent store installation, while the compact type is easy to move and set up, making it ideal for event venues. Both models feature AI personal color analysis, QR + print hybrid output, and trilingual support.',
    questionJp: 'ピキピック フォトブースの製品ラインナップには何がありますか？',
    answerJp: 'ピキピックはモダンレトロデザインのスタンディング型とコンパクト型の2種類のラインナップを展開しています。スタンディング型は店舗設置用に最適化されており、コンパクト型は移動・設置が簡単でイベント会場に適しています。両モデルともAIパーソナルカラー分析、QR＋プリントハイブリッド出力、3言語対応などのコア機能を搭載しています。',
  },
  {
    question: '포토부스 구매 후 유지비용은 얼마나 드나요?',
    answer: '주요 유지비용은 인화 용지와 잉크 등 소모품 비용이며, 촬영 1건당 약 200~300원 수준입니다. 월 1,000건 촬영 기준 소모품 비용은 약 20~30만 원이며, 1건당 촬영 요금(보통 3,000~5,000원)을 고려하면 높은 수익률을 기대할 수 있습니다. 소프트웨어 업데이트는 구매 후 1년간 무상, 이후 연간 유지보수 계약으로 지속 지원됩니다.',
    questionEn: 'How much does it cost to maintain the photo booth after purchase?',
    answerEn: 'The main maintenance costs are consumables such as photo paper and ink, approximately ₩200–300 per shot. Based on 1,000 shots per month, consumable costs are around ₩200,000–300,000. Considering a typical shooting fee of ₩3,000–5,000 per shot, you can expect a high profit margin. Software updates are free for 1 year after purchase, with annual maintenance contracts available thereafter.',
    questionJp: 'フォトブース購入後の維持費はどのくらいかかりますか？',
    answerJp: '主な維持費は印画紙やインクなどの消耗品費用で、撮影1件あたり約200〜300ウォン程度です。月1,000件撮影の場合、消耗品費は約20〜30万ウォンで、撮影料金（通常3,000〜5,000ウォン/件）を考えると高い収益率が期待できます。ソフトウェアアップデートは購入後1年間無償、以降は年間保守契約で継続サポートされます。',
  },
  {
    question: '피키픽 포토부스에 자체 필터나 프레임을 추가할 수 있나요?',
    answer: '네, 피키픽 포토부스는 관리자 페이지를 통해 자체 필터와 프레임을 무제한으로 추가할 수 있습니다. 시즌별, 이벤트별 맞춤 프레임을 직접 디자인하여 업로드할 수 있으며, PSD 템플릿을 제공하여 디자인 작업이 간편합니다. AI 퍼스널 컬러 분석 기반 자동 추천 필터 외에 수동 선택 필터도 함께 운영할 수 있어 다양한 고객 취향을 만족시킬 수 있습니다.',
    questionEn: 'Can I add my own filters or frames to the PICKYPIC photo booth?',
    answerEn: 'Yes, PICKYPIC photo booths allow unlimited custom filters and frames through the admin page. You can design and upload your own frames for each season or event, with PSD templates provided for easy design work. In addition to AI personal color analysis-based auto-recommended filters, manual selection filters are also available to satisfy diverse customer preferences.',
    questionJp: 'ピキピック フォトブースに独自のフィルターやフレームを追加できますか？',
    answerJp: 'はい、ピキピック フォトブースは管理者ページから独自のフィルターとフレームを無制限に追加できます。シーズンやイベントに合わせたカスタムフレームを直接デザインしてアップロードでき、PSDテンプレートが提供されているため作業も簡単です。AIパーソナルカラー分析による自動推薦フィルターのほか、手動選択フィルターも併用できます。',
  },
  {
    question: '구매 후 설치와 초기 세팅은 어떻게 진행되나요?',
    answer: '피키픽 전문 엔지니어가 구매 장소를 방문하여 설치, 네트워크 연결, 소프트웨어 세팅을 완료합니다. 설치 소요 시간은 약 1~2시간이며, 운영자 교육(약 1시간)까지 당일 완료됩니다. 설치 후 7일간 집중 모니터링을 통해 안정적인 운영을 지원하며, 서울 기준 구매 확정 후 영업일 5일 이내에 설치가 완료됩니다.',
    questionEn: 'How does installation and initial setup work after purchase?',
    answerEn: 'A PICKYPIC specialist engineer will visit your location to complete installation, network connection, and software setup. Installation takes approximately 1–2 hours, and operator training (about 1 hour) is also completed on the same day. 7-day intensive monitoring after installation ensures stable operation, and installation is completed within 5 business days of purchase confirmation (Seoul area).',
    questionJp: '購入後の設置と初期設定はどのように進みますか？',
    answerJp: 'ピキピックの専門エンジニアが購入場所に訪問し、設置・ネットワーク接続・ソフトウェア設定を完了します。設置所要時間は約1〜2時間で、運営者トレーニング（約1時間）まで当日中に完了します。設置後7日間の集中モニタリングで安定した運営をサポートし、ソウル基準で購入確定後5営業日以内に設置が完了します。',
  },
];

let productsFAQ: { question: string; answer: string }[] = [];
try {
  const sanityFAQ = await sanityClient.fetch(faqQueries.byPage, { page: 'products' });
  productsFAQ = sanityFAQ && sanityFAQ.length > 0 ? sanityFAQ : fallbackFAQ;
} catch {
  productsFAQ = fallbackFAQ;
}

// 제품 슬러그 순서 (캐러셀 순서와 동일)
const productSlugs = [
  'modern-picky', 'classic-picky', 'urban-picky',
  'modern-mini-picky', 'urban-mini-picky',
  'modern-retro-picky', 'urban-retro-picky',
  'outdoor-picky', 'air-picky',
];

// 제품별 PDF URL 매핑
const productPdfMap = productSlugs.map(slug => {
  const match = downloadFiles.find((f: any) => f.linkedProducts?.includes(slug));
  return match?.fileUrl || '';
});
---

<BaseLayout
  title="포토부스 제품 · 구매 · 판매 | 피키픽 PICKYPIC"
  description="포토부스 구매 및 판매 전문 피키픽의 9종 이상 제품 라인업. 모던피키, 클래식피키, 어반피키, 미니피키 등 행사에 맞는 최적의 포토부스를 비교하고 선택하세요."
>
  <BreadcrumbSchema items={[
    { name: '홈', href: '/' },
    { name: '제품소개', href: '/products' },
  ]} />

  <!-- Hero: PRODUCT TYPE -->
  <section class="pt-10 pb-5 lg:pt-14 lg:pb-8 bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <h1 class="text-center text-2xl sm:text-3xl md:text-5xl lg:text-6xl font-black tracking-tight text-primary uppercase gs-fade-up">
        PRODUCT TYPE
      </h1>
    </div>
  </section>

  <!-- Category Filter Pills -->
  <section class="pb-4 lg:pb-12 bg-white" aria-label="제품 카테고리 필터">
    <div class="mx-auto max-w-[1600px] px-6 lg:px-8">
      <div class="relative" id="pills-wrapper">
        <!-- Mobile scroll indicator left -->
        <button type="button" class="pills-scroll-left absolute left-0 top-1/2 -translate-y-1/2 -translate-x-1 z-10 w-7 h-7 bg-white/90 border border-gray-300 rounded-full flex items-center justify-center text-gray-500 shadow-sm lg:hidden opacity-0 pointer-events-none transition-opacity duration-200" aria-label="왼쪽 스크롤">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <nav class="overflow-x-auto scrollbar-hide pills-scroll-container" aria-label="제품 카테고리">
          <div class="flex gap-2.5 lg:gap-3 justify-start lg:justify-center min-w-max lg:min-w-0 lg:flex-wrap pb-2" id="category-pills">
            {productCategories.map((cat, i) => (
              <button
                type="button"
                class:list={[
                  'product-pill flex flex-col items-center justify-center h-[42px] lg:h-[46px] px-2.5 lg:px-3 rounded-full transition-all duration-300 cursor-pointer whitespace-nowrap min-w-[100px] lg:min-w-[110px] bg-white text-black',
                  i === 0
                    ? 'active-pill'
                    : '',
                ]}
                data-category={cat.id}
                data-index={i}
                aria-pressed={i === 0 ? 'true' : 'false'}
              >
                <span class="text-[11px] lg:text-xs font-normal leading-tight">{cat.labelKo}</span>
                <span class="text-[10px] lg:text-xs font-normal mt-0.5 opacity-70 leading-tight">{cat.labelEn}</span>
              </button>
            ))}
          </div>
        </nav>
        <!-- Mobile scroll indicator right -->
        <button type="button" class="pills-scroll-right absolute right-0 top-1/2 -translate-y-1/2 translate-x-1 z-10 w-7 h-7 bg-white/90 border border-gray-300 rounded-full flex items-center justify-center text-gray-500 shadow-sm lg:hidden opacity-0 pointer-events-none transition-opacity duration-200" aria-label="오른쪽 스크롤">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- Product Carousel -->
  <section class="py-8 lg:py-16 bg-white" aria-label="제품 상세정보">
    <div class="mx-auto max-w-[1600px] px-6 lg:px-8 relative">
      <!-- Navigation Arrows -->
      <button
        type="button"
        id="prev-btn"
        class="absolute left-0 top-1/2 -translate-y-1/2 z-20 w-12 h-12 lg:w-14 lg:h-14 flex items-center justify-center bg-white border border-border rounded-full shadow-lg hover:bg-primary hover:text-white hover:border-primary transition-all duration-300 cursor-pointer"
        aria-label="이전 제품"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
      </button>
      <button
        type="button"
        id="next-btn"
        class="absolute right-0 top-1/2 -translate-y-1/2 z-20 w-12 h-12 lg:w-14 lg:h-14 flex items-center justify-center bg-white border border-border rounded-full shadow-lg hover:bg-primary hover:text-white hover:border-primary transition-all duration-300 cursor-pointer"
        aria-label="다음 제품"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </button>

      <!-- Carousel Container -->
      <div class="overflow-hidden mx-8 lg:mx-12" id="carousel-viewport">
        <div class="flex transition-transform duration-500 ease-in-out" id="carousel-track">
          {products.map((product) => (
            <article
              class="w-full flex-shrink-0 product-slide"
              data-product-id={product.id}
              data-product-index={product.index}
              itemscope
              itemtype="https://schema.org/Product"
            >
              <!-- Product Title -->
              <div class="hidden lg:block mb-6 pl-2">
                <span class="text-2xl lg:text-3xl font-black tracking-[0.15em] text-primary uppercase block mb-1">{product.type}</span>
                <h2 class="text-base lg:text-lg font-medium text-secondary tracking-tight leading-tight" itemprop="name">
                  {product.name} | {product.nameKo}
                </h2>
              </div>

              <!-- Mobile: Product Title -->
              <div class="flex flex-col items-center mb-4 lg:hidden">
                <span class="text-xl font-black tracking-[0.15em] text-primary uppercase mb-1">{product.type}</span>
                <h2 class="text-sm font-medium text-secondary tracking-tight leading-tight" itemprop="name">
                  {product.name} | {product.nameKo}
                </h2>
              </div>

              <!-- Desktop: 3-column layout -->
              <div class={`hidden lg:grid lg:grid-cols-12 gap-0 ${['modern-mini-picky', 'urban-mini-picky', 'modern-retro-picky', 'urban-retro-picky'].includes(product.id) ? 'items-center' : 'items-end'}`}>
                <!-- Left: Line Image -->
                <div class="lg:col-span-3 flex items-center justify-center">
                  <img
                    src={product.imageLeft}
                    alt={`${product.name} ${product.nameKo} 라인 이미지`}
                    class={`max-w-full ${['modern-mini-picky', 'urban-mini-picky', 'modern-retro-picky', 'urban-retro-picky'].includes(product.id) ? 'max-h-[340px]' : ['modern-picky', 'classic-picky', 'urban-picky'].includes(product.id) ? 'max-h-[480px]' : 'max-h-[420px]'}`}
                    loading="lazy"
                  />
                </div>

                <!-- Center: Spec Table -->
                <div class="lg:col-span-6 px-6 flex flex-col justify-center">
                  <h3 class="text-sm font-bold tracking-[0.1em] text-primary uppercase mb-4 text-center">
                    Photo booth specification
                  </h3>
                  <table class="w-full text-sm border-collapse" itemprop="additionalProperty">
                    <tbody>
                      {product.specs.map((spec) => (
                        <tr class="border-b border-border-light">
                          <th class="text-left py-2 pr-4 font-semibold text-primary text-xs whitespace-nowrap align-top w-[140px]">
                            {spec.label}
                          </th>
                          <td class="py-2 text-secondary text-xs leading-relaxed">
                            {spec.value}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>

                <!-- Right: Product Photo -->
                <div class="lg:col-span-3 flex items-center justify-start">
                  <img
                    src={product.imageRight}
                    alt={`${product.name} ${product.nameKo} 제품 이미지`}
                    class={`max-w-full ${['modern-mini-picky', 'urban-mini-picky', 'modern-retro-picky', 'urban-retro-picky'].includes(product.id) ? 'max-h-[340px] scale-[0.85]' : ['modern-picky', 'classic-picky', 'urban-picky'].includes(product.id) ? 'max-h-[480px]' : 'max-h-[420px]'}`}
                    loading="lazy"
                    itemprop="image"
                  />
                </div>
              </div>

              <!-- Mobile: Images + Spec -->
              <div class="lg:hidden">
                <div class={`flex gap-4 justify-center mb-6 ${['modern-mini-picky', 'urban-mini-picky', 'modern-retro-picky', 'urban-retro-picky'].includes(product.id) ? 'items-center' : 'items-end'}`}>
                  <div class="w-1/2 max-w-[200px] flex items-center justify-center">
                    <img
                      src={product.imageLeft}
                      alt={`${product.name} ${product.nameKo} 라인 이미지`}
                      class="max-w-full max-h-[300px] object-contain"
                      loading="lazy"
                    />
                  </div>
                  <div class="w-1/2 max-w-[200px] flex items-center justify-center">
                    <img
                      src={product.imageRight}
                      alt={`${product.name} ${product.nameKo} 제품 이미지`}
                      class={`max-w-full object-contain ${['modern-mini-picky', 'urban-mini-picky', 'modern-retro-picky', 'urban-retro-picky'].includes(product.id) ? 'max-h-[255px]' : 'max-h-[300px]'}`}
                      loading="lazy"
                    />
                  </div>
                </div>
                <h3 class="text-sm font-bold tracking-[0.1em] text-primary uppercase mb-4 text-center">
                  Photo booth specification
                </h3>
                <table class="w-full text-sm border-collapse" itemprop="additionalProperty">
                  <tbody>
                    {product.specs.map((spec) => (
                      <tr class="border-b border-border-light">
                        <th class="text-left py-2 pr-4 font-semibold text-primary text-xs whitespace-nowrap align-top w-[140px]">
                          {spec.label}
                        </th>
                        <td class="py-2 text-secondary text-xs leading-relaxed">
                          {spec.value}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </article>
          ))}
        </div>
      </div>

      <!-- Carousel Dots -->
      <div class="flex justify-center gap-2 mt-8" id="carousel-dots" aria-label="제품 선택">
        {products.map((_, i) => (
          <button
            type="button"
            class:list={[
              'carousel-dot w-2.5 h-2.5 rounded-full transition-all duration-300 cursor-pointer',
              i === 0 ? 'bg-primary scale-125' : 'bg-border-light hover:bg-secondary',
            ]}
            data-dot-index={i}
            aria-label={`제품 ${i + 1}`}
          ></button>
        ))}
      </div>
    </div>
  </section>

  <!-- Download Section (changes based on selected product) -->
  <section class="py-4 lg:py-6 bg-white" aria-label="제품 소개서 다운로드">
    <div class="mx-auto max-w-3xl px-6 lg:px-8 text-center">
      <a
        id="product-download-btn"
        href={productPdfMap[0] || '#'}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center gap-2 px-10 py-4 border border-gray-400 rounded-full text-primary font-semibold text-sm tracking-[0.02em] hover:bg-primary hover:text-white hover:border-primary transition-colors duration-300"
      >
        <span data-i18n="products.download_btn">제품소개서 다운로드</span>
      </a>
    </div>
  </section>

  <!-- Product PDF Data (from Sanity) -->
  <script id="product-pdf-data" type="application/json" set:html={JSON.stringify(productPdfMap)} />

  <!-- Structured Data: Products -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "PICKYPIC 포토부스 제품 라인업",
    "description": "피키픽 포토부스의 9종 포토부스 제품 소개. 스탠드형, 테이블형, 부스형 포토부스를 확인하세요.",
    "numberOfItems": products.length,
    "itemListElement": products.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "Product",
        "name": `${p.name} | ${p.nameKo}`,
        "image": `https://picky-pic.com${p.imageRight}`,
        "description": `${p.nameKo} - ${p.type} 포토부스. 브랜드 팝업, 기업 행사, 파티 등에 적합한 PICKYPIC의 프리미엄 포토부스.`,
        "category": p.type,
        "brand": {
          "@type": "Brand",
          "name": "PICKYPIC"
        },
        "url": "https://picky-pic.com/products",
        "offers": {
          "@type": "Offer",
          "availability": "https://schema.org/InStock",
          "url": "https://picky-pic.com/rental",
          "seller": {
            "@type": "Organization",
            "name": "PICKYPIC"
          }
        }
      }
    }))
  })} />

  <!-- Products FAQ Section -->
  <FAQSchema items={productsFAQ} title="포토부스 제품 자주 묻는 질문" titleKey="faq.title_products" />
</BaseLayout>

<style>
  /* Hide scrollbar for category pills */
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  /* Product pill border styles */
  .product-pill {
    border: 1px solid #bbb;
  }
  .product-pill.active-pill {
    border-color: #333;
  }
  .product-pill:hover {
    border-color: #333;
  }
</style>

<script>
  function initProductCarousel() {
    const track = document.getElementById('carousel-track') as HTMLElement;
    const pills = document.querySelectorAll<HTMLButtonElement>('.product-pill');
    const dots = document.querySelectorAll<HTMLButtonElement>('.carousel-dot');
    const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
    const downloadBtn = document.getElementById('product-download-btn') as HTMLAnchorElement;

    if (!track || !prevBtn || !nextBtn) return;

    // 제품별 PDF 매핑 (Sanity에서 가져온 데이터)
    const productPdfMap = JSON.parse(document.getElementById('product-pdf-data')?.textContent || '[]');

    const totalSlides = track.children.length;
    let currentIndex = 0;

    function goToSlide(index: number) {
      if (index < 0) index = totalSlides - 1;
      if (index >= totalSlides) index = 0;
      currentIndex = index;

      track.style.transform = `translateX(-${currentIndex * 100}%)`;

      // Update download button link
      if (downloadBtn && productPdfMap[currentIndex]) {
        downloadBtn.setAttribute('href', productPdfMap[currentIndex]);
      }

      // Update pills
      pills.forEach((pill, i) => {
        if (i === currentIndex) {
          pill.classList.add('active-pill');
          pill.setAttribute('aria-pressed', 'true');
        } else {
          pill.classList.remove('active-pill');
          pill.setAttribute('aria-pressed', 'false');
        }
      });

      // Update dots
      dots.forEach((dot, i) => {
        if (i === currentIndex) {
          dot.classList.add('bg-primary', 'scale-125');
          dot.classList.remove('bg-border-light');
        } else {
          dot.classList.remove('bg-primary', 'scale-125');
          dot.classList.add('bg-border-light');
        }
      });

      // Scroll active pill into view
      const activePill = pills[currentIndex];
      if (activePill) {
        activePill.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      }
    }

    prevBtn.addEventListener('click', () => goToSlide(currentIndex - 1));
    nextBtn.addEventListener('click', () => goToSlide(currentIndex + 1));

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const index = parseInt(pill.dataset.index || '0', 10);
        goToSlide(index);
      });
    });

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.dataset.dotIndex || '0', 10);
        goToSlide(index);
      });
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') goToSlide(currentIndex - 1);
      if (e.key === 'ArrowRight') goToSlide(currentIndex + 1);
    });

    // Touch/swipe support
    let touchStartX = 0;
    let touchEndX = 0;
    const viewport = document.getElementById('carousel-viewport');
    if (viewport) {
      viewport.addEventListener('touchstart', (e) => {
        touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });
      viewport.addEventListener('touchend', (e) => {
        touchEndX = e.changedTouches[0].screenX;
        const diff = touchStartX - touchEndX;
        if (Math.abs(diff) > 50) {
          if (diff > 0) goToSlide(currentIndex + 1);
          else goToSlide(currentIndex - 1);
        }
      }, { passive: true });
    }
  }

  function initPillsScrollIndicators() {
    const wrapper = document.getElementById('pills-wrapper');
    if (!wrapper) return;
    const container = wrapper.querySelector('.pills-scroll-container') as HTMLElement;
    const leftBtn = wrapper.querySelector('.pills-scroll-left') as HTMLButtonElement;
    const rightBtn = wrapper.querySelector('.pills-scroll-right') as HTMLButtonElement;
    if (!container || !leftBtn || !rightBtn) return;

    function updateIndicators() {
      const { scrollLeft, scrollWidth, clientWidth } = container;
      const atStart = scrollLeft <= 5;
      const atEnd = scrollLeft + clientWidth >= scrollWidth - 5;

      leftBtn.style.opacity = atStart ? '0' : '1';
      leftBtn.style.pointerEvents = atStart ? 'none' : 'auto';
      rightBtn.style.opacity = atEnd ? '0' : '1';
      rightBtn.style.pointerEvents = atEnd ? 'none' : 'auto';
    }

    container.addEventListener('scroll', updateIndicators, { passive: true });
    window.addEventListener('resize', updateIndicators);
    leftBtn.addEventListener('click', () => container.scrollBy({ left: -150, behavior: 'smooth' }));
    rightBtn.addEventListener('click', () => container.scrollBy({ left: 150, behavior: 'smooth' }));

    // Initial check
    setTimeout(updateIndicators, 100);
  }

  document.addEventListener('DOMContentLoaded', () => { initProductCarousel(); initPillsScrollIndicators(); });
  document.addEventListener('astro:after-swap', () => { initProductCarousel(); initPillsScrollIndicators(); });
</script>
