---
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import { products, productCategories } from '@data/products';
---

<BaseLayout
  title="제품소개 페이지 | 피키픽 | 포토부스 대여 및 기업 행사 렌탈 전문"
  description="피키픽 포토부스의 9종 이상 포토부스 라인업을 소개합니다. 모던피키, 클래식피키, 어반피키, 미니피키, 레트로피키, 아웃도어피키, 에어피키 등 행사에 맞는 최적의 포토부스를 선택하세요."
>
  <BreadcrumbSchema items={[
    { name: '홈', href: '/' },
    { name: '제품소개', href: '/products' },
  ]} />

  <!-- Hero: PRODUCT TYPE -->
  <section class="pt-28 pb-4 lg:pt-40 lg:pb-12 bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <h1 class="text-center text-2xl sm:text-4xl md:text-7xl lg:text-8xl font-black tracking-tight text-primary uppercase gs-fade-up">
        PRODUCT TYPE
      </h1>
    </div>
  </section>

  <!-- Category Filter Pills -->
  <section class="pb-4 lg:pb-12 bg-white" aria-label="제품 카테고리 필터">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <nav class="overflow-x-auto scrollbar-hide" aria-label="제품 카테고리">
        <div class="flex gap-2.5 lg:gap-3.5 justify-start lg:justify-center min-w-max pb-2" id="category-pills">
          {productCategories.map((cat, i) => (
            <button
              type="button"
              class:list={[
                'product-pill flex flex-col items-center justify-center h-[42px] lg:h-[50px] px-2.5 lg:px-3 rounded-full transition-all duration-300 cursor-pointer whitespace-nowrap min-w-[100px] lg:min-w-[125px] bg-white text-black',
                i === 0
                  ? 'active-pill'
                  : '',
              ]}
              data-category={cat.id}
              data-index={i}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              <span class="text-[11px] lg:text-xs font-normal leading-tight">{cat.labelKo}</span>
              <span class="text-[10px] lg:text-xs font-normal mt-0.5 opacity-70 leading-tight">{cat.labelEn}</span>
            </button>
          ))}
        </div>
      </nav>
    </div>
  </section>

  <!-- Product Carousel -->
  <section class="py-8 lg:py-16 bg-white" aria-label="제품 상세정보">
    <div class="mx-auto max-w-[1600px] px-6 lg:px-8 relative">
      <!-- Navigation Arrows -->
      <button
        type="button"
        id="prev-btn"
        class="absolute left-0 top-1/2 -translate-y-1/2 z-20 w-12 h-12 lg:w-14 lg:h-14 flex items-center justify-center bg-white border border-border rounded-full shadow-lg hover:bg-primary hover:text-white hover:border-primary transition-all duration-300 cursor-pointer"
        aria-label="이전 제품"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
      </button>
      <button
        type="button"
        id="next-btn"
        class="absolute right-0 top-1/2 -translate-y-1/2 z-20 w-12 h-12 lg:w-14 lg:h-14 flex items-center justify-center bg-white border border-border rounded-full shadow-lg hover:bg-primary hover:text-white hover:border-primary transition-all duration-300 cursor-pointer"
        aria-label="다음 제품"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </button>

      <!-- Carousel Container -->
      <div class="overflow-hidden mx-8 lg:mx-12" id="carousel-viewport">
        <div class="flex transition-transform duration-500 ease-in-out" id="carousel-track">
          {products.map((product) => (
            <article
              class="w-full flex-shrink-0 product-slide"
              data-product-id={product.id}
              data-product-index={product.index}
              itemscope
              itemtype="https://schema.org/Product"
            >
              <!-- Product Title -->
              <div class="hidden lg:block mb-6 pl-2">
                <span class="text-2xl lg:text-3xl font-black tracking-[0.15em] text-primary uppercase block mb-1">{product.type}</span>
                <h2 class="text-base lg:text-lg font-medium text-secondary tracking-tight leading-tight" itemprop="name">
                  {product.name} | {product.nameKo}
                </h2>
              </div>

              <!-- Mobile: Product Title -->
              <div class="flex flex-col items-center mb-4 lg:hidden">
                <span class="text-xl font-black tracking-[0.15em] text-primary uppercase mb-1">{product.type}</span>
                <h2 class="text-sm font-medium text-secondary tracking-tight leading-tight" itemprop="name">
                  {product.name} | {product.nameKo}
                </h2>
              </div>

              <!-- Desktop: 3-column layout -->
              <div class="hidden lg:grid lg:grid-cols-12 gap-0 items-end">
                <!-- Left: Line Image -->
                <div class="lg:col-span-3 flex items-end justify-center">
                  <img
                    src={product.imageLeft}
                    alt={`${product.name} ${product.nameKo} 라인 이미지`}
                    class="max-w-full max-h-[550px]"
                    loading="lazy"
                  />
                </div>

                <!-- Center: Spec Table -->
                <div class="lg:col-span-5 px-6 flex flex-col justify-end">
                  <h3 class="text-sm font-bold tracking-[0.1em] text-primary uppercase mb-4 text-center">
                    Photo booth specification
                  </h3>
                  <table class="w-full text-sm border-collapse" itemprop="additionalProperty">
                    <tbody>
                      {product.specs.map((spec) => (
                        <tr class="border-b border-border-light">
                          <th class="text-left py-2 pr-4 font-semibold text-primary text-xs whitespace-nowrap align-top w-[140px]">
                            {spec.label}
                          </th>
                          <td class="py-2 text-secondary text-xs leading-relaxed">
                            {spec.value}
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>

                <!-- Right: Product Photo -->
                <div class="lg:col-span-4 flex items-end justify-center">
                  <img
                    src={product.imageRight}
                    alt={`${product.name} ${product.nameKo} 제품 이미지`}
                    class="max-w-full max-h-[550px]"
                    loading="lazy"
                    itemprop="image"
                  />
                </div>
              </div>

              <!-- Mobile: Images + Spec -->
              <div class="lg:hidden">
                <div class="flex gap-4 justify-center mb-6">
                  <div class="w-1/2 max-w-[200px] flex items-end justify-center">
                    <img
                      src={product.imageLeft}
                      alt={`${product.name} ${product.nameKo} 라인 이미지`}
                      class="max-w-full max-h-[300px] object-contain"
                      loading="lazy"
                    />
                  </div>
                  <div class="w-1/2 max-w-[200px] flex items-end justify-center">
                    <img
                      src={product.imageRight}
                      alt={`${product.name} ${product.nameKo} 제품 이미지`}
                      class="max-w-full max-h-[300px] object-contain"
                      loading="lazy"
                    />
                  </div>
                </div>
                <h3 class="text-sm font-bold tracking-[0.1em] text-primary uppercase mb-4 text-center">
                  Photo booth specification
                </h3>
                <table class="w-full text-sm border-collapse" itemprop="additionalProperty">
                  <tbody>
                    {product.specs.map((spec) => (
                      <tr class="border-b border-border-light">
                        <th class="text-left py-2 pr-4 font-semibold text-primary text-xs whitespace-nowrap align-top w-[140px]">
                          {spec.label}
                        </th>
                        <td class="py-2 text-secondary text-xs leading-relaxed">
                          {spec.value}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </article>
          ))}
        </div>
      </div>

      <!-- Carousel Dots -->
      <div class="flex justify-center gap-2 mt-8" id="carousel-dots" aria-label="제품 선택">
        {products.map((_, i) => (
          <button
            type="button"
            class:list={[
              'carousel-dot w-2.5 h-2.5 rounded-full transition-all duration-300 cursor-pointer',
              i === 0 ? 'bg-primary scale-125' : 'bg-border-light hover:bg-secondary',
            ]}
            data-dot-index={i}
            aria-label={`제품 ${i + 1}`}
          ></button>
        ))}
      </div>
    </div>
  </section>

  <!-- Download Section (changes based on selected product) -->
  <section class="py-12 lg:py-16 bg-white" aria-label="제품 소개서 다운로드">
    <div class="mx-auto max-w-3xl px-6 lg:px-8 text-center">
      <a
        id="product-download-btn"
        href="/files/products/stand-picky-intro.pdf"
        download
        class="inline-flex items-center justify-center gap-2 px-10 py-4 border border-gray-400 rounded-full text-primary font-semibold text-sm tracking-[0.02em] hover:bg-primary hover:text-white hover:border-primary transition-colors duration-300"
      >
        제품소개서 다운로드
      </a>
    </div>
  </section>

  <!-- Structured Data: Products -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "PICKYPIC 포토부스 제품 라인업",
    "description": "피키픽 포토부스의 9종 포토부스 제품 소개. 스탠드형, 테이블형, 부스형 포토부스를 확인하세요.",
    "numberOfItems": products.length,
    "itemListElement": products.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "Product",
        "name": `${p.name} | ${p.nameKo}`,
        "image": `https://picky-pic.com${p.image}`,
        "description": `${p.nameKo} - ${p.type} 포토부스. 브랜드 팝업, 기업 행사, 파티 등에 적합한 PICKYPIC의 프리미엄 포토부스.`,
        "category": p.type,
        "brand": {
          "@type": "Brand",
          "name": "PICKYPIC"
        },
        "url": "https://picky-pic.com/products"
      }
    }))
  })} />
</BaseLayout>

<style>
  /* Hide scrollbar for category pills */
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  /* Product pill border styles */
  .product-pill {
    border: 1px solid #bbb;
  }
  .product-pill.active-pill {
    border-color: #333;
  }
  .product-pill:hover {
    border-color: #333;
  }
</style>

<script>
  function initProductCarousel() {
    const track = document.getElementById('carousel-track') as HTMLElement;
    const pills = document.querySelectorAll<HTMLButtonElement>('.product-pill');
    const dots = document.querySelectorAll<HTMLButtonElement>('.carousel-dot');
    const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
    const downloadBtn = document.getElementById('product-download-btn') as HTMLAnchorElement;

    if (!track || !prevBtn || !nextBtn) return;

    // 제품별 PDF 매핑 (9개 제품 → 5개 PDF)
    const productPdfMap = [
      '/files/products/stand-picky-intro.pdf',   // 0: Modern Picky
      '/files/products/stand-picky-intro.pdf',   // 1: Classic Picky
      '/files/products/stand-picky-intro.pdf',   // 2: Urban Picky
      '/files/products/mini-picky-intro.pdf',    // 3: Modern Mini Picky
      '/files/products/mini-picky-intro.pdf',    // 4: Urban Mini Picky
      '/files/products/retro-picky-intro.pdf',   // 5: Modern Retro Picky
      '/files/products/retro-picky-intro.pdf',   // 6: Urban Retro Picky
      '/files/products/outdoor-picky-intro.pdf', // 7: Outdoor Picky
      '/files/products/air-picky-intro.pdf',     // 8: Air Picky
    ];

    const totalSlides = track.children.length;
    let currentIndex = 0;

    function goToSlide(index: number) {
      if (index < 0) index = totalSlides - 1;
      if (index >= totalSlides) index = 0;
      currentIndex = index;

      track.style.transform = `translateX(-${currentIndex * 100}%)`;

      // Update download button link
      if (downloadBtn && productPdfMap[currentIndex]) {
        downloadBtn.setAttribute('href', productPdfMap[currentIndex]);
      }

      // Update pills
      pills.forEach((pill, i) => {
        if (i === currentIndex) {
          pill.classList.add('active-pill');
          pill.setAttribute('aria-pressed', 'true');
        } else {
          pill.classList.remove('active-pill');
          pill.setAttribute('aria-pressed', 'false');
        }
      });

      // Update dots
      dots.forEach((dot, i) => {
        if (i === currentIndex) {
          dot.classList.add('bg-primary', 'scale-125');
          dot.classList.remove('bg-border-light');
        } else {
          dot.classList.remove('bg-primary', 'scale-125');
          dot.classList.add('bg-border-light');
        }
      });

      // Scroll active pill into view
      const activePill = pills[currentIndex];
      if (activePill) {
        activePill.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      }
    }

    prevBtn.addEventListener('click', () => goToSlide(currentIndex - 1));
    nextBtn.addEventListener('click', () => goToSlide(currentIndex + 1));

    pills.forEach((pill) => {
      pill.addEventListener('click', () => {
        const index = parseInt(pill.dataset.index || '0', 10);
        goToSlide(index);
      });
    });

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.dataset.dotIndex || '0', 10);
        goToSlide(index);
      });
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') goToSlide(currentIndex - 1);
      if (e.key === 'ArrowRight') goToSlide(currentIndex + 1);
    });

    // Touch/swipe support
    let touchStartX = 0;
    let touchEndX = 0;
    const viewport = document.getElementById('carousel-viewport');
    if (viewport) {
      viewport.addEventListener('touchstart', (e) => {
        touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });
      viewport.addEventListener('touchend', (e) => {
        touchEndX = e.changedTouches[0].screenX;
        const diff = touchStartX - touchEndX;
        if (Math.abs(diff) > 50) {
          if (diff > 0) goToSlide(currentIndex + 1);
          else goToSlide(currentIndex - 1);
        }
      }, { passive: true });
    }
  }

  document.addEventListener('DOMContentLoaded', initProductCarousel);
  document.addEventListener('astro:after-swap', initProductCarousel);
</script>
