---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import ServiceSchema from '@components/seo/ServiceSchema.astro';
import FAQSchema from '@components/seo/FAQSchema.astro';
import { sanityClient, faqQueries } from '../sanity/client';

const emailjsServiceId = 'service_lo0iveb';
const emailjsTemplateId = 'template_zyud66s';
const emailjsPublicKey = 'DiKfjM0kSilVVTle_';

// EN/JP translation supplements (used until Sanity admin enters translations)
// If Sanity has questionEn/answerEn filled in, those take priority.
const faqTranslationSupplements: Record<string, { questionEn: string; answerEn: string; questionJp: string; answerJp: string }> = {
  '포토부스 렌탈 비용은 얼마인가요?': {
    questionEn: 'How much does photo booth rental cost?',
    answerEn: 'Rental pricing varies based on booth type, rental duration, and event details. Please submit an inquiry through our rental form and we will provide a custom quote within 1 business hour.',
    questionJp: 'フォトブースのレンタル費用はいくらですか？',
    answerJp: 'レンタル料金は、ブースの種類、レンタル期間、イベント内容によって異なります。レンタルフォームからお問い合わせいただければ、営業時間内1時間以内にお見積もりをご案内します。',
  },
  '최소 대여 기간은 얼마인가요?': {
    questionEn: 'What is the minimum rental period?',
    answerEn: 'The minimum rental period is 1 day. We also offer multi-day and long-term rental packages tailored to your event schedule.',
    questionJp: '最低レンタル期間はどのくらいですか？',
    answerJp: '最低レンタル期間は1日からとなります。イベントのスケジュールに合わせた複数日・長期レンタルパッケージもご用意しています。',
  },
  '설치와 철거는 누가 하나요?': {
    questionEn: 'Who handles installation and dismantling?',
    answerEn: 'Our team handles all setup and dismantling. We coordinate delivery, installation, and removal so you can focus entirely on your event.',
    questionJp: '設置と撤去は誰が行いますか？',
    answerJp: '設置と撤去はすべて弊社スタッフが担当します。搬入・設置・撤去まで一貫してサポートしますので、イベントに集中いただけます。',
  },
  '래핑 커스텀이 가능한가요?': {
    questionEn: 'Is custom wrapping available?',
    answerEn: 'Yes, we offer full custom wrapping services including lettering and full-surface graphics. Branded designs can be tailored to your event concept.',
    questionJp: 'ラッピングカスタムは可能ですか？',
    answerJp: 'はい、レタリングや全面グラフィックのカスタムラッピングが可能です。イベントのコンセプトに合わせたブランドデザインをご提案します。',
  },
  '해외 행사도 가능한가요?': {
    questionEn: 'Are overseas events available?',
    answerEn: 'Yes, we support international events. We have experience operating in Singapore, Japan, and other countries. Please contact us for overseas event inquiries.',
    questionJp: '海外イベントにも対応していますか？',
    answerJp: 'はい、海外イベントにも対応しています。シンガポール、日本など様々な国でのオペレーション実績があります。海外イベントのお問い合わせはお気軽にご連絡ください。',
  },
  '어떤 포토부스를 선택해야 할지 모르겠어요.': {
    questionEn: "I'm not sure which photo booth to choose.",
    answerEn: "Don't worry! Submit your rental inquiry with your event type, venue size, and concept, and our team will recommend the best booth for your needs.",
    questionJp: 'どのフォトブースを選べばいいか分かりません。',
    answerJp: 'ご安心ください！イベントの種類、会場の広さ、コンセプトをレンタルフォームからお知らせいただければ、担当スタッフが最適なブースをご提案します。',
  },
};

// FAQ를 Sanity에서 불러오기 (실패 시 빈 배열)
let rentalFAQ: { question: string; answer: string; questionEn?: string; answerEn?: string; questionJp?: string; answerJp?: string }[] = [];
try {
  const sanityFAQ = await sanityClient.fetch(faqQueries.byPage, { page: 'rental' });
  if (sanityFAQ && sanityFAQ.length > 0) {
    // Merge Sanity data with translation supplements (Sanity takes priority)
    rentalFAQ = sanityFAQ.map((item: any) => {
      const supplement = faqTranslationSupplements[item.question] || {};
      return {
        ...item,
        questionEn: item.questionEn || supplement.questionEn,
        answerEn: item.answerEn || supplement.answerEn,
        questionJp: item.questionJp || supplement.questionJp,
        answerJp: item.answerJp || supplement.answerJp,
      };
    });
  }
} catch (e) {
  // Sanity 연결 실패 시 빈 FAQ
}

const rentalProducts = [
  { image: '/images/rental/rental-1.jpg', labelKo: '테이블 타입 _ 모던 레트로피키 (영수증 사진)', labelEn: 'Table _ Modern Retro Picky' },
  { image: '/images/rental/rental-2.jpg', labelKo: '테이블 타입 _ 어반 레트로피키 (영수증 사진)', labelEn: 'Table _ Urban Retro Picky' },
  { image: '/images/rental/rental-3.jpg', labelKo: '테이블 타입 _ 모던 미니피키', labelEn: 'Table _ Modern Mini Picky' },
  { image: '/images/rental/rental-4.jpg', labelKo: '테이블 타입 _ 어반 미니피키', labelEn: 'Table _ Urban Mini Picky' },
  { image: '/images/rental/rental-5.jpg', labelKo: '스탠드 타입 _ 모던피키', labelEn: 'Stand _ Modern Picky' },
  { image: '/images/rental/rental-6.jpg', labelKo: '스탠드 타입 _ 클래식피키', labelEn: 'Stand _ Classic Picky' },
  { image: '/images/rental/rental-7.jpg', labelKo: '스탠드 타입 _ 어반피키', labelEn: 'Stand _ Urban Picky' },
  { image: '/images/rental/rental-8.jpg', labelKo: '부스 타입 _ 아웃도어피키', labelEn: 'Booth _ Outdoor Picky' },
  { image: '/images/rental/rental-9.jpg', labelKo: '부스 타입 _ 에어피키', labelEn: 'Booth _ Air Picky' },
];
---

<BaseLayout
  title="포토부스 대여 · 인생네컷 대여 문의 | 피키픽 PICKYPIC"
  description="포토부스 대여, 인생네컷 대여 문의는 피키픽에서. 브랜드 팝업, 기업 행사, 웨딩, 파티 맞춤 렌탈 서비스. 영업시간 1시간 내 답변. 지금 견적을 요청하세요."
>
  <BreadcrumbSchema items={[
    { name: '홈', href: '/' },
    { name: '렌탈문의', href: '/rental' },
  ]} />
  <ServiceSchema />
  <!-- RENTAL Hero Heading -->
  <section class="relative bg-white pt-14 pb-1 lg:pt-12 lg:pb-2 overflow-hidden">
    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8 gs-fade-up">
      <div class="flex items-center justify-between">
        <h1 class="text-2xl lg:text-[clamp(2.5rem,6vw,4.5rem)] font-bold tracking-[0.04em] text-primary leading-none" style="font-family: 'Montserrat', sans-serif;">
          RENTAL
        </h1>
        <a href="/products" class="text-sm border border-gray-400 rounded-full px-5 py-2 text-primary hover:bg-primary hover:text-white transition-colors lg:hidden" data-i18n="rental.btn_products">제품소개</a>
      </div>
      <p class="mt-3 text-sm lg:text-base text-secondary leading-relaxed max-w-2xl" data-i18n="rental.hero_desc">
        피키픽 포토부스는 "어디에나 어울리는 포토부스"를 슬로건으로, 장소와 상황에 구애받지 않는 새로운 포토부스 경험을 만듭니다. 스탠드형·테이블형·부스형 등 9종 이상의 라인업을 갖추고 있으며, 누적 10,000건 이상의 브랜드 팝업·기업 행사를 진행한 경험으로 완벽한 솔루션을 제공합니다.
      </p>
    </div>
  </section>

  <!-- Product Carousel -->
  <section class="pb-0 lg:pb-0 bg-white overflow-hidden" aria-label="렌탈 제품 갤러리">
    <div class="relative mx-auto max-w-7xl px-6 lg:px-8 gs-fade-up">
      <div class="relative">
        <!-- Carousel Track -->
        <div id="rental-carousel" class="flex gap-4 lg:gap-5 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-1 -mx-6 px-6 lg:-mx-8 lg:px-8" style="scrollbar-width: none; -ms-overflow-style: none;">
          {rentalProducts.map((product, i) => (
            <article class="flex-shrink-0 w-[calc(50%-8px)] sm:w-[300px] lg:w-[320px] snap-start">
              <div class="overflow-hidden bg-bg-light mb-2 rounded-sm">
                <img
                  src={product.image}
                  alt={`피키픽 포토부스 렌탈 ${product.labelKo} — ${product.labelEn}`}
                  class="w-full h-auto transition-transform duration-500 hover:scale-105"
                  loading={i < 4 ? 'eager' : 'lazy'}
                  width="280"
                  height="373"
                />
              </div>
              <p class="text-[11px] lg:text-xs text-primary font-medium leading-snug">{product.labelKo}</p>
              <p class="text-[10px] lg:text-[11px] text-secondary leading-snug mt-0.5">{product.labelEn}</p>
            </article>
          ))}
        </div>

        <!-- Pagination Dots (mobile) -->
        <div class="flex justify-center gap-1.5 mt-1 lg:hidden" id="rental-dots">
          {rentalProducts.map((_, i) => (
            <span class:list={['rental-dot w-2 h-2 rounded-full', i === 0 ? 'bg-primary' : 'bg-gray-300']} data-index={i}></span>
          ))}
        </div>

        <!-- Navigation Arrows -->
        <button
          type="button"
          id="carousel-prev"
          class="absolute left-0 top-[calc(50%-40px)] -translate-y-1/2 -translate-x-2 z-10 w-10 h-10 bg-white/90 border border-border-light flex items-center justify-center hover:bg-primary hover:text-white transition-colors duration-200 hidden lg:flex"
          aria-label="이전 제품 보기"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button
          type="button"
          id="carousel-next"
          class="absolute right-0 top-[calc(50%-40px)] -translate-y-1/2 translate-x-2 z-10 w-10 h-10 bg-white/90 border border-border-light flex items-center justify-center hover:bg-primary hover:text-white transition-colors duration-200 hidden lg:flex"
          aria-label="다음 제품 보기"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- Rental Inquiry Form Section -->
  <section class="pt-6 pb-8 lg:pt-8 lg:pb-10 bg-bg-light" aria-labelledby="rental-form-heading">
    <div class="mx-auto max-w-3xl px-6 lg:px-8">
      <!-- Section Heading -->
      <div class="mb-8">
        <h2 id="rental-form-heading" class="text-2xl lg:text-3xl font-bold text-primary tracking-tight" data-i18n="rental.inquiry_title">렌탈 문의</h2>
        <p class="mt-4 text-sm lg:text-base text-secondary leading-relaxed" data-i18n="rental.inquiry_desc">
          희망하시는 렌탈 내용을 아래 양식에 맞춰 작성 부탁드립니다!<br />
          해당 부서에서 순차적으로 답변드릴 예정입니다. (영업 시간 기준 1시간 이내)
        </p>
      </div>

      <form id="rental-form" class="space-y-10" novalidate
        data-emailjs-service={emailjsServiceId}
        data-emailjs-template={emailjsTemplateId}
        data-emailjs-key={emailjsPublicKey}
      >
        <!-- 포토부스 타입 -->
        <fieldset>
          <legend class="text-lg font-bold text-primary mb-6 tracking-tight flex items-center gap-1">
            <span data-i18n="rental.booth_type">포토부스 타입</span> <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-1" aria-label="필수"></span>
          </legend>

          <div class="space-y-3">
              <label class="booth-label flex w-fit items-start gap-3 cursor-pointer group" data-img-left="/images/products/urban-mini-picky-line.png" data-img-right="/images/products/urban-mini-picky-photo.webp">
                <input type="checkbox" name="boothType" value="urban-mini" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors"><span class="font-semibold" data-i18n="rental.type_table">[테이블형]</span> 어반 미니 <span class="text-secondary">(W350 x L350 x H400)</span></span>
              </label>
              <label class="booth-label flex w-fit items-start gap-3 cursor-pointer group" data-img-left="/images/products/modern-mini-picky-line.png" data-img-right="/images/products/modern-mini-picky-photo.webp">
                <input type="checkbox" name="boothType" value="modern-mini" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors"><span class="font-semibold" data-i18n="rental.type_table">[테이블형]</span> 모던 미니 <span class="text-secondary">(W330 x L330 x H390)</span></span>
              </label>
              <label class="booth-label flex w-fit items-start gap-3 cursor-pointer group" data-img-left="/images/products/modern-retro-picky-line.png" data-img-right="/images/products/modern-retro-picky-photo.webp">
                <input type="checkbox" name="boothType" value="modern-retro" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors"><span class="font-semibold" data-i18n="rental.type_table">[테이블형]</span> <span class="font-semibold" data-i18n="rental.type_receipt">[영수증 사진기]</span> 모던 레트로피키 <span class="text-secondary">(W290 x L290 x H310)</span></span>
              </label>
              <label class="booth-label flex w-fit items-start gap-3 cursor-pointer group" data-img-left="/images/products/urban-retro-picky-line.png" data-img-right="/images/products/urban-retro-picky-photo.webp">
                <input type="checkbox" name="boothType" value="urban-retro" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors"><span class="font-semibold" data-i18n="rental.type_table">[테이블형]</span> <span class="font-semibold" data-i18n="rental.type_receipt">[영수증 사진기]</span> 어반 레트로 피키 <span class="text-secondary">(W190 x L230 x H316)</span></span>
              </label>
              <label class="booth-label flex w-fit items-start gap-3 cursor-pointer group" data-img-left="/images/products/modern-picky-line.png" data-img-right="/images/products/modern-picky-photo.webp">
                <input type="checkbox" name="boothType" value="modern-picky" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors"><span class="font-semibold" data-i18n="rental.type_stand">[스탠드형]</span> 모던 피키 <span class="text-secondary">(W550 x L550 x H1,570)</span></span>
              </label>
              <label class="booth-label flex w-fit items-start gap-3 cursor-pointer group" data-img-left="/images/products/classic-picky-line.png" data-img-right="/images/products/classic-picky-photo.webp">
                <input type="checkbox" name="boothType" value="classic-picky" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors"><span class="font-semibold" data-i18n="rental.type_stand">[스탠드형]</span> 클래식 피키 <span class="text-secondary">(W550 x L550 x H1,570)</span></span>
              </label>
              <label class="booth-label flex w-fit items-start gap-3 cursor-pointer group" data-img-left="/images/products/urban-picky-line.png" data-img-right="/images/products/urban-picky-photo.webp">
                <input type="checkbox" name="boothType" value="urban-picky" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors"><span class="font-semibold" data-i18n="rental.type_stand">[스탠드형]</span> 어반 피키 <span class="text-secondary">(W500 x L500 x H1,440)</span></span>
              </label>
              <label class="booth-label flex w-fit items-start gap-3 cursor-pointer group" data-img-left="/images/products/air-picky-line.png" data-img-right="/images/products/air-picky-photo.webp">
                <input type="checkbox" name="boothType" value="air-picky" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors"><span class="font-semibold" data-i18n="rental.type_booth">[부스형]</span> 에어 피키 <span class="text-secondary">(Booth: W930 x L930 x H2,350 / Kiosk: W500 x L600 x H1,200)</span></span>
              </label>
              <label class="booth-label flex w-fit items-start gap-3 cursor-pointer group" data-img-left="/images/products/outdoor-picky-line.png" data-img-right="/images/products/outdoor-picky-photo.webp">
                <input type="checkbox" name="boothType" value="outdoor-picky" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors"><span class="font-semibold" data-i18n="rental.type_booth">[부스형]</span> 아웃도어 피키 <span class="text-secondary">(W1,400 x L1,000 x H2,050)</span></span>
              </label>
          </div>
        </fieldset>

        <!-- Booth Preview Popup (desktop only) -->
        <div id="booth-preview" class="hidden fixed z-50 bg-white shadow-xl rounded-lg border border-border/30 p-3 pointer-events-none transition-opacity duration-150" style="width: 380px;">
          <div class="flex gap-2">
            <img id="preview-left" src="" alt="피키픽 포토부스 제품 라인아트 — 포토부스 렌탈 모델 도면" class="w-1/2 h-auto object-contain bg-gray-50 rounded" />
            <img id="preview-right" src="" alt="피키픽 포토부스 제품 실물 사진 — 포토부스 대여 모델" class="w-1/2 h-auto object-contain bg-gray-50 rounded" />
          </div>
        </div>

        <div class="h-px bg-border-light"></div>

        <!-- 행사 & 담당자 정보 -->
        <div class="space-y-5">
          <div>
            <label for="event-name" class="block text-sm font-medium text-primary mb-2">
              <span data-i18n="rental.event_name">행사명</span> <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5 align-middle" aria-label="필수"></span>
            </label>
            <input
              type="text"
              id="event-name"
              name="eventName"
              required
              class="w-full px-4 py-3 border border-border-light text-sm text-primary placeholder:text-secondary/50 focus:outline-none focus:border-primary transition-colors bg-white"
              placeholder="행사명을 입력해주세요"
              data-i18n-placeholder="rental.event_name_placeholder"
            />
          </div>

          <div>
            <label for="company-name" class="block text-sm font-medium text-primary mb-2">
              <span data-i18n="rental.company_name">개인 or 사업자명</span> <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5 align-middle" aria-label="필수"></span>
            </label>
            <input
              type="text"
              id="company-name"
              name="companyName"
              required
              class="w-full px-4 py-3 border border-border-light text-sm text-primary placeholder:text-secondary/50 focus:outline-none focus:border-primary transition-colors bg-white"
              placeholder="개인명 또는 사업자명을 입력해주세요"
              data-i18n-placeholder="rental.company_name_placeholder"
            />
          </div>

          <div>
            <label for="contact-name" class="block text-sm font-medium text-primary mb-2">
              <span data-i18n="rental.contact_name">담당자 성함</span> <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5 align-middle" aria-label="필수"></span>
            </label>
            <input
              type="text"
              id="contact-name"
              name="contactName"
              required
              class="w-full px-4 py-3 border border-border-light text-sm text-primary placeholder:text-secondary/50 focus:outline-none focus:border-primary transition-colors bg-white"
              placeholder="담당자 성함을 입력해주세요"
              data-i18n-placeholder="rental.contact_name_placeholder"
            />
          </div>

          <div>
            <label for="contact-phone" class="block text-sm font-medium text-primary mb-2">
              <span data-i18n="rental.contact_phone">담당자 연락처</span> <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5 align-middle" aria-label="필수"></span>
            </label>
            <input
              type="tel"
              id="contact-phone"
              name="contactPhone"
              required
              pattern="[0-9]{2,3}-?[0-9]{3,4}-?[0-9]{4}"
              class="w-full px-4 py-3 border border-border-light text-sm text-primary placeholder:text-secondary/50 focus:outline-none focus:border-primary transition-colors bg-white"
              placeholder="010-0000-0000"
            />
          </div>

          <div>
            <label for="contact-email" class="block text-sm font-medium text-primary mb-2">
              <span data-i18n="rental.contact_email">담당자 이메일 주소</span> <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5 align-middle" aria-label="필수"></span>
            </label>
            <input
              type="email"
              id="contact-email"
              name="contactEmail"
              required
              class="w-full px-4 py-3 border border-border-light text-sm text-primary placeholder:text-secondary/50 focus:outline-none focus:border-primary transition-colors bg-white"
              placeholder="email@example.com"
            />
          </div>

          <div>
            <label for="install-location" class="block text-sm font-medium text-primary mb-2">
              <span data-i18n="rental.install_location">설치 장소</span> <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5 align-middle" aria-label="필수"></span>
            </label>
            <input
              type="text"
              id="install-location"
              name="installLocation"
              required
              class="w-full px-4 py-3 border border-border-light text-sm text-primary placeholder:text-secondary/50 focus:outline-none focus:border-primary transition-colors bg-white"
              placeholder="설치 장소 주소를 입력해주세요"
              data-i18n-placeholder="rental.install_location_placeholder"
            />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="event-schedule" class="block text-sm font-medium text-primary mb-2">
                <span data-i18n="rental.event_schedule">행사 일정</span> <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5 align-middle" aria-label="필수"></span>
              </label>
              <input
                type="date"
                id="event-schedule"
                name="eventSchedule"
                required
                class="w-full px-4 py-3 border border-border-light text-sm text-primary focus:outline-none focus:border-primary transition-colors bg-white"
              />
            </div>
            <div>
              <label for="removal-schedule" class="block text-sm font-medium text-primary mb-2">
                <span data-i18n="rental.removal_schedule">철거 일정</span> <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5 align-middle" aria-label="필수"></span>
              </label>
              <input
                type="date"
                id="removal-schedule"
                name="removalSchedule"
                required
                class="w-full px-4 py-3 border border-border-light text-sm text-primary focus:outline-none focus:border-primary transition-colors bg-white"
              />
            </div>
          </div>
        </div>

        <div class="h-px bg-border-light"></div>

        <!-- 래핑 진행 여부 -->
        <fieldset>
          <legend class="text-sm font-medium text-primary mb-3 flex items-center gap-1">
            <span data-i18n="rental.wrapping">래핑 진행 여부</span> <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5" aria-label="필수"></span>
          </legend>
          <div class="flex flex-wrap gap-4">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="wrapping" value="래핑 안함" required class="w-4 h-4 accent-primary" />
              <span class="text-sm text-primary" data-i18n="rental.wrapping_none">래핑 안함</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="wrapping" value="레터링 래핑" class="w-4 h-4 accent-primary" />
              <span class="text-sm text-primary" data-i18n="rental.wrapping_lettering">레터링 래핑</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="wrapping" value="전체 래핑" class="w-4 h-4 accent-primary" />
              <span class="text-sm text-primary" data-i18n="rental.wrapping_full">전체 래핑</span>
            </label>
          </div>
        </fieldset>

        <div class="h-px bg-border-light"></div>

        <!-- 유료/무료 촬영 -->
        <fieldset>
          <legend class="text-sm font-medium text-primary mb-3 flex items-center gap-1">
            <span data-i18n="rental.shooting_type">유료/무료 촬영</span> <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5" aria-label="필수"></span>
          </legend>
          <div class="flex flex-wrap gap-4">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="shootingType" value="유료 촬영" required class="w-4 h-4 accent-primary" />
              <span class="text-sm text-primary" data-i18n="rental.shooting_paid">유료 촬영</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="shootingType" value="무료 촬영" class="w-4 h-4 accent-primary" />
              <span class="text-sm text-primary" data-i18n="rental.shooting_free">무료 촬영</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="shootingType" value="쿠폰 촬영" class="w-4 h-4 accent-primary" />
              <span class="text-sm text-primary" data-i18n="rental.shooting_coupon">쿠폰 촬영</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="shootingType" value="미정" class="w-4 h-4 accent-primary" />
              <span class="text-sm text-primary" data-i18n="rental.shooting_undecided">미정</span>
            </label>
          </div>
        </fieldset>

        <div class="h-px bg-border-light"></div>

        <!-- 기타 문의 사항 -->
        <div>
          <label for="additional-message" class="block text-sm font-medium text-primary mb-2" data-i18n="rental.additional">기타 문의 사항</label>
          <textarea
            id="additional-message"
            name="additionalMessage"
            rows="5"
            class="w-full px-4 py-3 border border-border-light text-sm text-primary placeholder:text-secondary/50 focus:outline-none focus:border-primary transition-colors resize-none bg-white"
            placeholder="기타 문의 사항이 있으시면 자유롭게 작성해주세요."
            data-i18n-placeholder="rental.additional_placeholder"
          ></textarea>
        </div>

        <div class="h-px bg-border-light"></div>

        <!-- 개인정보 수집 및 이용 동의 -->
        <div>
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" id="privacy-agree" name="privacyAgree" required class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
            <div class="text-sm text-secondary leading-relaxed">
              <span class="font-semibold text-primary" data-i18n="rental.privacy_title">[필수] 개인정보 수집 및 이용 동의</span>
              <p class="mt-2 text-xs text-secondary leading-relaxed" data-i18n="rental.privacy_desc">
                수집 항목: 성함, 연락처, 이메일, 소속/회사명<br />
                수집 목적: 렌탈 문의 상담 및 답변<br />
                보유 기간: 문의 접수 후 상담 완료 시까지 (최대 1년)<br />
                동의를 거부하실 수 있으나, 거부 시 렌탈 문의가 제한됩니다.
              </p>
            </div>
          </label>
        </div>

        <!-- Submit -->
        <div class="text-center pt-4">
          <button
            type="submit"
            class="inline-block w-full sm:w-auto px-16 py-4 bg-primary text-white text-base font-semibold tracking-[0.08em] hover:bg-black transition-colors duration-300 cursor-pointer"
            data-i18n="rental.submit"
          >
            문의하기
          </button>
        </div>
      </form>
    </div>
  </section>

  <!-- Rental FAQ Section -->
  <FAQSchema items={rentalFAQ} title="렌탈 자주 묻는 질문" titleKey="faq.title_rental" />

  <!-- 문의 완료 모달 -->
  <div id="inquiry-result-overlay" class="fixed inset-0 z-[9999] flex items-center justify-center bg-black/40" style="display:none;">
    <div id="inquiry-result-modal" class="relative bg-white rounded-2xl shadow-2xl w-[90vw] max-w-[400px] p-8 text-center">
      <p id="inquiry-result-message" class="text-base text-gray-800 whitespace-pre-line leading-relaxed"></p>
      <button id="inquiry-result-confirm" class="mt-6 px-8 py-2.5 bg-black text-white rounded-full text-sm font-medium hover:bg-gray-800 transition-colors cursor-pointer">
        확인
      </button>
    </div>
  </div>
</BaseLayout>

<style>
  /* Hide scrollbar for carousel */
  #rental-carousel::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  // Import i18n translation function
  function getT(key: string): string {
    const lang = (localStorage.getItem('pickypic-lang') || 'ko') as 'ko' | 'en' | 'jp';
    const translations: Record<string, Record<string, string>> = {
      ko: {
        'validation.booth_required': '포토부스 타입을 1개 이상 선택해주세요.',
        'validation.required': '필수 입력 항목입니다.',
        'validation.email': '올바른 이메일 주소를 입력해주세요.',
        'validation.phone': '올바른 연락처를 입력해주세요. (예: 010-0000-0000)',
        'validation.select_required': '항목을 선택해주세요.',
        'validation.privacy_required': '개인정보 수집 및 이용에 동의해주세요.',
        'validation.success': '문의가 접수되었습니다. 담당자가 빠르게 연락드리겠습니다.',
        'validation.error': '전송에 실패했습니다. 잠시 후 다시 시도해주세요.\n또는 pickypic.photobooth@gmail.com으로 직접 문의해주세요.',
        'rental.submit': '문의하기',
        'rental.submitting': '전송 중...',
      },
      en: {
        'validation.booth_required': 'Please select at least one photo booth type.',
        'validation.required': 'This field is required.',
        'validation.email': 'Please enter a valid email address.',
        'validation.phone': 'Please enter a valid phone number. (e.g., 010-0000-0000)',
        'validation.select_required': 'Please select an option.',
        'validation.privacy_required': 'Please agree to the collection and use of personal information.',
        'validation.success': 'Your inquiry has been submitted. Our team will contact you shortly.',
        'validation.error': 'Failed to send. Please try again later.\nOr contact us directly at pickypic.photobooth@gmail.com.',
        'rental.submit': 'Submit Inquiry',
        'rental.submitting': 'Sending...',
      },
      jp: {
        'validation.booth_required': 'フォトブースタイプを1つ以上選択してください。',
        'validation.required': '必須入力項目です。',
        'validation.email': '正しいメールアドレスを入力してください。',
        'validation.phone': '正しい連絡先を入力してください。（例：010-0000-0000）',
        'validation.select_required': '項目を選択してください。',
        'validation.privacy_required': '個人情報の収集及び利用にご同意ください。',
        'validation.success': 'お問合せが受付されました。担当者より速やかにご連絡いたします。',
        'validation.error': '送信に失敗しました。しばらくしてから再度お試しください。\nまたは pickypic.photobooth@gmail.com まで直接お問合せください。',
        'rental.submit': 'お問合せする',
        'rental.submitting': '送信中...',
      },
    };
    return translations[lang]?.[key] ?? translations['ko'][key] ?? key;
  }

  function showInquiryModal(message: string) {
    const overlay = document.getElementById('inquiry-result-overlay');
    const msgEl = document.getElementById('inquiry-result-message');
    const confirmBtn = document.getElementById('inquiry-result-confirm');
    if (!overlay || !msgEl || !confirmBtn) return;

    msgEl.textContent = message;
    overlay.style.display = 'flex';

    const close = () => { overlay.style.display = 'none'; };
    confirmBtn.onclick = close;
    overlay.onclick = (e) => { if (e.target === overlay) close(); };
  }

  function initRentalPage() {
    // Carousel navigation
    const carousel = document.getElementById('rental-carousel');
    const prevBtn = document.getElementById('carousel-prev');
    const nextBtn = document.getElementById('carousel-next');

    if (carousel && prevBtn && nextBtn) {
      const scrollAmount = 300;

      prevBtn.addEventListener('click', () => {
        carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      });

      nextBtn.addEventListener('click', () => {
        carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      });
    }

    // Form validation
    const form = document.getElementById('rental-form') as HTMLFormElement | null;
    if (!form) return;

    // Error display helper
    function showError(input: HTMLElement, message: string) {
      clearError(input);
      input.classList.add('!border-red-500');
      const errorEl = document.createElement('p');
      errorEl.className = 'text-red-500 text-xs mt-1 form-error';
      errorEl.textContent = message;
      input.closest('div, label')?.appendChild(errorEl);
    }

    function clearError(input: HTMLElement) {
      input.classList.remove('!border-red-500');
      const parent = input.closest('div, label');
      const existing = parent?.querySelector('.form-error');
      if (existing) existing.remove();
    }

    // Clear errors on input
    form.addEventListener('input', (e) => {
      const target = e.target as HTMLElement;
      if (target) clearError(target);
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear all previous errors
      form.querySelectorAll('.form-error').forEach(el => el.remove());
      form.querySelectorAll('.\\!border-red-500').forEach(el => el.classList.remove('!border-red-500'));

      let isValid = true;
      let firstInvalid: HTMLElement | null = null;

      // Validate booth type (at least one checked)
      const boothChecks = form.querySelectorAll<HTMLInputElement>('input[name="boothType"]');
      const anyBoothChecked = Array.from(boothChecks).some(cb => cb.checked);
      if (!anyBoothChecked) {
        isValid = false;
        const legend = form.querySelector('fieldset legend');
        if (legend) {
          const errorEl = document.createElement('p');
          errorEl.className = 'text-red-500 text-xs mt-2 form-error';
          errorEl.textContent = getT('validation.booth_required');
          legend.parentElement?.insertBefore(errorEl, legend.nextSibling);
          if (!firstInvalid) firstInvalid = legend as HTMLElement;
        }
      }

      // Validate required text/email/tel inputs
      const requiredInputs = form.querySelectorAll<HTMLInputElement>('input[required]:not([type="checkbox"]):not([type="radio"])');
      requiredInputs.forEach(input => {
        if (!input.value.trim()) {
          isValid = false;
          showError(input, getT('validation.required'));
          if (!firstInvalid) firstInvalid = input;
        } else if (input.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value)) {
          isValid = false;
          showError(input, getT('validation.email'));
          if (!firstInvalid) firstInvalid = input;
        } else if (input.type === 'tel' && !/^[0-9]{2,3}-?[0-9]{3,4}-?[0-9]{4}$/.test(input.value)) {
          isValid = false;
          showError(input, getT('validation.phone'));
          if (!firstInvalid) firstInvalid = input;
        }
      });

      // Validate required radios
      ['wrapping', 'shootingType'].forEach(name => {
        const radios = form.querySelectorAll<HTMLInputElement>(`input[name="${name}"]`);
        const anyChecked = Array.from(radios).some(r => r.checked);
        if (!anyChecked) {
          isValid = false;
          const fieldset = radios[0]?.closest('fieldset');
          if (fieldset && !fieldset.querySelector('.form-error')) {
            const errorEl = document.createElement('p');
            errorEl.className = 'text-red-500 text-xs mt-2 form-error';
            errorEl.textContent = getT('validation.select_required');
            fieldset.appendChild(errorEl);
            if (!firstInvalid) firstInvalid = fieldset as HTMLElement;
          }
        }
      });

      // Validate privacy agreement
      const privacyCheck = form.querySelector<HTMLInputElement>('#privacy-agree');
      if (privacyCheck && !privacyCheck.checked) {
        isValid = false;
        const errorEl = document.createElement('p');
        errorEl.className = 'text-red-500 text-xs mt-2 form-error';
        errorEl.textContent = getT('validation.privacy_required');
        privacyCheck.closest('label')?.parentElement?.appendChild(errorEl);
        if (!firstInvalid) firstInvalid = privacyCheck;
      }

      if (!isValid) {
        firstInvalid?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      // Collect form data for EmailJS
      const checkedBooths = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="boothType"]:checked'))
        .map(cb => {
          const label = cb.closest('label')?.querySelector('span')?.textContent?.trim() || cb.value;
          return label;
        })
        .join(', ');

      const wrapping = form.querySelector<HTMLInputElement>('input[name="wrapping"]:checked')?.value || '';
      const shootingType = form.querySelector<HTMLInputElement>('input[name="shootingType"]:checked')?.value || '';

      const eventName = (form.querySelector<HTMLInputElement>('#event-name')?.value || '').trim();
      const companyName = (form.querySelector<HTMLInputElement>('#company-name')?.value || '').trim();
      const contactName = (form.querySelector<HTMLInputElement>('#contact-name')?.value || '').trim();
      const contactPhone = (form.querySelector<HTMLInputElement>('#contact-phone')?.value || '').trim();
      const contactEmail = (form.querySelector<HTMLInputElement>('#contact-email')?.value || '').trim();
      const installLocation = (form.querySelector<HTMLInputElement>('#install-location')?.value || '').trim();
      const eventSchedule = (form.querySelector<HTMLInputElement>('#event-schedule')?.value || '').trim();
      const removalSchedule = (form.querySelector<HTMLInputElement>('#removal-schedule')?.value || '').trim();
      const additionalMessage = (form.querySelector<HTMLTextAreaElement>('#additional-message')?.value || '').trim();

      const templateParams = {
        event_name: eventName,
        company_name: companyName,
        contact_name: contactName,
        contact_phone: contactPhone,
        contact_email: contactEmail,
        install_location: installLocation,
        event_schedule: eventSchedule,
        removal_schedule: removalSchedule,
        booth_type: checkedBooths,
        wrapping: wrapping,
        shooting_type: shootingType,
        additional_message: additionalMessage || '없음',
      };

      // Disable submit button
      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = getT('rental.submitting');
      }

      try {
        const emailjs = await import('@emailjs/browser');
        const serviceId = form.dataset.emailjsService!;
        const templateId = form.dataset.emailjsTemplate!;
        const publicKey = form.dataset.emailjsKey!;
        await emailjs.default.send(serviceId, templateId, templateParams, publicKey);

        // Sanity에도 저장 (서버 API 경유, 토큰 노출 없음)
        try {
          await fetch('/api/sanity', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              action: 'submitInquiry',
              data: {
                inquiryType: '렌탈문의',
                name: templateParams.contact_name,
                phone: templateParams.contact_phone,
                email: templateParams.contact_email,
                company: templateParams.company_name,
                eventName: templateParams.event_name,
                eventDate: templateParams.event_schedule,
                message: `설치장소: ${templateParams.install_location}\n부스타입: ${templateParams.booth_type}\n래핑: ${templateParams.wrapping}\n촬영: ${templateParams.shooting_type}\n철거: ${templateParams.removal_schedule}\n추가메시지: ${templateParams.additional_message}`,
                language: document.documentElement.lang || 'ko',
              },
            }),
          });
        } catch (sanityErr) {
          console.error('Sanity save error:', sanityErr);
        }

        showInquiryModal(getT('validation.success'));
        form.reset();
      } catch (error) {
        console.error('EmailJS Error:', error);
        showInquiryModal(getT('validation.error'));
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = getT('rental.submit');
        }
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initRentalPage);
  document.addEventListener('astro:after-swap', initRentalPage);

  // Booth type hover preview (desktop only)
  function initBoothPreview() {
    const isTouchOnly = 'ontouchstart' in window && !window.matchMedia('(min-width: 1024px)').matches;
    if (isTouchOnly) return;

    const preview = document.getElementById('booth-preview') as HTMLDivElement | null;
    const previewLeft = document.getElementById('preview-left') as HTMLImageElement | null;
    const previewRight = document.getElementById('preview-right') as HTMLImageElement | null;
    if (!preview || !previewLeft || !previewRight) return;

    const labels = document.querySelectorAll<HTMLLabelElement>('.booth-label');

    labels.forEach((label) => {
      label.addEventListener('mouseenter', () => {
        const imgLeft = label.dataset.imgLeft;
        const imgRight = label.dataset.imgRight;
        if (!imgLeft || !imgRight) return;

        previewLeft.src = imgLeft;
        previewRight.src = imgRight;
        preview.classList.remove('hidden');
      });

      label.addEventListener('mousemove', (e: MouseEvent) => {
        const pw = 400;
        const ph = 250;
        let x = e.clientX + 20;
        let y = e.clientY - 100;

        // Keep within viewport
        if (x + pw > window.innerWidth) x = e.clientX - pw - 20;
        if (y < 10) y = 10;
        if (y + ph > window.innerHeight) y = window.innerHeight - ph - 10;

        preview.style.left = x + 'px';
        preview.style.top = y + 'px';
      });

      label.addEventListener('mouseleave', () => {
        preview.classList.add('hidden');
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initBoothPreview);
  document.addEventListener('astro:after-swap', initBoothPreview);
</script>
