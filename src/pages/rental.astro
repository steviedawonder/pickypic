---
import BaseLayout from '@layouts/BaseLayout.astro';

const rentalProducts = [
  { image: '/images/rental/rental-1.jpg', labelKo: '테이블 타입 _ 모던 레트로피키 (영수증 사진)', labelEn: 'Table _ Modern Retro Picky' },
  { image: '/images/rental/rental-2.jpg', labelKo: '테이블 타입 _ 어반 레트로피키 (영수증 사진)', labelEn: 'Table _ Urban Retro Picky' },
  { image: '/images/rental/rental-3.jpg', labelKo: '테이블 타입 _ 모던 미니피키', labelEn: 'Table _ Modern Mini Picky' },
  { image: '/images/rental/rental-4.jpg', labelKo: '테이블 타입 _ 어반 미니피키', labelEn: 'Table _ Urban Mini Picky' },
  { image: '/images/rental/rental-5.jpg', labelKo: '스탠드 타입 _ 모던피키', labelEn: 'Stand _ Modern Picky' },
  { image: '/images/rental/rental-6.jpg', labelKo: '스탠드 타입 _ 클래식피키', labelEn: 'Stand _ Classic Picky' },
  { image: '/images/rental/rental-7.jpg', labelKo: '스탠드 타입 _ 어반피키', labelEn: 'Stand _ Urban Picky' },
  { image: '/images/rental/rental-8.jpg', labelKo: '부스 타입 _ 아웃도어피키', labelEn: 'Booth _ Outdoor Picky' },
  { image: '/images/rental/rental-9.jpg', labelKo: '부스 타입 _ 에어피키', labelEn: 'Booth _ Air Picky' },
];
---

<BaseLayout
  title="렌탈문의 페이지 | 피키픽 | 포토부스 대여 및 기업 행사 렌탈 전문"
  description="피키픽 포토부스 렌탈 문의. 테이블형, 스탠드형, 부스형 다양한 포토부스를 브랜드 팝업, 기업 행사, 웨딩, 파티 등에 맞춤 대여하세요. 영업 시간 기준 1시간 이내 답변."
>
  <!-- RENTAL Hero Heading -->
  <section class="relative bg-white pt-36 pb-12 lg:pt-44 lg:pb-16 overflow-hidden">
    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8 text-center gs-fade-up">
      <h1 class="text-[clamp(3.5rem,10vw,8rem)] font-bold tracking-[0.04em] text-primary leading-none" style="font-family: 'Montserrat', sans-serif;">
        RENTAL
      </h1>
    </div>
  </section>

  <!-- Product Carousel -->
  <section class="pb-16 lg:pb-24 bg-white overflow-hidden" aria-label="렌탈 제품 갤러리">
    <div class="relative mx-auto max-w-7xl px-6 lg:px-8 gs-fade-up">
      <div class="relative">
        <!-- Carousel Track -->
        <div id="rental-carousel" class="flex gap-5 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4 -mx-6 px-6 lg:-mx-8 lg:px-8" style="scrollbar-width: none; -ms-overflow-style: none;">
          {rentalProducts.map((product, i) => (
            <article class="flex-shrink-0 w-[240px] sm:w-[260px] lg:w-[280px] snap-start">
              <div class="aspect-[3/4] overflow-hidden bg-bg-light mb-3">
                <img
                  src={product.image}
                  alt={`${product.labelKo} - ${product.labelEn}`}
                  class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
                  loading={i < 4 ? 'eager' : 'lazy'}
                  width="280"
                  height="373"
                />
              </div>
              <p class="text-xs text-primary font-medium leading-snug">{product.labelKo}</p>
              <p class="text-[11px] text-secondary leading-snug mt-0.5">{product.labelEn}</p>
            </article>
          ))}
        </div>

        <!-- Navigation Arrows -->
        <button
          type="button"
          id="carousel-prev"
          class="absolute left-0 top-[calc(50%-40px)] -translate-y-1/2 -translate-x-2 z-10 w-10 h-10 bg-white/90 border border-border-light flex items-center justify-center hover:bg-primary hover:text-white transition-colors duration-200 hidden lg:flex"
          aria-label="이전 제품 보기"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button
          type="button"
          id="carousel-next"
          class="absolute right-0 top-[calc(50%-40px)] -translate-y-1/2 translate-x-2 z-10 w-10 h-10 bg-white/90 border border-border-light flex items-center justify-center hover:bg-primary hover:text-white transition-colors duration-200 hidden lg:flex"
          aria-label="다음 제품 보기"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- Rental Inquiry Form Section -->
  <section class="py-20 lg:py-28 bg-bg-light" aria-labelledby="rental-form-heading">
    <div class="mx-auto max-w-3xl px-6 lg:px-8">
      <!-- Section Heading -->
      <div class="mb-8 gs-fade-up">
        <h2 id="rental-form-heading" class="text-2xl lg:text-3xl font-bold text-primary tracking-tight">렌탈 문의</h2>
        <p class="mt-4 text-sm lg:text-base text-secondary leading-relaxed">
          희망하시는 렌탈 내용을 아래 양식에 맞춰 작성 부탁드립니다!<br />
          해당 부서에서 순차적으로 답변드릴 예정입니다. (영업 시간 기준 1시간 이내)
        </p>
      </div>

      <form id="rental-form" class="space-y-10 gs-fade-up" novalidate>
        <!-- 포토부스 타입 -->
        <fieldset>
          <legend class="text-lg font-bold text-primary mb-6 tracking-tight flex items-center gap-1">
            포토부스 타입 <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-1" aria-label="필수"></span>
          </legend>

          <!-- 1. 테이블형 -->
          <div class="mb-6">
            <p class="text-sm font-semibold text-primary mb-3">1. 테이블형</p>
            <div class="space-y-2.5">
              <label class="flex items-start gap-3 cursor-pointer group">
                <input type="checkbox" name="boothType" value="urban-mini" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors">어반 미니 <span class="text-secondary">(W350 x L350 x H400)</span></span>
              </label>
              <label class="flex items-start gap-3 cursor-pointer group">
                <input type="checkbox" name="boothType" value="modern-mini" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors">모던 미니 <span class="text-secondary">(W330 x L330 x H390)</span></span>
              </label>
              <label class="flex items-start gap-3 cursor-pointer group">
                <input type="checkbox" name="boothType" value="modern-retro" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors">[영수증 사진기] 모던 레트로피키 <span class="text-secondary">(W290 x L290 x H310)</span></span>
              </label>
              <label class="flex items-start gap-3 cursor-pointer group">
                <input type="checkbox" name="boothType" value="urban-retro" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors">어반 레트로 피키 <span class="text-secondary">(W190 x L230 x H316)</span></span>
              </label>
            </div>
          </div>

          <!-- 2. 스탠드형 -->
          <div class="mb-6">
            <p class="text-sm font-semibold text-primary mb-3">2. 스탠드형</p>
            <div class="space-y-2.5">
              <label class="flex items-start gap-3 cursor-pointer group">
                <input type="checkbox" name="boothType" value="modern-picky" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors">모던 피키 <span class="text-secondary">(W550 x L550 x H1,570)</span></span>
              </label>
              <label class="flex items-start gap-3 cursor-pointer group">
                <input type="checkbox" name="boothType" value="classic-picky" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors">클래식 피키 <span class="text-secondary">(W550 x L550 x H1,570)</span></span>
              </label>
              <label class="flex items-start gap-3 cursor-pointer group">
                <input type="checkbox" name="boothType" value="urban-picky" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors">어반 피키 <span class="text-secondary">(W500 x L500 x H1,440)</span></span>
              </label>
            </div>
          </div>

          <!-- 3. 부스형 -->
          <div>
            <p class="text-sm font-semibold text-primary mb-3">3. 부스형</p>
            <div class="space-y-2.5">
              <label class="flex items-start gap-3 cursor-pointer group">
                <input type="checkbox" name="boothType" value="air-picky" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors">에어 피키 <span class="text-secondary">(Booth: W930 x L930 x H2,350 / Kiosk: W500 x L600 x H1,200)</span></span>
              </label>
              <label class="flex items-start gap-3 cursor-pointer group">
                <input type="checkbox" name="boothType" value="outdoor-picky" class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
                <span class="text-sm text-primary group-hover:text-primary-light transition-colors">아웃도어 피키 <span class="text-secondary">(W1,400 x L1,000 x H2,050)</span></span>
              </label>
            </div>
          </div>
        </fieldset>

        <div class="h-px bg-border-light"></div>

        <!-- 행사 & 담당자 정보 -->
        <div class="space-y-5">
          <div>
            <label for="event-name" class="block text-sm font-medium text-primary mb-2">
              행사명 <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5 align-middle" aria-label="필수"></span>
            </label>
            <input
              type="text"
              id="event-name"
              name="eventName"
              required
              class="w-full px-4 py-3 border border-border-light text-sm text-primary placeholder:text-secondary/50 focus:outline-none focus:border-primary transition-colors bg-white"
              placeholder="행사명을 입력해주세요"
            />
          </div>

          <div>
            <label for="company-name" class="block text-sm font-medium text-primary mb-2">
              개인 or 사업자명 <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5 align-middle" aria-label="필수"></span>
            </label>
            <input
              type="text"
              id="company-name"
              name="companyName"
              required
              class="w-full px-4 py-3 border border-border-light text-sm text-primary placeholder:text-secondary/50 focus:outline-none focus:border-primary transition-colors bg-white"
              placeholder="개인명 또는 사업자명을 입력해주세요"
            />
          </div>

          <div>
            <label for="contact-name" class="block text-sm font-medium text-primary mb-2">
              담당자 성함 <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5 align-middle" aria-label="필수"></span>
            </label>
            <input
              type="text"
              id="contact-name"
              name="contactName"
              required
              class="w-full px-4 py-3 border border-border-light text-sm text-primary placeholder:text-secondary/50 focus:outline-none focus:border-primary transition-colors bg-white"
              placeholder="담당자 성함을 입력해주세요"
            />
          </div>

          <div>
            <label for="contact-phone" class="block text-sm font-medium text-primary mb-2">
              담당자 연락처 <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5 align-middle" aria-label="필수"></span>
            </label>
            <input
              type="tel"
              id="contact-phone"
              name="contactPhone"
              required
              pattern="[0-9]{2,3}-?[0-9]{3,4}-?[0-9]{4}"
              class="w-full px-4 py-3 border border-border-light text-sm text-primary placeholder:text-secondary/50 focus:outline-none focus:border-primary transition-colors bg-white"
              placeholder="010-0000-0000"
            />
          </div>

          <div>
            <label for="contact-email" class="block text-sm font-medium text-primary mb-2">
              담당자 이메일 주소 <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5 align-middle" aria-label="필수"></span>
            </label>
            <input
              type="email"
              id="contact-email"
              name="contactEmail"
              required
              class="w-full px-4 py-3 border border-border-light text-sm text-primary placeholder:text-secondary/50 focus:outline-none focus:border-primary transition-colors bg-white"
              placeholder="email@example.com"
            />
          </div>

          <div>
            <label for="install-location" class="block text-sm font-medium text-primary mb-2">
              설치 장소 <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5 align-middle" aria-label="필수"></span>
            </label>
            <input
              type="text"
              id="install-location"
              name="installLocation"
              required
              class="w-full px-4 py-3 border border-border-light text-sm text-primary placeholder:text-secondary/50 focus:outline-none focus:border-primary transition-colors bg-white"
              placeholder="설치 장소 주소를 입력해주세요"
            />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="event-schedule" class="block text-sm font-medium text-primary mb-2">
                행사 일정 <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5 align-middle" aria-label="필수"></span>
              </label>
              <input
                type="date"
                id="event-schedule"
                name="eventSchedule"
                required
                class="w-full px-4 py-3 border border-border-light text-sm text-primary focus:outline-none focus:border-primary transition-colors bg-white"
              />
            </div>
            <div>
              <label for="removal-schedule" class="block text-sm font-medium text-primary mb-2">
                철거 일정 <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5 align-middle" aria-label="필수"></span>
              </label>
              <input
                type="date"
                id="removal-schedule"
                name="removalSchedule"
                required
                class="w-full px-4 py-3 border border-border-light text-sm text-primary focus:outline-none focus:border-primary transition-colors bg-white"
              />
            </div>
          </div>
        </div>

        <div class="h-px bg-border-light"></div>

        <!-- 래핑 진행 여부 -->
        <fieldset>
          <legend class="text-sm font-medium text-primary mb-3 flex items-center gap-1">
            래핑 진행 여부 <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5" aria-label="필수"></span>
          </legend>
          <div class="flex flex-wrap gap-4">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="wrapping" value="래핑 안함" required class="w-4 h-4 accent-primary" />
              <span class="text-sm text-primary">래핑 안함</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="wrapping" value="레터링 래핑" class="w-4 h-4 accent-primary" />
              <span class="text-sm text-primary">레터링 래핑</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="wrapping" value="전체 래핑" class="w-4 h-4 accent-primary" />
              <span class="text-sm text-primary">전체 래핑</span>
            </label>
          </div>
        </fieldset>

        <div class="h-px bg-border-light"></div>

        <!-- 유료/무료 촬영 -->
        <fieldset>
          <legend class="text-sm font-medium text-primary mb-3 flex items-center gap-1">
            유료/무료 촬영 <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 ml-0.5" aria-label="필수"></span>
          </legend>
          <div class="flex flex-wrap gap-4">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="shootingType" value="유료 촬영" required class="w-4 h-4 accent-primary" />
              <span class="text-sm text-primary">유료 촬영</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="shootingType" value="무료 촬영" class="w-4 h-4 accent-primary" />
              <span class="text-sm text-primary">무료 촬영</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="shootingType" value="쿠폰 촬영" class="w-4 h-4 accent-primary" />
              <span class="text-sm text-primary">쿠폰 촬영</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="shootingType" value="미정" class="w-4 h-4 accent-primary" />
              <span class="text-sm text-primary">미정</span>
            </label>
          </div>
        </fieldset>

        <div class="h-px bg-border-light"></div>

        <!-- 기타 문의 사항 -->
        <div>
          <label for="additional-message" class="block text-sm font-medium text-primary mb-2">기타 문의 사항</label>
          <textarea
            id="additional-message"
            name="additionalMessage"
            rows="5"
            class="w-full px-4 py-3 border border-border-light text-sm text-primary placeholder:text-secondary/50 focus:outline-none focus:border-primary transition-colors resize-none bg-white"
            placeholder="기타 문의 사항이 있으시면 자유롭게 작성해주세요."
          ></textarea>
        </div>

        <div class="h-px bg-border-light"></div>

        <!-- 개인정보 수집 및 이용 동의 -->
        <div>
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="checkbox" id="privacy-agree" name="privacyAgree" required class="w-4 h-4 accent-primary mt-0.5 flex-shrink-0" />
            <div class="text-sm text-secondary leading-relaxed">
              <span class="font-semibold text-primary">[필수] 개인정보 수집 및 이용 동의</span>
              <p class="mt-2 text-xs text-secondary leading-relaxed">
                수집 항목: 성함, 연락처, 이메일, 소속/회사명<br />
                수집 목적: 렌탈 문의 상담 및 답변<br />
                보유 기간: 문의 접수 후 상담 완료 시까지 (최대 1년)<br />
                동의를 거부하실 수 있으나, 거부 시 렌탈 문의가 제한됩니다.
              </p>
            </div>
          </label>
        </div>

        <!-- Submit -->
        <div class="text-center pt-4">
          <button
            type="submit"
            class="inline-block w-full sm:w-auto px-16 py-4 bg-primary text-white text-base font-semibold tracking-[0.08em] hover:bg-black transition-colors duration-300 cursor-pointer"
          >
            문의하기
          </button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hide scrollbar for carousel */
  #rental-carousel::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function initRentalPage() {
    // Carousel navigation
    const carousel = document.getElementById('rental-carousel');
    const prevBtn = document.getElementById('carousel-prev');
    const nextBtn = document.getElementById('carousel-next');

    if (carousel && prevBtn && nextBtn) {
      const scrollAmount = 300;

      prevBtn.addEventListener('click', () => {
        carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      });

      nextBtn.addEventListener('click', () => {
        carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      });
    }

    // Form validation
    const form = document.getElementById('rental-form') as HTMLFormElement | null;
    if (!form) return;

    // Error display helper
    function showError(input: HTMLElement, message: string) {
      clearError(input);
      input.classList.add('!border-red-500');
      const errorEl = document.createElement('p');
      errorEl.className = 'text-red-500 text-xs mt-1 form-error';
      errorEl.textContent = message;
      input.closest('div, label')?.appendChild(errorEl);
    }

    function clearError(input: HTMLElement) {
      input.classList.remove('!border-red-500');
      const parent = input.closest('div, label');
      const existing = parent?.querySelector('.form-error');
      if (existing) existing.remove();
    }

    // Clear errors on input
    form.addEventListener('input', (e) => {
      const target = e.target as HTMLElement;
      if (target) clearError(target);
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      // Clear all previous errors
      form.querySelectorAll('.form-error').forEach(el => el.remove());
      form.querySelectorAll('.\\!border-red-500').forEach(el => el.classList.remove('!border-red-500'));

      let isValid = true;
      let firstInvalid: HTMLElement | null = null;

      // Validate booth type (at least one checked)
      const boothChecks = form.querySelectorAll<HTMLInputElement>('input[name="boothType"]');
      const anyBoothChecked = Array.from(boothChecks).some(cb => cb.checked);
      if (!anyBoothChecked) {
        isValid = false;
        const legend = form.querySelector('fieldset legend');
        if (legend) {
          const errorEl = document.createElement('p');
          errorEl.className = 'text-red-500 text-xs mt-2 form-error';
          errorEl.textContent = '포토부스 타입을 1개 이상 선택해주세요.';
          legend.parentElement?.insertBefore(errorEl, legend.nextSibling);
          if (!firstInvalid) firstInvalid = legend as HTMLElement;
        }
      }

      // Validate required text/email/tel inputs
      const requiredInputs = form.querySelectorAll<HTMLInputElement>('input[required]:not([type="checkbox"]):not([type="radio"])');
      requiredInputs.forEach(input => {
        if (!input.value.trim()) {
          isValid = false;
          showError(input, '필수 입력 항목입니다.');
          if (!firstInvalid) firstInvalid = input;
        } else if (input.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value)) {
          isValid = false;
          showError(input, '올바른 이메일 주소를 입력해주세요.');
          if (!firstInvalid) firstInvalid = input;
        } else if (input.type === 'tel' && !/^[0-9]{2,3}-?[0-9]{3,4}-?[0-9]{4}$/.test(input.value)) {
          isValid = false;
          showError(input, '올바른 연락처를 입력해주세요. (예: 010-0000-0000)');
          if (!firstInvalid) firstInvalid = input;
        }
      });

      // Validate required radios
      ['wrapping', 'shootingType'].forEach(name => {
        const radios = form.querySelectorAll<HTMLInputElement>(`input[name="${name}"]`);
        const anyChecked = Array.from(radios).some(r => r.checked);
        if (!anyChecked) {
          isValid = false;
          const fieldset = radios[0]?.closest('fieldset');
          if (fieldset && !fieldset.querySelector('.form-error')) {
            const errorEl = document.createElement('p');
            errorEl.className = 'text-red-500 text-xs mt-2 form-error';
            errorEl.textContent = '항목을 선택해주세요.';
            fieldset.appendChild(errorEl);
            if (!firstInvalid) firstInvalid = fieldset as HTMLElement;
          }
        }
      });

      // Validate privacy agreement
      const privacyCheck = form.querySelector<HTMLInputElement>('#privacy-agree');
      if (privacyCheck && !privacyCheck.checked) {
        isValid = false;
        const errorEl = document.createElement('p');
        errorEl.className = 'text-red-500 text-xs mt-2 form-error';
        errorEl.textContent = '개인정보 수집 및 이용에 동의해주세요.';
        privacyCheck.closest('label')?.parentElement?.appendChild(errorEl);
        if (!firstInvalid) firstInvalid = privacyCheck;
      }

      if (!isValid) {
        firstInvalid?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      // Success
      alert('문의가 접수되었습니다. 담당자가 빠르게 연락드리겠습니다.');
      form.reset();
    });
  }

  document.addEventListener('DOMContentLoaded', initRentalPage);
  document.addEventListener('astro:after-swap', initRentalPage);
</script>
