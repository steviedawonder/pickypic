const faqItems = [
  {
    question: '팝업스토어 포토부스 대여 비용은 얼마인가요?',
    answer: '팝업스토어 포토부스 대여 비용은 부스 타입, 행사 기간, 커스터마이징 범위에 따라 달라집니다. 테이블형 기준 1일 대여부터 장기 대여까지 유연하게 운영되며, 정확한 견적은 문의 후 1시간 이내에 안내드립니다.',
  },
  {
