---
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import { supportGuides } from '@data/support';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return supportGuides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
};

const { guide } = Astro.props;
---

<BaseLayout
  title={`${guide.name} 가이드 | 피키픽 | 포토부스 대여 및 기업 행사 렌탈 전문`}
  description={`${guide.name} (${guide.nameKo}) 포토부스 템플릿 가이드파일 다운로드. ${guide.category} 포토부스.`}
>
  <!-- TechArticle Schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TechArticle",
    "headline": `${guide.name} 포토부스 가이드`,
    "description": `${guide.name} (${guide.nameKo}) 포토부스 템플릿 가이드파일 다운로드`,
    "url": `https://picky-pic.com/support/${guide.slug}`,
    "author": { "@type": "Organization", "@id": "https://picky-pic.com/#organization" },
    "publisher": { "@type": "Organization", "@id": "https://picky-pic.com/#organization" },
    "inLanguage": "ko"
  })} />

  <BreadcrumbSchema items={[
    { name: '홈', href: '/' },
    { name: '고객지원', href: '/support' },
    { name: guide.name, href: `/support/${guide.slug}` },
  ]} />

  <section class="pt-4 pb-16 lg:pt-4 lg:pb-24 bg-white">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">

      <!-- Back Button -->
      <a href="/support" class="inline-flex items-center gap-2 text-sm text-secondary hover:text-primary transition-colors mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
        <span data-i18n="support.back_to_support">고객지원으로 돌아가기</span>
      </a>

      <!-- Header -->
      <div class="text-center mb-10 lg:mb-14">
        <span class="text-xs font-semibold tracking-[0.15em] text-secondary uppercase">{guide.category}</span>
        <h1 class="text-2xl lg:text-4xl font-bold text-primary tracking-tight mt-2">
          {guide.name}
        </h1>
        <p class="text-sm text-secondary mt-1">{guide.nameKo}</p>
      </div>

      <!-- Product Image -->
      <div class="flex justify-center mb-10 lg:mb-14">
        <div class="border border-border-light rounded-lg p-8 lg:p-12 inline-block">
          <img
            src={`/images/support/detail-${guide.slug}.png?v=2`}
            alt={`${guide.name} 가이드`}
            class="max-h-48 lg:max-h-72 w-auto object-contain"
          />
        </div>
      </div>

      <!-- Notice -->
      <div class="mb-10 lg:mb-14">
        <h2 class="text-lg lg:text-2xl font-bold text-primary tracking-tight mb-6 text-center">
          <span data-i18n="support.notice_label">주의사항 :</span> {guide.notice}
        </h2>
        <div class="flex justify-center">
          <img
            src={`/images/support/templates/${guide.slug}/notice.jpg?v=2`}
            alt={`${guide.name} ${guide.notice}`}
            class="max-w-full rounded-lg"
            loading="lazy"
          />
        </div>
      </div>

      <!-- File Groups - Image Grid -->
      {guide.fileGroups.map((group) => (
        <div class="mb-12 lg:mb-16">
          <h2 class="text-lg lg:text-2xl font-bold text-primary tracking-tight mb-6">
            <span data-i18n="support.template_label">템플릿 :</span> {group.category}
          </h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 lg:gap-5">
            {group.files.map((file, i) => (
              <a
                href={encodeURI(file.path)}
                download
                class="group block bg-bg-light rounded-lg overflow-hidden hover:shadow-md transition-all duration-300 cursor-pointer"
              >
                <div class="aspect-square flex items-center justify-center p-4">
                  <img
                    src={`${file.thumbnail}?v=2`}
                    alt={file.name}
                    class="max-w-full max-h-full object-contain"
                    loading="lazy"
                  />
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}

      <!-- Back to List -->
      <div class="text-center mt-12 lg:mt-16">
        <a
          href="/support"
          class="inline-flex items-center gap-2 px-8 py-3 border border-border text-sm font-medium text-primary hover:bg-primary hover:text-white hover:border-primary transition-colors rounded-full"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
          </svg>
          <span data-i18n="support.back_to_list">목록으로 돌아가기</span>
        </a>
      </div>

    </div>
  </section>
</BaseLayout>
