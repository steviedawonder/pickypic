---
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import { supportGuides } from '@data/support';

const title = '고객지원 페이지 | 피키픽 | 포토부스 대여 및 기업 행사 렌탈 전문';
const description = '피키픽 포토부스 제품별 가이드파일 다운로드. 부스형, 스탠드형, 테이블형 포토부스 가이드를 확인하세요.';

const products = supportGuides.map((g) => ({
  image: g.image,
  name: g.name,
  category: g.category,
  link: `/support/${g.slug}`,
}));

const categories = [
  { label: '전체', i18nKey: 'support.cat_all' },
  { label: '부스형', i18nKey: 'support.cat_booth' },
  { label: '스탠드형', i18nKey: 'support.cat_stand' },
  { label: '테이블형', i18nKey: 'support.cat_table' },
];
---

<BaseLayout title={title} description={description}>
  <BreadcrumbSchema items={[
    { name: '홈', href: '/' },
    { name: '고객지원', href: '/support' },
  ]} />

  <section class="pt-4 pb-20 lg:pt-4 lg:pb-28 bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">

      <!-- Title -->
      <div class="text-center mb-6 lg:mb-10 gs-fade-up">
        <h1 class="text-2xl lg:text-[clamp(2rem,4vw,3.5rem)] font-bold tracking-tight text-primary leading-tight" data-i18n="support.title">
          고객지원
        </h1>
      </div>

      <!-- Search Bar -->
      <div class="max-w-xs lg:max-w-sm mx-auto mb-6 lg:mb-8 gs-fade-up">
        <div class="relative">
          <input
            type="search"
            id="support-search"
            placeholder="Search"
            aria-label="제품 검색"
            class="w-full border border-border py-2 pl-4 pr-10 text-sm text-primary placeholder:text-secondary-light focus:outline-none focus:border-primary transition-colors"
          />
          <button type="button" aria-label="검색" class="absolute right-3 top-1/2 -translate-y-1/2 text-secondary-light hover:text-primary transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Subtitle -->
      <p class="text-sm lg:text-lg text-secondary mb-4 lg:mb-8 text-center gs-fade-up" data-i18n="support.subtitle">
        피키픽 포토부스 가이드파일 다운로드
      </p>

      <!-- Category filter tabs -->
      <nav aria-label="제품 카테고리 필터" class="mb-8 lg:mb-12 gs-fade-up">
        <ul class="flex flex-nowrap gap-0 border border-border rounded-md overflow-hidden max-w-md mx-auto lg:max-w-none lg:justify-center lg:border-0 lg:gap-2" role="tablist">
          {categories.map((cat, i) => (
            <li role="presentation" class="flex-1 lg:flex-initial">
              <button
                type="button"
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                data-category={cat.label}
                class:list={[
                  'category-tab w-full lg:w-auto px-4 lg:px-5 py-2 text-xs lg:text-sm font-medium transition-colors',
                  i === 0
                    ? 'bg-primary text-white'
                    : 'bg-bg-light text-secondary hover:bg-border-light',
                ]}
                data-i18n={cat.i18nKey}
              >
                {cat.label}
              </button>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Product guide cards grid -->
      <div id="product-grid" class="grid grid-cols-2 lg:grid-cols-3 gap-3 lg:gap-6 gs-stagger">
        {products.map((product) => (
          <a
            href={product.link}
            class="product-card border border-border-light rounded-xl lg:rounded-2xl overflow-hidden hover:border-primary/30 hover:shadow-md transition-all duration-300 flex flex-col cursor-pointer"
            data-category={product.category}
            data-name={product.name}
          >
            <div class="flex items-center justify-center p-3 lg:p-6">
              <img
                src={product.image}
                alt={`${product.name} 가이드`}
                class="w-full h-auto object-contain"
                loading="lazy"
                decoding="async"
              />
            </div>
          </a>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden py-20 text-center text-secondary">
        <p class="text-lg" data-i18n="support.no_results">검색 결과가 없습니다.</p>
      </div>

    </div>
  </section>

  <script>
    function initSupportFilters() {
      const tabs = document.querySelectorAll<HTMLButtonElement>('.category-tab');
      const cards = document.querySelectorAll<HTMLElement>('.product-card');
      const searchInput = document.querySelector<HTMLInputElement>('#support-search');
      const emptyState = document.getElementById('empty-state');
      const grid = document.getElementById('product-grid');

      let activeCategory = '전체';

      function filterCards() {
        const searchTerm = (searchInput?.value ?? '').toLowerCase().trim();
        let visibleCount = 0;

        cards.forEach((card) => {
          const cardCategory = card.getAttribute('data-category') ?? '';
          const cardName = (card.getAttribute('data-name') ?? '').toLowerCase();

          const matchesCategory = activeCategory === '전체' || cardCategory === activeCategory;
          const matchesSearch = !searchTerm || cardName.includes(searchTerm);

          if (matchesCategory && matchesSearch) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        if (emptyState && grid) {
          emptyState.classList.toggle('hidden', visibleCount > 0);
          grid.classList.toggle('hidden', visibleCount === 0);
        }
      }

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          tabs.forEach((t) => {
            t.classList.remove('bg-primary', 'text-white');
            t.classList.add('bg-bg-light', 'text-secondary');
            t.setAttribute('aria-selected', 'false');
          });
          tab.classList.remove('bg-bg-light', 'text-secondary');
          tab.classList.add('bg-primary', 'text-white');
          tab.setAttribute('aria-selected', 'true');

          activeCategory = tab.getAttribute('data-category') ?? '전체';
          filterCards();
        });
      });

      searchInput?.addEventListener('input', filterCards);
    }

    document.addEventListener('DOMContentLoaded', initSupportFilters);
    document.addEventListener('astro:after-swap', initSupportFilters);
  </script>
</BaseLayout>
