---
export const prerender = false;

import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import TextHero from '@components/common/TextHero.astro';
import BlogCard from '@components/blog/BlogCard.astro';
import { createClient } from '@sanity/client';

const sanityClient = createClient({
  projectId: '7b9lcco4',
  dataset: 'production',
  useCdn: true,
  apiVersion: '2024-01-01',
});

let posts: any[] = [];
let rawCategories: any[] = [];
try {
  posts = await sanityClient.fetch(`*[_type == "blogPost" && publishedAt != null] | order(publishedAt desc) {
    _id, title, slug, excerpt, publishedAt,
    mainImage { asset-> { _id, url } },
    category-> { title, slug },
    author-> { name },
    "estimatedReadingTime": round(length(pt::text(body)) / 500)
  }`);
  rawCategories = await sanityClient.fetch(`*[_type == "blogCategory"] {
    title, slug,
    "postCount": count(*[_type == "blogPost" && publishedAt != null && references(^._id)])
  }`);
} catch (e) {
  // Sanity 접속 실패 시 빈 목록 표시
}

const totalCount = posts.length;
const categories = [
  { title: '전체', slug: { current: 'all' }, postCount: totalCount },
  ...rawCategories.filter((c: any) => c.postCount > 0),
];
---

<BaseLayout
  title="포토부스 블로그 · 렌탈 가이드 | 피키픽 PICKYPIC"
  description="포토부스 대여 가이드, 렌탈 트렌드, 브랜드 팝업 사례 등 유용한 정보를 제공합니다. 피키픽 블로그에서 최신 포토부스 소식을 확인하세요."
>
  <!-- Blog CollectionPage Schema -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "피키픽 블로그",
    "description": "포토부스 트렌드, 렌탈 가이드, 브랜드 팝업 사례 등 유용한 정보를 제공합니다.",
    "url": "https://picky-pic.com/blog",
    "publisher": { "@type": "Organization", "@id": "https://picky-pic.com/#organization" },
    "inLanguage": "ko"
  })} />

  <BreadcrumbSchema items={[
    { name: '홈', href: '/' },
    { name: '블로그', href: '/blog' },
  ]} />

  <TextHero
    subtitle="Blog"
    title="블로그"
    description="포토부스에 대한 트렌드, 가이드, 사례를 공유합니다."
    titleI18n="blog.title"
    descriptionI18n="blog.description"
  />

  <section class="py-20 lg:py-28 bg-white">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <!-- Category Filter -->
      <div class="flex flex-wrap justify-center gap-2 mb-12 lg:mb-16 gs-fade-up" id="blog-filter">
        {categories.map((cat) => (
          <button
            class:list={[
              'px-4 py-2 text-xs font-medium tracking-[0.05em] transition-all duration-300 cursor-pointer border',
              cat.slug.current === 'all'
                ? 'bg-primary text-white border-primary'
                : 'bg-white text-secondary border-border-light hover:border-primary hover:text-primary',
            ]}
            data-filter={cat.slug.current}
          >
            {cat.title}
            <span class="ml-1 text-[10px] opacity-60">{cat.postCount}</span>
          </button>
        ))}
      </div>

      <!-- Blog Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10 gs-stagger" id="blog-grid">
        {posts.map((post) => (
          <div data-category={post.category?.title}>
            <BlogCard post={post} />
          </div>
        ))}
      </div>

      <!-- Empty State -->
      <div id="blog-empty" class="hidden text-center py-16">
        <p class="text-secondary" data-i18n="blog.empty_category">해당 카테고리의 포스트가 없습니다.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function initBlogFilter() {
    const filterContainer = document.getElementById('blog-filter');
    const grid = document.getElementById('blog-grid');
    const empty = document.getElementById('blog-empty');
    if (!filterContainer || !grid) return;

    const buttons = filterContainer.querySelectorAll('button');
    const items = grid.querySelectorAll<HTMLElement>('[data-category]');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');

        buttons.forEach((b) => {
          b.classList.remove('bg-primary', 'text-white', 'border-primary');
          b.classList.add('bg-white', 'text-secondary', 'border-border-light');
        });
        btn.classList.remove('bg-white', 'text-secondary', 'border-border-light');
        btn.classList.add('bg-primary', 'text-white', 'border-primary');

        let visibleCount = 0;
        items.forEach((item) => {
          if (filter === 'all' || item.dataset.category === btn.textContent?.trim().split('\n')[0]?.trim()) {
            item.style.display = '';
            visibleCount++;
          } else {
            item.style.display = 'none';
          }
        });

        if (empty) {
          empty.classList.toggle('hidden', visibleCount > 0);
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initBlogFilter);
  document.addEventListener('astro:after-swap', initBlogFilter);
</script>
