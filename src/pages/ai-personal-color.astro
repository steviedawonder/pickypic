---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="A.I 퍼스널컬러 | 피키픽 | 포토부스 대여 및 기업 행사 렌탈 전문"
  description="피키픽 포토부스의 AI 기반 퍼스널 컬러 진단 포토부스. 최신 AI 기술을 활용한 개인 맞춤형 컬러 진단 서비스."
>
  <section class="pt-28 pb-16 lg:pt-40 lg:pb-24 bg-white">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <div class="text-center mb-8 lg:mb-12 gs-fade-up">
        <h1 class="text-2xl lg:text-[clamp(2rem,4vw,3.5rem)] font-bold tracking-tight text-primary leading-tight">
          A.I 퍼스널 컬러 진단 포토부스
        </h1>
      </div>

      <div class="gs-fade-up">
        <img
          src="/images/ai-personal-color/personal-color.jpg"
          alt="AI 퍼스널 컬러 진단 포토부스"
          class="w-full rounded-lg"
        />
      </div>
    </div>
  </section>
</BaseLayout>
