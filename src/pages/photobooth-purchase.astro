<script>
  function initProductModal() {
    const modal = document.getElementById('product-modal');
    const backdrop = document.getElementById('modal-backdrop');
    const closeBtn = document.getElementById('modal-close');
    if (!modal || !backdrop || !closeBtn) return;

    const productsData = JSON.parse(document.getElementById('products-data')?.textContent || '[]');
    const productById: Record<string, any> = {};
    productsData.forEach((p: any) => { productById[p.id] = p; });

    // Size classes for mini/retro types
    const smallTypes = ['modern-mini-picky', 'urban-mini-picky', 'modern-retro-picky', 'urban-retro-picky'];

    function openModal(productId: string) {
      const product = productById[productId];
      if (!product) return;

      const isSmall = smallTypes.includes(productId);
      const maxH = isSmall ? 'max-h-[320px]' : 'max-h-[420px]';

      // Title
      (document.getElementById('modal-type') as HTMLElement).textContent = product.type;
      (document.getElementById('modal-name') as HTMLElement).textContent = `${product.name} | ${product.nameKo}`;

      // Desktop images
      const imgLeft = document.getElementById('modal-img-left') as HTMLImageElement;
      const imgRight = document.getElementById('modal-img-right') as HTMLImageElement;
      imgLeft.src = product.imageLeft;
      imgLeft.alt = `${product.name} ${product.nameKo} 라인 이미지`;
      imgLeft.className = `max-w-full ${maxH}`;
      imgRight.src = product.imageRight;
      imgRight.alt = `${product.name} ${product.nameKo} 제품 이미지`;
      imgRight.className = `max-w-full ${maxH}`;

      // Mobile images
      const imgLeftM = document.getElementById('modal-img-left-m') as HTMLImageElement;
      const imgRightM = document.getElementById('modal-img-right-m') as HTMLImageElement;
      imgLeftM.src = product.imageLeft;
      imgLeftM.alt = imgLeft.alt;
      imgRightM.src = product.imageRight;
      imgRightM.alt = imgRight.alt;

      // Spec tables
      const specHtml = product.specs.map((s: any) =>
        `<tr class="border-b border-border-light">
          <th class="text-left py-2 pr-4 font-semibold text-primary text-xs whitespace-nowrap align-top w-[140px]">${s.label}</th>
          <td class="py-2 text-secondary text-xs leading-relaxed">${s.value}</td>
        </tr>`
      ).join('');
      (document.getElementById('modal-specs-desktop') as HTMLElement).innerHTML = specHtml;
      (document.getElementById('modal-specs-mobile') as HTMLElement).innerHTML = specHtml;

      // Show modal
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    // Event listeners
    document.querySelectorAll<HTMLTableRowElement>('.product-row').forEach(row => {
      row.addEventListener('click', () => {
        const id = row.dataset.productId;
        if (id) openModal(id);
      });
    });

    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
    });
  }

  document.addEventListener('DOMContentLoaded', initProductModal);
  document.addEventListener('astro:after-swap', initProductModal);
</script>
