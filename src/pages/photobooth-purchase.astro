---
// SEO landing page for photo booth purchase keywords
// Target keywords: 포토부스 구매, 포토부스 판매, 포토부스 기기 구매, 포토부스 구매 가격, 오픈형 포토부스 구매, 포토부스 기기
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import FAQSchema from '@components/seo/FAQSchema.astro';
import { company } from '@data/company';
import { products } from '@data/products';

// Product ID to display name mapping for table rows
const productMap: Record<string, typeof products[0]> = {};
products.forEach(p => { productMap[p.id] = p; });

// FAQ items for structured data
const faqItems = [
  {
    question: '포토부스 구매 가격대는 어떻게 되나요?',
    answer: 'PICKYPIC 포토부스는 모델에 따라 가격이 다릅니다. 테이블형 레트로피키는 소형 기기로 가장 합리적인 가격대이며, 스탠드형 모던피키·클래식피키·어반피키는 중간 가격대, 부스형 아웃도어피키·에어피키는 대형 기기로 가격이 높습니다. 정확한 견적은 모델, 수량, 커스터마이징 옵션에 따라 달라지므로 문의 주시면 맞춤 견적을 안내해 드립니다.',
  },
  {
    question: '포토부스 배송은 어떻게 진행되나요?',
    answer: '국내 배송은 서울·수도권 기준 직접 배송 및 설치를 지원하며, 지방의 경우 택배 또는 화물 배송이 가능합니다. 해외 배송은 항공(Air Freight) 및 해상(Ocean Freight) 운송을 모두 지원하며, 현재 싱가포르를 비롯한 동남아시아, 일본 등에 수출 실적이 있습니다.',
  },
  {
    question: '포토부스 설치가 어렵지 않나요?',
    answer: '스탠드형과 테이블형은 간단한 조립으로 설치할 수 있으며, 설치 매뉴얼과 영상 가이드를 제공합니다. 부스형(아웃도어피키, 에어피키)은 전문 설치 지원이 포함됩니다. 무인사진관 창업 시에는 공간 컨설팅부터 설치까지 원스톱으로 지원해 드립니다.',
  },
  {
    question: '구매 후 A/S(애프터서비스)는 어떻게 받나요?',
    answer: 'PICKYPIC은 자체 설계·제조 기업으로 부품부터 소프트웨어까지 직접 관리합니다. 구매 후 1년간 무상 A/S를 제공하며, 이후에도 유상 A/S를 합리적인 비용으로 지원합니다. 원격 소프트웨어 업데이트, 부품 교체, 현장 출장 수리 등 다양한 A/S 옵션이 있습니다.',
  },
  {
    question: '해외에서도 포토부스를 구매할 수 있나요?',
    answer: '네, 해외 배송이 가능합니다. 항공 및 해상 운송을 통해 전 세계로 배송하며, 영어·일본어 UI 지원도 가능합니다. 현재 싱가포르에 지사(PICKYPIC SG)를 운영 중이며, 동남아시아 지역은 현지 설치 지원도 제공합니다.',
  },
  {
    question: '포토부스 커스터마이징(맞춤 제작)이 가능한가요?',
    answer: '모든 PICKYPIC 포토부스는 외관 래핑, UI 화면 디자인, 인쇄 템플릿 디자인 등 커스터마이징이 가능합니다. 브랜드 컬러와 로고를 반영한 맞춤형 포토부스를 제작할 수 있어, 무인사진관 창업이나 브랜드 매장 설치 시 차별화된 경험을 제공합니다.',
  },
];
---

<BaseLayout
  title="포토부스 구매 · 포토부스 판매 | 9종 라인업 제조사 직접 판매 - PICKYPIC"
  description="포토부스 구매를 고려하시나요? PICKYPIC은 스탠드형·테이블형·부스형 9종 이상의 포토부스를 자체 설계·제조·판매합니다. 무인사진관 창업, 카페, 이벤트업체를 위한 포토부스 기기 구매 가이드와 가격 정보를 확인하세요."
>
  <!-- Breadcrumb Schema -->
  <BreadcrumbSchema items={[
    { name: '홈', href: '/' },
    { name: '포토부스 구매', href: '/photobooth-purchase' },
  ]} />

  <!-- FAQ Schema -->
  <FAQSchema items={faqItems} title="포토부스 구매 자주 묻는 질문" />

  <!-- Hero Section -->
  <section class="pt-16 pb-10 lg:pt-20 lg:pb-14 bg-white">
    <div class="mx-auto max-w-4xl px-6 lg:px-8 text-center">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-black tracking-tight text-primary mb-6 gs-fade-up">
        포토부스 구매 · 판매
      </h1>
      <p class="text-base sm:text-lg text-secondary leading-relaxed max-w-3xl mx-auto gs-fade-up">
        PICKYPIC은 <strong>9종 이상의 프리미엄 포토부스</strong>를 자체 설계·제조·판매하는 포토부스 전문 기업입니다.
        테이블 위에 올려놓는 미니 포토부스부터 독립형 풀사이즈 부스까지, 용도와 공간에 맞는 최적의 포토부스 기기를 제공합니다.
        넷플릭스, 현대자동차, 스타벅스 등 1,000건 이상의 행사에서 검증된 품질을 경험하세요.
      </p>
    </div>
  </section>

  <!-- Purchase Guide Section -->
  <section class="py-12 lg:py-16 bg-bg-muted" aria-labelledby="guide-heading">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      <h2 id="guide-heading" class="text-2xl sm:text-3xl font-bold text-primary text-center mb-4 gs-fade-up">
        포토부스 구매 가이드
      </h2>
      <p class="text-secondary text-center mb-10 max-w-2xl mx-auto gs-fade-up">
        어떤 업종에서 포토부스가 필요하신가요? 목적에 맞는 포토부스를 추천해 드립니다.
      </p>

      <div class="grid md:grid-cols-3 gap-6 lg:gap-8 gs-stagger">
        <!-- Cafe / Unmanned Photo Studio -->
        <div class="bg-white rounded-xl p-6 lg:p-8 border border-border-default">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016c.896 0 1.7-.393 2.25-1.015a3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-primary mb-2">카페 · 무인사진관 창업</h3>
          <p class="text-secondary text-sm leading-relaxed mb-3">
            무인 운영이 가능한 스탠드형 포토부스가 적합합니다. 카드·코인·쿠폰 결제를 지원하며, 자동 인쇄까지 원스톱으로 운영됩니다.
          </p>
          <p class="text-xs text-primary font-medium">추천: 모던피키 · 클래식피키 · 어반피키</p>
        </div>

        <!-- Event / Brand Popup -->
        <div class="bg-white rounded-xl p-6 lg:p-8 border border-border-default">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-primary mb-2">이벤트 · 브랜드 팝업</h3>
          <p class="text-secondary text-sm leading-relaxed mb-3">
            이동과 설치가 간편한 테이블형 미니 포토부스가 인기입니다. 외관 래핑과 UI 커스터마이징으로 브랜드 아이덴티티를 반영할 수 있습니다.
          </p>
          <p class="text-xs text-primary font-medium">추천: 모던 미니피키 · 어반 미니피키 · 레트로피키</p>
        </div>

        <!-- Large Venue / Permanent Installation -->
        <div class="bg-white rounded-xl p-6 lg:p-8 border border-border-default">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-primary mb-2">대형 매장 · 상설 운영</h3>
          <p class="text-secondary text-sm leading-relaxed mb-3">
            프라이빗한 촬영 공간이 필요하다면 부스형을 추천합니다. 21인치 대형 모니터와 DSLR 카메라로 최상의 촬영 품질을 제공합니다.
          </p>
          <p class="text-xs text-primary font-medium">추천: 아웃도어피키 · 에어피키</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Lineup Summary -->
  <section class="py-12 lg:py-16 bg-white" aria-labelledby="lineup-heading">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      <h2 id="lineup-heading" class="text-2xl sm:text-3xl font-bold text-primary text-center mb-10 gs-fade-up">
        포토부스 제품 라인업
      </h2>

      <!-- Stand Type -->
      <div class="mb-10 gs-fade-up">
        <h3 class="text-lg font-bold text-primary mb-1 flex items-center gap-2">
          <span class="inline-block w-2 h-2 bg-primary rounded-full"></span>
          스탠드형 포토부스 — 3종
        </h3>
        <p class="text-xs text-secondary mb-4 ml-4">무인사진관·카페에 최적화된 독립형 포토부스</p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse min-w-[600px]">
            <thead>
              <tr class="border-b-2 border-primary">
                <th class="text-left py-3 pr-4 font-semibold text-primary">모델명</th>
                <th class="text-left py-3 pr-4 font-semibold text-primary">카메라</th>
                <th class="text-left py-3 pr-4 font-semibold text-primary">디스플레이</th>
                <th class="text-left py-3 pr-4 font-semibold text-primary">소재</th>
                <th class="text-left py-3 pr-4 font-semibold text-primary">크기 (mm)</th>
                <th class="text-left py-3 font-semibold text-primary">무게</th>
              </tr>
            </thead>
            <tbody>
              <tr class="product-row border-b border-border-light cursor-pointer hover:bg-primary/5 transition-colors duration-200" data-product-id="modern-picky">
                <td class="py-3 pr-4 font-medium text-primary">모던피키<br><span class="text-xs text-secondary">Modern Picky</span></td>
                <td class="py-3 pr-4 text-secondary">DSLR</td>
                <td class="py-3 pr-4 text-secondary">13인치</td>
                <td class="py-3 pr-4 text-secondary">우드</td>
                <td class="py-3 pr-4 text-secondary">550×550×1570</td>
                <td class="py-3 text-secondary">30kg</td>
              </tr>
              <tr class="product-row border-b border-border-light cursor-pointer hover:bg-primary/5 transition-colors duration-200" data-product-id="classic-picky">
                <td class="py-3 pr-4 font-medium text-primary">클래식피키<br><span class="text-xs text-secondary">Classic Picky</span></td>
                <td class="py-3 pr-4 text-secondary">DSLR</td>
                <td class="py-3 pr-4 text-secondary">13인치</td>
                <td class="py-3 pr-4 text-secondary">우드</td>
                <td class="py-3 pr-4 text-secondary">550×550×1570</td>
                <td class="py-3 text-secondary">23kg</td>
              </tr>
              <tr class="product-row border-b border-border-light cursor-pointer hover:bg-primary/5 transition-colors duration-200" data-product-id="urban-picky">
                <td class="py-3 pr-4 font-medium text-primary">어반피키<br><span class="text-xs text-secondary">Urban Picky</span></td>
                <td class="py-3 pr-4 text-secondary">DSLR</td>
                <td class="py-3 pr-4 text-secondary">13인치</td>
                <td class="py-3 pr-4 text-secondary">아크릴</td>
                <td class="py-3 pr-4 text-secondary">550×550×1440</td>
                <td class="py-3 text-secondary">40kg</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Table Type -->
      <div class="mb-10 gs-fade-up">
        <h3 class="text-lg font-bold text-primary mb-1 flex items-center gap-2">
          <span class="inline-block w-2 h-2 bg-primary rounded-full"></span>
          테이블형 포토부스 — 4종
        </h3>
        <p class="text-xs text-secondary mb-4 ml-4">이동이 간편한 컴팩트 사이즈, 이벤트·팝업에 최적</p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse min-w-[600px]">
            <thead>
              <tr class="border-b-2 border-primary">
                <th class="text-left py-3 pr-4 font-semibold text-primary">모델명</th>
                <th class="text-left py-3 pr-4 font-semibold text-primary">카메라</th>
                <th class="text-left py-3 pr-4 font-semibold text-primary">디스플레이</th>
                <th class="text-left py-3 pr-4 font-semibold text-primary">소재</th>
                <th class="text-left py-3 pr-4 font-semibold text-primary">크기 (mm)</th>
                <th class="text-left py-3 font-semibold text-primary">무게</th>
              </tr>
            </thead>
            <tbody>
              <tr class="product-row border-b border-border-light cursor-pointer hover:bg-primary/5 transition-colors duration-200" data-product-id="modern-mini-picky">
                <td class="py-3 pr-4 font-medium text-primary">모던 미니피키<br><span class="text-xs text-secondary">Modern Mini Picky</span></td>
                <td class="py-3 pr-4 text-secondary">웹캠</td>
                <td class="py-3 pr-4 text-secondary">11.6인치</td>
                <td class="py-3 pr-4 text-secondary">우드</td>
                <td class="py-3 pr-4 text-secondary">330×330×390</td>
                <td class="py-3 text-secondary">15kg</td>
              </tr>
              <tr class="product-row border-b border-border-light cursor-pointer hover:bg-primary/5 transition-colors duration-200" data-product-id="urban-mini-picky">
                <td class="py-3 pr-4 font-medium text-primary">어반 미니피키<br><span class="text-xs text-secondary">Urban Mini Picky</span></td>
                <td class="py-3 pr-4 text-secondary">웹캠</td>
                <td class="py-3 pr-4 text-secondary">11.6인치</td>
                <td class="py-3 pr-4 text-secondary">아크릴</td>
                <td class="py-3 pr-4 text-secondary">350×350×400</td>
                <td class="py-3 text-secondary">15kg</td>
              </tr>
              <tr class="product-row border-b border-border-light cursor-pointer hover:bg-primary/5 transition-colors duration-200" data-product-id="modern-retro-picky">
                <td class="py-3 pr-4 font-medium text-primary">모던 레트로피키<br><span class="text-xs text-secondary">Modern Retro Picky</span></td>
                <td class="py-3 pr-4 text-secondary">태블릿 내장</td>
                <td class="py-3 pr-4 text-secondary">8.7인치</td>
                <td class="py-3 pr-4 text-secondary">우드</td>
                <td class="py-3 pr-4 text-secondary">290×290×310</td>
                <td class="py-3 text-secondary">5kg</td>
              </tr>
              <tr class="product-row border-b border-border-light cursor-pointer hover:bg-primary/5 transition-colors duration-200" data-product-id="urban-retro-picky">
                <td class="py-3 pr-4 font-medium text-primary">어반 레트로피키<br><span class="text-xs text-secondary">Urban Retro Picky</span></td>
                <td class="py-3 pr-4 text-secondary">태블릿 내장</td>
                <td class="py-3 pr-4 text-secondary">8.7인치</td>
                <td class="py-3 pr-4 text-secondary">아크릴</td>
                <td class="py-3 pr-4 text-secondary">190×230×316</td>
                <td class="py-3 text-secondary">5kg</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Booth Type -->
      <div class="gs-fade-up">
        <h3 class="text-lg font-bold text-primary mb-1 flex items-center gap-2">
          <span class="inline-block w-2 h-2 bg-primary rounded-full"></span>
