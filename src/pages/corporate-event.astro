// Process steps
const processSteps = [
  { step: '01', title: '문의 및 상담', description: '행사 일정, 규모, 콘셉트를 알려주시면 최적의 부스와 견적을 안내드립니다.' },
  { step: '02', title: '맞춤 기획', description: '기업 CI/BI에 맞는 프레임 디자인, 배경, 시작화면 등을 커스터마이징합니다.' },
