---
import '../styles/global.css';
import Navbar from '@components/common/Navbar.astro';
import Footer from '@components/common/Footer.astro';
import FloatingContactButton from '@components/common/FloatingContactButton.astro';
import { company } from '@data/company';

interface ArticleMeta {
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  section?: string;
  tags?: string[];
}

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  articleMeta?: ArticleMeta;
}

const {
  title = `${company.brandKo} | PICKYPIC`,
  description = '피키픽 포토부스 - 포토부스 렌탈/대여 전문. 브랜드 팝업, 기업 행사, 웨딩 등 다양한 이벤트에 맞춤형 포토부스를 제공합니다.',
  ogImage = '/images/common/og-image.jpg',
  ogType = 'website',
  noindex = false,
  articleMeta,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    )}
    <meta name="theme-color" content="#ffffff" />

    <!-- Google Search Console -->
    <meta name="google-site-verification" content="XALCn56VEHtBbtrm49DnZH2WdT3ccOizTGKTkTHsIns" />

    <!-- Naver Search Advisor -->
    <meta name="naver-site-verification" content="062e44a0df871ea7efc1955b667ed80346b8d5ef" />

    <!-- Google Analytics 4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-YG5KHLQHJ9"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YG5KHLQHJ9');
    </script>

    <!-- Hreflang -->
    <link rel="alternate" hreflang="ko" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="ja" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-KDRFNN4H');
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:locale:alternate" content="ja_JP" />
    <meta property="og:site_name" content="PICKYPIC" />
    {articleMeta?.publishedTime && <meta property="article:published_time" content={articleMeta.publishedTime} />}
    {articleMeta?.modifiedTime && <meta property="article:modified_time" content={articleMeta.modifiedTime} />}
    {articleMeta?.author && <meta property="article:author" content={articleMeta.author} />}
    {articleMeta?.section && <meta property="article:section" content={articleMeta.section} />}
    {articleMeta?.tags?.map(tag => <meta property="article:tag" content={tag} />)}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
    <meta name="twitter:site" content="@pickypic_official" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/pickypic_logo.png" />
    <link rel="apple-touch-icon" href="/pickypic_logo.png" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Font Preload: Bebas Neue (local) -->
    <link rel="preload" href="/fonts/BebasNeue-Regular.ttf" as="font" type="font/ttf" crossorigin />

    <!-- Google Fonts: Noto Sans KR & Montserrat -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Noto+Sans+KR:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Structured Data: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": "https://picky-pic.com/#organization",
      "name": company.brand,
      "legalName": company.name,
      "alternateName": company.brandKo,
      "url": company.url,
      "logo": company.logo,
      "image": company.logo,
      "description": company.description,
      "telephone": company.phone,
      "email": company.email,
      "foundingDate": company.foundingDate,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "성수이로18길 31, 602호",
        "addressLocality": "성동구",
        "addressRegion": "서울특별시",
        "postalCode": "04790",
        "addressCountry": "KR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": company.geo.lat,
        "longitude": company.geo.lng
      },
      "sameAs": company.sameAs,
      "knowsLanguage": ["ko", "en", "ja"],
      "areaServed": [
        { "@type": "Country", "name": "KR" },
        { "@type": "Country", "name": "SG" }
      ],
      "serviceType": "포토부스 렌탈"
    })} />

    <!-- Structured Data: WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "PICKYPIC PHOTOBOOTH",
      "alternateName": "피키픽 포토부스",
      "url": company.url,
      "inLanguage": ["ko", "en", "ja"],
      "publisher": {
        "@type": "Organization",
        "@id": "https://picky-pic.com/#organization",
        "name": company.brand
      }
    })} />

    <!-- Page-specific structured data slot -->
    <slot name="head" />

    <title>{title}</title>
    <script is:inline>
      (function() {
        var lang = localStorage.getItem('pickypic-lang');
        if (lang && lang !== 'ko') {
          document.documentElement.style.visibility = 'hidden';
        }
      })();
    </script>
    <!-- Hide page until fonts are loaded to prevent FOUT -->
    <style>
      .fonts-loading { opacity: 0; }
      .fonts-loaded { opacity: 1; transition: opacity 0.1s ease-in; }
    </style>
    <script is:inline>
      document.documentElement.classList.add('fonts-loading');
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(function() {
          document.documentElement.classList.remove('fonts-loading');
          document.documentElement.classList.add('fonts-loaded');
        });
      } else {
        // Fallback for browsers without Font Loading API
        window.addEventListener('load', function() {
          document.documentElement.classList.remove('fonts-loading');
          document.documentElement.classList.add('fonts-loaded');
        });
      }
      // Safety timeout: show page after 2s even if fonts fail
      setTimeout(function() {
        document.documentElement.classList.remove('fonts-loading');
        document.documentElement.classList.add('fonts-loaded');
      }, 2000);
    </script>
  </head>
  <body class="bg-white text-primary antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KDRFNN4H"
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <FloatingContactButton />

    <!-- i18n Language Switching -->
    <script>
      import '../i18n/i18n';
    </script>

    <!-- GSAP ScrollTrigger -->
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      function initAnimations() {
        // Fade up
        gsap.utils.toArray('.gs-fade-up').forEach((el) => {
          const element = el as HTMLElement;
          gsap.fromTo(
            element,
            { opacity: 0, y: 60 },
            {
              opacity: 1,
              y: 0,
              duration: 1,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        // Fade in
        gsap.utils.toArray('.gs-fade-in').forEach((el) => {
          const element = el as HTMLElement;
          gsap.fromTo(
            element,
            { opacity: 0 },
            {
              opacity: 1,
              duration: 1.2,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        // Slide left
        gsap.utils.toArray('.gs-slide-left').forEach((el) => {
          const element = el as HTMLElement;
          const xOffset = window.innerWidth >= 768 ? -80 : -40;
          gsap.fromTo(
            element,
            { opacity: 0, x: xOffset },
            {
              opacity: 1,
              x: 0,
              duration: 1,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        // Slide right
        gsap.utils.toArray('.gs-slide-right').forEach((el) => {
          const element = el as HTMLElement;
          gsap.fromTo(
            element,
            { opacity: 0, x: 80 },
            {
              opacity: 1,
              x: 0,
              duration: 1,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        // Scale in
        gsap.utils.toArray('.gs-scale-in').forEach((el) => {
          const element = el as HTMLElement;
          gsap.fromTo(
            element,
            { opacity: 0, scale: 0.9 },
            {
              opacity: 1,
              scale: 1,
              duration: 1.2,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        // Stagger children
        gsap.utils.toArray('.gs-stagger').forEach((el) => {
          const element = el as HTMLElement;
          const children = element.children;
          gsap.fromTo(
            children,
            { opacity: 0, y: 40 },
            {
              opacity: 1,
              y: 0,
              duration: 0.8,
              ease: 'power3.out',
              stagger: 0.1,
              scrollTrigger: {
                trigger: element,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });
      }

      document.addEventListener('DOMContentLoaded', initAnimations);
      document.addEventListener('astro:after-swap', initAnimations);
    </script>
  </body>
</html>
