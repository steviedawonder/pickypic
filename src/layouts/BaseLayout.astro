---
import '../styles/global.css';
import Navbar from '@components/common/Navbar.astro';
import Footer from '@components/common/Footer.astro';
import FloatingContactButton from '@components/common/FloatingContactButton.astro';
import { company } from '@data/company';
import { sanityClient } from '../sanity/client';

let siteSettings: any = null;
try {
  siteSettings = await sanityClient.fetch(`*[_type == "siteSettings"][0] {
    headScripts, headMeta, headCustomCss, bodyStartScripts, bodyEndScripts,
    gtmContainerId, ga4MeasurementId, naverAnalyticsId, kakaoPixelId, metaPixelId,
    googleSiteVerification, naverSiteVerification, chatPluginCode
  }`);
} catch (e) { /* silent fail */ }

interface ArticleMeta {
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  section?: string;
  tags?: string[];
}

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  articleMeta?: ArticleMeta;
}

const {
  title = `${company.brandKo} | PICKYPIC`,
  description = '피키픽 포토부스 - 포토부스 렌탈/대여 전문. 브랜드 팝업, 기업 행사, 웨딩 등 다양한 이벤트에 맞춤형 포토부스를 제공합니다.',
  ogImage = '/images/common/og-image.jpg',
  ogType = 'website',
  noindex = false,
  articleMeta,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    )}
    <meta name="theme-color" content="#ffffff" />

    <!-- Google Search Console -->
    <meta name="google-site-verification" content="JW_ZpRY2Qb3YRrWB2wW7fOyxuIAox4hidSEUQHRLOks" />
    <meta name="google-site-verification" content={siteSettings?.googleSiteVerification || 'XALCn56VEHtBbtrm49DnZH2WdT3ccOizTGKTkTHsIns'} />

    <!-- Naver Search Advisor -->
    <meta name="naver-site-verification" content={siteSettings?.naverSiteVerification || '062e44a0df871ea7efc1955b667ed80346b8d5ef'} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="ko" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="ja" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <!-- Google Tag Manager -->
    <script is:inline define:vars={{ gtmId: siteSettings?.gtmContainerId || 'GTM-KDRFNN4H' }}>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer',gtmId);
    </script>

    <!-- GA4 (only if set AND GTM is not set in Sanity) -->
    {siteSettings?.ga4MeasurementId && !siteSettings?.gtmContainerId && (
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${siteSettings.ga4MeasurementId}`}></script>
    )}
    {siteSettings?.ga4MeasurementId && !siteSettings?.gtmContainerId && (
      <script is:inline define:vars={{ ga4Id: siteSettings.ga4MeasurementId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', ga4Id);
      </script>
    )}

    <!-- Naver Analytics -->
    {siteSettings?.naverAnalyticsId && (
      <script async src="https://wcs.naver.net/wcslog.js"></script>
    )}
    {siteSettings?.naverAnalyticsId && (
      <script is:inline define:vars={{ naverId: siteSettings.naverAnalyticsId }}>
        var wcs_add = wcs_add || {};wcs_add["wa"]=naverId;
        if(window.wcs){wcs_do();}
      </script>
    )}

    <!-- Kakao Pixel -->
    {siteSettings?.kakaoPixelId && (
      <script is:inline define:vars={{ kakaoId: siteSettings.kakaoPixelId }}>
        !function(e,t,n,a,s,c){e.kakaoPixel||(s=e.kakaoPixel=function(){s.queue.push(arguments)},s.queue=[],
        c=t.createElement(n),c.async=1,c.src='https://t1.daumcdn.net/kas/static/kp.js',
        t.head.appendChild(c))}(window,document,'script');
        kakaoPixel(kakaoId);
        kakaoPixel('pageView');
      </script>
    )}

    <!-- Meta (Facebook) Pixel -->
    {siteSettings?.metaPixelId && (
      <script is:inline define:vars={{ metaId: siteSettings.metaPixelId }}>
        !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
        n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
        t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
        document,'script','https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', metaId);
        fbq('track', 'PageView');
      </script>
    )}

    <!-- Custom head meta from Sanity -->
    {siteSettings?.headMeta && <Fragment set:html={siteSettings.headMeta} />}

    <!-- Custom head scripts from Sanity -->
    {siteSettings?.headScripts && <Fragment set:html={siteSettings.headScripts} />}

    <!-- Custom head CSS from Sanity -->
    {siteSettings?.headCustomCss && <style set:html={siteSettings.headCustomCss} />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:locale:alternate" content="ja_JP" />
    <meta property="og:site_name" content="PICKYPIC" />
    {articleMeta?.publishedTime && <meta property="article:published_time" content={articleMeta.publishedTime} />}
    {articleMeta?.modifiedTime && <meta property="article:modified_time" content={articleMeta.modifiedTime} />}
    {articleMeta?.author && <meta property="article:author" content={articleMeta.author} />}
    {articleMeta?.section && <meta property="article:section" content={articleMeta.section} />}
    {articleMeta?.tags?.map(tag => <meta property="article:tag" content={tag} />)}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
    <meta name="twitter:site" content="@pickypic_official" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/pickypic_logo.png" />
    <link rel="apple-touch-icon" href="/pickypic_logo.png" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Font Preload: Bebas Neue (local) -->
    <link rel="preload" href="/fonts/BebasNeue-Regular.ttf" as="font" type="font/ttf" crossorigin />

    <!-- Google Fonts: Noto Sans KR & Montserrat -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Noto+Sans+KR:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Structured Data: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": "https://picky-pic.com/#organization",
      "name": company.brand,
      "legalName": company.name,
      "alternateName": company.brandKo,
      "url": company.url,
      "logo": company.logo,
      "image": company.logo,
      "description": company.description,
      "telephone": company.phone,
      "email": company.email,
      "foundingDate": company.foundingDate,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "성수이로18길 31, 602호",
        "addressLocality": "성동구",
        "addressRegion": "서울특별시",
        "postalCode": "04790",
        "addressCountry": "KR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": company.geo.lat,
        "longitude": company.geo.lng
      },
      "sameAs": company.sameAs,
      "knowsLanguage": ["ko", "en", "ja"],
      "areaServed": [
        { "@type": "Country", "name": "KR" },
        { "@type": "Country", "name": "SG" }
      ],
      "serviceType": "포토부스 렌탈"
    })} />

    <!-- Structured Data: WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "PICKYPIC PHOTOBOOTH",
      "alternateName": "피키픽 포토부스",
      "url": company.url,
      "inLanguage": ["ko", "en", "ja"],
      "publisher": {
        "@type": "Organization",
        "@id": "https://picky-pic.com/#organization",
        "name": company.brand
      }
    })} />

    <!-- Page-specific structured data slot -->
    <slot name="head" />

    <title>{title}</title>
    <script is:inline>
      (function() {
        var lang = localStorage.getItem('pickypic-lang');
        if (lang && lang !== 'ko') {
          document.documentElement.style.visibility = 'hidden';
        }
      })();
    </script>
    <!-- Hide page until fonts are loaded to prevent FOUT -->
    <style>
      .fonts-loading { opacity: 0; }
      .fonts-loaded { opacity: 1; transition: opacity 0.1s ease-in; }
    </style>
    <script is:inline>
      document.documentElement.classList.add('fonts-loading');
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(function() {
          document.documentElement.classList.remove('fonts-loading');
          document.documentElement.classList.add('fonts-loaded');
        });
      } else {
        // Fallback for browsers without Font Loading API
        window.addEventListener('load', function() {
          document.documentElement.classList.remove('fonts-loading');
          document.documentElement.classList.add('fonts-loaded');
        });
      }
      // Safety timeout: show page after 2s even if fonts fail
      setTimeout(function() {
        document.documentElement.classList.remove('fonts-loading');
        document.documentElement.classList.add('fonts-loaded');
      }, 2000);
    </script>
  </head>
  <body class="bg-white text-primary antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe src={`https://www.googletagmanager.com/ns.html?id=${siteSettings?.gtmContainerId || 'GTM-KDRFNN4H'}`}
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    <!-- Body start scripts from Sanity -->
    {siteSettings?.bodyStartScripts && <Fragment set:html={siteSettings.bodyStartScripts} />}

    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <FloatingContactButton />

    <!-- i18n Language Switching -->
    <script>
      import '../i18n/i18n';
    </script>

    <!-- GSAP ScrollTrigger -->
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      function initAnimations() {
        // Fade up
        gsap.utils.toArray('.gs-fade-up').forEach((el) => {
          const element = el as HTMLElement;
          gsap.fromTo(
            element,
            { opacity: 0, y: 60 },
            {
              opacity: 1,
              y: 0,
              duration: 1,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        // Fade in
        gsap.utils.toArray('.gs-fade-in').forEach((el) => {
          const element = el as HTMLElement;
          gsap.fromTo(
            element,
            { opacity: 0 },
            {
              opacity: 1,
              duration: 1.2,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        // Slide left
        gsap.utils.toArray('.gs-slide-left').forEach((el) => {
          const element = el as HTMLElement;
          const xOffset = window.innerWidth >= 768 ? -80 : -40;
          gsap.fromTo(
            element,
            { opacity: 0, x: xOffset },
            {
              opacity: 1,
              x: 0,
              duration: 1,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        // Slide right
        gsap.utils.toArray('.gs-slide-right').forEach((el) => {
          const element = el as HTMLElement;
          gsap.fromTo(
            element,
            { opacity: 0, x: 80 },
            {
              opacity: 1,
              x: 0,
              duration: 1,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        // Scale in
        gsap.utils.toArray('.gs-scale-in').forEach((el) => {
          const element = el as HTMLElement;
          gsap.fromTo(
            element,
            { opacity: 0, scale: 0.9 },
            {
              opacity: 1,
              scale: 1,
              duration: 1.2,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: element,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        // Stagger children
        gsap.utils.toArray('.gs-stagger').forEach((el) => {
          const element = el as HTMLElement;
          const children = element.children;
          gsap.fromTo(
            children,
            { opacity: 0, y: 40 },
            {
              opacity: 1,
              y: 0,
              duration: 0.8,
              ease: 'power3.out',
              stagger: 0.1,
              scrollTrigger: {
                trigger: element,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });
      }

      document.addEventListener('DOMContentLoaded', initAnimations);
      document.addEventListener('astro:after-swap', initAnimations);
    </script>

    <!-- 채널톡 위젯 강제 제거 (GTM에서 로드됨) -->
    <script is:inline>
      (function removeChannelTalk() {
        var selectors = ['#ch-plugin', '#channel-io-plugin', '[id^="ch-plugin"]', '.ch-desk-messenger', '[class*="channel"]'];
        function remove() {
          selectors.forEach(function(sel) {
            document.querySelectorAll(sel).forEach(function(el) { el.remove(); });
          });
          // Also remove channel talk script
          if (window.ChannelIO) { try { window.ChannelIO('shutdown'); } catch(e) {} }
        }
        remove();
        setInterval(remove, 1000);
        var observer = new MutationObserver(remove);
        observer.observe(document.body, { childList: true, subtree: true });
      })();
    </script>

    <!-- Chat plugin from Sanity -->
    {siteSettings?.chatPluginCode && <Fragment set:html={siteSettings.chatPluginCode} />}

    <!-- Body end scripts from Sanity -->
    {siteSettings?.bodyEndScripts && <Fragment set:html={siteSettings.bodyEndScripts} />}
  </body>
</html>
