{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/support/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=604800"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/home",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/bbs/board.php",
      "has": [
        {
          "type": "query",
          "key": "bo_table",
          "value": "portfolio"
        }
      ],
      "destination": "/portfolio",
      "statusCode": 301
    },
    {
      "source": "/bbs/:path*",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/blog/피키픽-포토부스대여-가이드-모델하우스-렌탈-서비스-후기-2026-",
      "destination": "/blog/model-house-photobooth-rental-guide-2026",
      "statusCode": 301
    },
    {
      "source": "/blog/피키픽-포토부스대여-가이드-모델하우스-렌탈-서비스-후기-2026",
      "destination": "/blog/model-house-photobooth-rental-guide-2026",
      "statusCode": 301
    },
    {
      "source": "/blog/피키픽포토부스-브랜드-소개-포토부스대여구매렌탈장단기-선택-가이드-2026",
      "destination": "/blog/pickypic-photobooth-rental-purchase-guide-2026",
      "statusCode": 301
    }
  ]
}
